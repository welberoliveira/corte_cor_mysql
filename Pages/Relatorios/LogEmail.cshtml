@page
@model CorteCor.Pages.Relatorios.LogEmailModel
@{
    ViewData["Title"] = "Log de Envio de E-mails";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2>@ViewData["Title"]</h2>
        </div>
    </div>
    <br />

    <!-- Filtros -->
    <div class="card mb-3">
        <div class="card-header">Filtros</div>
        <div class="card-body">
            <form method="get" class="form-inlines">
                <div class="form-row">
                    <div class="form-group col-md-2">
                        <label>De:</label>
                        <input type="date" name="DataInicio" class="form-control" value="@Model.DataInicio?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="form-group col-md-2">
                        <label>Até:</label>
                        <input type="date" name="DataFim" class="form-control" value="@Model.DataFim?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="form-group col-md-3">
                        <label>Destinatário:</label>
                        <input type="text" name="Destinatario" class="form-control" value="@Model.Destinatario" placeholder="E-mail do destinatário" />
                    </div>
                    <div class="form-group col-md-3">
                        <label>Assunto:</label>
                        <input type="text" name="Assunto" class="form-control" value="@Model.Assunto" placeholder="Assunto do e-mail" />
                    </div>
                    <div class="form-group col-md-2">
                        <label>Status:</label>
                        <select name="Status" class="form-control">
                            <option value="">Todos</option>
                            <option value="Sucesso" selected="@(Model.Status == "Sucesso")">Sucesso</option>
                            <option value="Erro" selected="@(Model.Status == "Erro")">Erro</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="col-md-12 text-right">
                        <a href="/Relatorios/LogEmail" class="btn btn-secondary">Limpar</a>
                        <button type="submit" class="btn btn-primary">Filtrar</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Data Envio</th>
                        <th>Destinatário</th>
                        <th>Assunto</th>
                        <th>Status</th>
                        <th>Erro</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.Logs.Items)
                    {
                        <tr>
                            <td>@log.DataEnvio.ToString("dd/MM/yyyy HH:mm:ss")</td>
                            <td>@log.Destinatario</td>
                            <td>@log.Assunto</td>
                            <td>
                                @if (log.Status == "Sucesso")
                                {
                                    <span class="badge badge-success">Enviado</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">Erro</span>
                                }
                            </td>
                            <td>@log.MensagemErro</td>
                        </tr>
                    }
                    @if (!Model.Logs.Items.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Nenhum registro encontrado com estes filtros.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    <!-- Pagination Controls -->
    @if (Model.Logs.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-3">
            <ul class="pagination justify-content-center">
                @{
                    var queryParams = new Dictionary<string, string>();
                    if (Model.DataInicio.HasValue) queryParams.Add("DataInicio", Model.DataInicio.Value.ToString("yyyy-MM-dd"));
                    if (Model.DataFim.HasValue) queryParams.Add("DataFim", Model.DataFim.Value.ToString("yyyy-MM-dd"));
                    if (!string.IsNullOrEmpty(Model.Destinatario)) queryParams.Add("Destinatario", Model.Destinatario);
                    if (!string.IsNullOrEmpty(Model.Assunto)) queryParams.Add("Assunto", Model.Assunto);
                    if (!string.IsNullOrEmpty(Model.Status)) queryParams.Add("Status", Model.Status);
                    
                    string GetLink(int page)
                    {
                        var dict = new Dictionary<string, string>(queryParams);
                        dict["p"] = page.ToString();
                        return "?" + string.Join("&", dict.Select(kv => $"{kv.Key}={System.Net.WebUtility.UrlEncode(kv.Value)}"));
                    }
                }

                <li class="page-item @(Model.Logs.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="@GetLink(Model.Logs.PageIndex - 1)" tabindex="-1">Anterior</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Página @Model.Logs.PageIndex de @Model.Logs.TotalPages</span>
                </li>
                <li class="page-item @(Model.Logs.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="@GetLink(Model.Logs.PageIndex + 1)">Próxima</a>
                </li>
            </ul>
        </nav>
    }
</div>
