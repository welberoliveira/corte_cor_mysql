@page
@model CorteCor.Pages.LembreteConfigListaModel
@{
    ViewData["Title"] = "Regras de Lembretes";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Regras de Lembretes</h2>
        <a asp-page="/LembreteConfigCadastro" class="btn btn-primary">Nova Regra</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
            <div class="alert alert-info">@Model.Mensagem</div>
    }

    <table class="table-striped table-hover">
        <thead class="thead-dark">
            <tr>
                <th>Tipo</th>
                <th title="Antecedência">Ant.</th>
                <th>Unidade</th>
                <th class="d-none d-md-table-cell">Modelo</th>
                <th>Status</th>
                <th class="d-none d-md-table-cell">Início</th>
                <th class="d-none d-md-table-cell">Fim</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Configs)
            {
                    <tr>
                        <td>@item.TipoLembrete</td>
                        <td>@item.AntecedenciaValor</td>
                        <td>@item.AntecedenciaUnidade</td>
                        <td class="d-none d-md-table-cell">@item.AssuntoModelo</td>
                        <td>
                            <span class="badge @(item.Ativo ? "bg-success" : "bg-danger")">
                            @(item.Ativo ? "Ativo" : "Inativo")
                            </span>
                        </td>
                        <td class="d-none d-md-table-cell">@item.DataInicio.ToString("dd/MM/yyyy")</td>
                        <td class="d-none d-md-table-cell">@(item.DataFim?.ToString("dd/MM/yyyy") ?? "Eterna")</td>
                        <td>
                            <a asp-page="/LembreteConfigCadastro" asp-route-id="@item.IdConfig" asp-route-view="true" class="btn btn-sm btn-info" style="margin-right: 5px;">Visualizar</a>
                            <form method="post" asp-page-handler="Excluir" asp-route-id="@item.IdConfig" onsubmit="return confirm('Tem certeza que deseja excluir esta regra?');" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-danger">Excluir</button>
                            </form>
                        </td>
                    </tr>
            }
        </tbody>
    </table>
</div>
