                                <h5 class="mb-1">Histórico da Nota @Model.NotaHistoricoSelecionada.Numero</h5>
                                <div class="small text-muted">
                                    @Model.NotaHistoricoSelecionada.TipoNota | Série @Model.NotaHistoricoSelecionada.Serie | Status @Model.NotaHistoricoSelecionada.Status
                                </div>
                            </div>
                            <div class="small font-monospace text-muted">@((Model.NotaHistoricoSelecionada.ChaveAcesso ?? Model.NotaHistoricoSelecionada.ChaveAcessoNacional) ?? "-")</div>
