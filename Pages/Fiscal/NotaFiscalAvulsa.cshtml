@page
@model CorteCor.Pages.Fiscal.NotaFiscalAvulsaModel
@using CorteCor.Services
@{
    ViewData["Title"] = "Nota Fiscal Avulsa Completa";
}

<div class="avulsa-container">
    <div class="header-section mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-file-earmark-spreadsheet"></i> Nota Fiscal Avulsa</h1>
            <p class="text-muted">Emissão independente com todos os campos regulatórios</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-outline-primary btn-sm" onclick="preencherDadosTesteNfseAvulsa()">
                <i class="bi bi-magic"></i> Preencher Dados de Teste
            </button>
            <div class="glass-card p-2 px-4">
                <span class="badge @(Model.Input.Ambiente == 1 ? "bg-danger" : "bg-warning")">
                    <i class="bi bi-broadcast"></i> @(Model.Input.Ambiente == 1 ? "PRODUÇÃO" : "HOMOLOGAÇÃO")
                </span>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert alert-@Model.MensagemTipo alert-dismissible fade show animate__animated animate__shakeX" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @Model.Mensagem
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-warning">
            <div class="fw-semibold mb-1">Revise os campos obrigatórios antes de emitir.</div>
            <div asp-validation-summary="ModelOnly" class="mb-0"></div>
        </div>
    }

    @if (TempData["SuccessMessage"] != null || !string.IsNullOrEmpty(Model.ProtocoloAutorizacao))
    {
        <div class="row mb-4 animate__animated animate__fadeIn">
            <div class="col-12">
                <div class="glass-card border-success border-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="text-success mb-1"><i class="bi bi-shield-check"></i> Resultado da Transmissão</h4>
                            @if (!string.IsNullOrEmpty(Model.ProtocoloAutorizacao))
                            {
                                <p class="mb-0"><strong>Protocolo:</strong> <span class="badge bg-success">@Model.ProtocoloAutorizacao</span></p>
                            }
                            else
                            {
                                <p class="mb-0 text-muted">@TempData["SuccessMessage"]</p>
                            }
                        </div>
                         <div class="d-flex flex-column align-items-end gap-2">
                            <div class="d-flex gap-2">
                                 @if (!string.IsNullOrEmpty(Model.XmlRetorno))
                                {
                                    <form method="post" asp-page-handler="DownloadXmlDb" class="d-inline">
                                        <input type="hidden" name="chaveAcesso" value="@Model.ChaveAcesso" />
                                        <input type="hidden" name="tipo" value="retorno" />
                                        <button type="submit" class="btn btn-primary btn-sm">
                                            <i class="bi bi-download"></i> Baixar XML Retorno
                                        </button>
                                    </form>
                                }
                                @if (!string.IsNullOrEmpty(Model.XmlEnvio))
                                {
                                    <form method="post" asp-page-handler="DownloadXmlDb" class="d-inline">
                                        <input type="hidden" name="chaveAcesso" value="@Model.ChaveAcesso" />
                                        <input type="hidden" name="tipo" value="envio" />
                                        <button type="submit" class="btn btn-secondary btn-sm">
                                            <i class="bi bi-code-slash"></i> XML Envio
                                        </button>
                                    </form>
                                }
                                @if (!string.IsNullOrEmpty(Model.ChaveAcesso) && !string.IsNullOrEmpty(Model.Input.DestinatarioEmail))
                                {
                                    <form method="post" asp-page-handler="EnviarEmail" class="d-inline">
                                        <input type="hidden" name="chaveAcesso" value="@Model.ChaveAcesso" />
                                        <input type="hidden" name="emailDestino" value="@Model.Input.DestinatarioEmail" />
                                        <input type="hidden" name="nomeDestino" value="@Model.Input.DestinatarioNome" />
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="bi bi-envelope"></i> Enviar E-mail
                                        </button>
                                    </form>
                                }
                            </div>
                            
                             @if (!string.IsNullOrEmpty(Model.ChaveAcesso))
                            {
                                <div class="input-group input-group-sm" style="max-width: 450px;">
                                    <span class="input-group-text bg-light">Chave:</span>
                                    <input type="text" class="form-control font-monospace" value="@Model.ChaveAcesso" readonly id="chaveAcessoCopiada" name="ChaveAcesso">
                                    <button class="btn btn-secondary" type="button" onclick="copyChave()">
                                        <i class="bi bi-clipboard"></i>
                                    </button>
                                     <button type="submit" asp-page-handler="Consultar" class="btn btn-primary">
                                        <i class="bi bi-search"></i> Consultar Status SEFAZ
                                    </button>
                                    @if (Model.RetornoResumoAtual?.PodeCancelar == true)
                                    {
                                        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#modalCancelar">
                                            <i class="bi bi-x-circle"></i> Cancelar Nota
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    @if (Model.RetornoResumoAtual != null)
                    {
                        <hr class="my-3" />
                        <div class="row g-3">
                            <div class="col-md-3">
                                <div class="border rounded-3 p-3 h-100 bg-light">
                                    <div class="small text-muted">Status fiscal</div>
                                    <div class="fw-semibold">@Model.RetornoResumoAtual.StatusFiscal</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="border rounded-3 p-3 h-100 bg-light">
                                    <div class="small text-muted">Codigo</div>
                                    <div class="fw-semibold">@(Model.RetornoResumoAtual.CodigoStatus ?? "-")</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="border rounded-3 p-3 h-100 bg-light">
                                    <div class="small text-muted">Protocolo</div>
                                    <div class="fw-semibold text-break">@(Model.RetornoResumoAtual.Protocolo ?? "-")</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="border rounded-3 p-3 h-100 bg-light">
                                    <div class="small text-muted">Situacao operacional</div>
                                    <div class="fw-semibold">@(Model.RetornoResumoAtual.OperacaoConcluida ? "Concluida" : "Pendente de analise")</div>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="border rounded-3 p-3 bg-light">
                                    <div class="small text-muted mb-1">Mensagem retornada pelo provedor fiscal</div>
                                    <div>@(Model.RetornoResumoAtual.MensagemRetorno ?? "Sem detalhe textual adicional no retorno.")</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <form method="post" enctype="multipart/form-data" id="nfeForm">
        <input type="hidden" name="NotasPage" value="@Model.NotasEmitidasPaginadas.PageIndex" />
        <input type="hidden" name="InutilizacoesPage" value="@Model.InutilizacoesPaginadas.PageIndex" />
        <input type="hidden" name="Aba" value="@Model.AbaAtiva" />
        <div class="row">
            <!-- Sidebar: Configurações Rápidas & Logs -->
            <div class="col-md-3">
                <div class="glass-card mb-4">
                    <h5 class="mb-3"><i class="bi bi-shield-lock"></i> Segurança</h5>
                    <div class="mb-3">
                        <label asp-for="Input.CertificadoFile" class="form-label small"></label>
                        <input asp-for="Input.CertificadoFile" type="file" class="form-control form-control-sm" accept=".pfx" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.CertificadoSenha" class="form-label small"></label>
                        <input asp-for="Input.CertificadoSenha" class="form-control form-control-sm" placeholder="Senha PFX" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Ambiente</label>
                        <select asp-for="Input.Ambiente" class="form-select form-select-sm">
                            <option value="2">Homologação (Teste)</option>
                            <option value="1">Produção (Real)</option>
                        </select>
                    </div>
                    @if (Model.HasSavedCertificate)
                    {
                        <div class="alert alert-success p-2 small">
                            <i class="bi bi-check-circle-fill"></i> Certificado salvo.
                        </div>
                    }
                </div>

                <div class="glass-card">
                    <h5 class="mb-3"><i class="bi bi-terminal"></i> Log em Tempo Real</h5>
                    <div id="logContent" class="log-area-compact">
                        @foreach (var log in Model.Logs)
                        {
                            <div class="log-entry">@log</div>
                        }
                        @if (Model.Logs.Count == 0)
                        {
                            <div class="text-muted small">Aguardando processamento...</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Main Content: Tabs -->
            <div class="col-md-9">
                <div class="glass-card shadow-lg p-0 overflow-hidden">
                    <ul class="nav nav-tabs custom-tabs" id="nfeTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="ident-tab" data-bs-toggle="tab" data-bs-target="#ident" type="button" role="tab"><i class="bi bi-info-circle"></i> Identificação</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="emit-tab" data-bs-toggle="tab" data-bs-target="#emit" type="button" role="tab"><i class="bi bi-building"></i> Emitente</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="dest-tab" data-bs-toggle="tab" data-bs-target="#dest" type="button" role="tab"><i class="bi bi-person"></i> Destinatário</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="itens-tab" data-bs-toggle="tab" data-bs-target="#itens" type="button" role="tab"><i class="bi bi-box-seam"></i> Itens</button>
                        </li>
                    </ul>

                    <div class="tab-content p-4" id="nfeTabsContent">
                        <!-- Identificação -->
                        <div class="tab-pane fade show active" id="ident" role="tabpanel">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="Input.Modelo" class="form-label"></label>
                                    <select asp-for="Input.Modelo" class="form-select" onchange="this.form.submit()">
                                        @foreach (var mod in Model.ModelosList)
                                        {
                                            <option value="@mod.Value">@mod.Text</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-8">
                                    <label asp-for="Input.NaturezaOperacao" class="form-label"></label>
                                    <select asp-for="Input.NaturezaOperacao" class="form-select" onchange="this.form.submit()">
                                        @foreach (var nat in Model.NaturezasList)
                                        {
                                            <option value="@nat">@nat</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="Input.Serie" class="form-label"></label>
                                    <input asp-for="Input.Serie" class="form-control" type="number" />
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="Input.Numero" class="form-label"></label>
                                    <input asp-for="Input.Numero" class="form-control" type="number" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Input.DataEmissao" class="form-label"></label>
                                    <input asp-for="Input.DataEmissao" class="form-control" type="datetime-local" />
                                </div>
                            </div>
                        </div>

                        <!-- Emitente -->
                        <div class="tab-pane fade" id="emit" role="tabpanel">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Input.EmitenteNome" class="form-label"></label>
                                    <input asp-for="Input.EmitenteNome" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Input.EmitenteCnpj" class="form-label"></label>
                                    <input asp-for="Input.EmitenteCnpj" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Input.EmitenteIE" class="form-label"></label>
                                    <input asp-for="Input.EmitenteIE" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Input.EmitenteIM" class="form-label"></label>
                                    <input asp-for="Input.EmitenteIM" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Input.EmitenteCRT" class="form-label"></label>
                                    <select asp-for="Input.EmitenteCRT" class="form-select">
                                        <option value="1">Simples Nacional</option>
                                        <option value="2">Simples Nacional - Excesso</option>
                                        <option value="3">Regime Normal</option>
                                    </select>
                                </div>
                                <div class="col-md-9">
                                    <label class="form-label">Logradouro</label>
                                    <input asp-for="Input.EmitenteLogradouro" class="form-control" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Número</label>
                                    <input asp-for="Input.EmitenteNumero" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Bairro</label>
                                    <input asp-for="Input.EmitenteBairro" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Cidade / Município</label>
                                    <input asp-for="Input.EmitenteCidade" class="form-control" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">UF</label>
                                    <input asp-for="Input.EmitenteUF" class="form-control" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Cód IBGE</label>
                                    <select asp-for="Input.EmitenteCodMun" class="form-select">
                                        <option value="">Selecione...</option>
                                        @foreach (var mun in Model.MunicipiosList)
                                        {
                                            <option value="@mun.Value">@mun.Value - @mun.Text</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Destinatário -->
                        <div class="tab-pane fade" id="dest" role="tabpanel">
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label asp-for="Input.DestinatarioNome" class="form-label"></label>
                                    <input asp-for="Input.DestinatarioNome" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Input.DestinatarioCpfCnpj" class="form-label"></label>
                                    <input asp-for="Input.DestinatarioCpfCnpj" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Input.DestinatarioIE" class="form-label"></label>
                                    <input asp-for="Input.DestinatarioIE" class="form-control" />
                                </div>
                                <div class="col-md-8">
                                    <label class="form-label">Endereco (Logradouro, Nº)</label>
                                    <div class="input-group">
                                        <input asp-for="Input.DestinatarioLogradouro" class="form-control" />
                                        <input asp-for="Input.DestinatarioNumero" class="form-control w-25" placeholder="S/N" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Bairro</label>
                                    <input asp-for="Input.DestinatarioBairro" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Cidade</label>
                                    <input asp-for="Input.DestinatarioCidade" class="form-control" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">UF</label>
                                    <input asp-for="Input.DestinatarioUF" class="form-control" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Cód IBGE</label>
                                    <select asp-for="Input.DestinatarioCodMun" class="form-select">
                                        <option value="">Selecione...</option>
                                        @foreach (var mun in Model.MunicipiosList)
                                        {
                                            <option value="@mun.Value">@mun.Value - @mun.Text</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Itens -->
                        <div class="tab-pane fade" id="itens" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle" id="itemsTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 10%">Cód</th>
                                            <th style="width: 25%">Descrição</th>
                                            <th style="width: 10%">NCM</th>
                                            <th style="width: 15%">Cod. Trib (NFSe)</th>
                                            <th style="width: 10%">Aliq ISS</th>
                                            <th style="width: 5%">Qtd</th>
                                            <th style="width: 10%">Vlr Unit</th>
                                            <th style="width: 10%">Subtotal</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.Input.Itens.Count; i++)
                                        {
                                            <tr class="item-row">
                                                <td><input name="Input.Itens[@i].CProd" value="@Model.Input.Itens[i].CProd" class="form-control form-control-sm" /></td>
                                                <td><input name="Input.Itens[@i].XProd" value="@Model.Input.Itens[i].XProd" class="form-control form-control-sm" /></td>
                                                <td><input name="Input.Itens[@i].NCM" value="@Model.Input.Itens[i].NCM" class="form-control form-control-sm" /></td>
                                                <td><input name="Input.Itens[@i].CodigoTributacao" value="@Model.Input.Itens[i].CodigoTributacao" class="form-control form-control-sm" placeholder="060101" /></td>
                                                <td><input name="Input.Itens[@i].AliquotaISS" value="@Model.Input.Itens[i].AliquotaISS" class="form-control form-control-sm" /></td>
                                                <td><input name="Input.Itens[@i].qCom" value="@Model.Input.Itens[i].qCom" class="form-control form-control-sm qty-input" /></td>
                                                <td><input name="Input.Itens[@i].vUnCom" value="@Model.Input.Itens[i].vUnCom" class="form-control form-control-sm price-input" /></td>
                                                <td class="subtotal-cell fw-bold">R$ 0,00</td>
                                                <td><button type="button" class="btn btn-sm btn-danger remove-item"><i class="bi bi-trash"></i></button></td>
                                                <input type="hidden" name="Input.Itens[@i].vProd" value="@Model.Input.Itens[i].vProd" class="vprod-hidden" />
                                                <input type="hidden" name="Input.Itens[@i].CSOSN" value="@Model.Input.Itens[i].CSOSN" />
                                                <input type="hidden" name="Input.Itens[@i].vTotTrib" value="@Model.Input.Itens[i].vTotTrib" />
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <button type="button" class="btn btn-sm btn-primary mt-2" id="addItemBtn">
                                <i class="bi bi-plus-circle"></i> Adicionar Item
                            </button>
                        </div>
                    </div>

                    <div class="bg-light p-3 border-top d-flex justify-content-between align-items-center">
                        <div>
                            <span class="text-muted small">Total da Nota:</span>
                            <span class="fs-4 fw-bold text-primary ms-2" id="totalNotaValue">R$ 0,00</span>
                        </div>
                        <button type="submit" name="btnEmitir" value="1" class="btn btn-primary pulse-button px-5">
                            <i class="bi bi-send-check-fill me-2"></i> Emitir Nota Fiscal
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <!-- Histórico de Notas (Fase 7) -->
    <div class="mt-5 animate__animated animate__fadeInUp">
        <ul class="nav nav-tabs mb-3" id="fiscalTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(Model.AbaAtiva == "notas" ? "active" : "")" id="notas-tab" data-bs-toggle="tab" data-bs-target="#notas" type="button" role="tab" aria-selected="@(Model.AbaAtiva == "notas" ? "true" : "false")">
                    <i class="bi bi-clock-history"></i> Notas Recentes
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(Model.AbaAtiva == "inut" ? "active" : "")" id="inut-tab" data-bs-toggle="tab" data-bs-target="#inut" type="button" role="tab" aria-selected="@(Model.AbaAtiva == "inut" ? "true" : "false")">
                    <i class="bi bi-slash-circle"></i> Inutilizações
                </button>
            </li>
        </ul>
        
        <div class="tab-content" id="fiscalTabsContent">
            <div class="tab-pane fade @(Model.AbaAtiva == "notas" ? "show active" : "")" id="notas" role="tabpanel">
                <div class="glass-card">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle custom-table">
                            <thead class="bg-light">
                                <tr>
                                    <th>Data</th>
                                    <th>Tipo</th>
                                    <th>Número/Série</th>
                                    <th>Valor</th>
                                    <th>Status</th>
                                    <th class="text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var nota in Model.NotasEmitidas)
                                {
                                    var acoes = NotaFiscalAvulsaService.ObterAcoesDisponiveis(nota);
                                    <tr>
                                        <td class="small">@nota.DataEmissao.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <span class="badge bg-secondary">@nota.TipoNota</span>
                                        </td>
                                        <td>
                                            <div class="fw-bold">@nota.Numero</div>
                                            <div class="text-muted small">Série @nota.Serie</div>
                                        </td>
                                        <td class="fw-bold">@nota.ValorTotal.ToString("C")</td>
                                        <td>
                                            <span class="badge @acoes.ClasseStatus">@nota.Status</span>
                                        </td>
                                        <td class="text-end nota-acoes-cell">
                                            <div class="nota-acoes-wrap">
                                                <form method="post" asp-page-handler="Consultar" class="nota-acao-form">
                                                    <input type="hidden" name="ChaveAcesso" value="@acoes.ChaveFiscal" />
                                                    <input type="hidden" name="NotasPage" value="@Model.NotasEmitidasPaginadas.PageIndex" />
                                                    <input type="hidden" name="InutilizacoesPage" value="@Model.InutilizacoesPaginadas.PageIndex" />
                                                    <input type="hidden" name="Aba" value="notas" />
                                                    <button type="submit" class="btn btn-sm nota-acao-btn nota-acao-primary" title="Consultar Status">
                                                        <i class="bi bi-search"></i>
                                                        <span class="nota-acao-label">Consultar</span>
                                                    </button>
                                                </form>

                                                <form method="post" asp-page-handler="VerHistorico" class="d-inline">
                                                    <input type="hidden" name="ChaveAcesso" value="@acoes.ChaveFiscal" />
                                                    <input type="hidden" name="NotasPage" value="@Model.NotasEmitidasPaginadas.PageIndex" />
                                                    <input type="hidden" name="InutilizacoesPage" value="@Model.InutilizacoesPaginadas.PageIndex" />
                                                    <input type="hidden" name="Aba" value="notas" />
                                                    <button type="submit" class="btn btn-outline-dark btn-sm" title="Ver Histórico">
                                                        <i class="bi bi-clock-history"></i>
                                                    </button>
                                                </form>

                                                @if (acoes.PodeBaixarXml)
                                                {
                                                    <form method="post" asp-page-handler="DownloadXmlDb" class="d-inline">
                                                        <input type="hidden" name="chaveAcesso" value="@acoes.ChaveFiscal" />
                                                        <input type="hidden" name="tipo" value="@acoes.TipoXmlPreferencial" />
                                                        <input type="hidden" name="NotasPage" value="@Model.NotasEmitidasPaginadas.PageIndex" />
                                                        <input type="hidden" name="InutilizacoesPage" value="@Model.InutilizacoesPaginadas.PageIndex" />
                                                        <input type="hidden" name="Aba" value="notas" />
                                                        <button type="submit" class="btn btn-outline-secondary btn-sm" title="Baixar XML">
                                                            <i class="bi bi-file-earmark-code"></i>
                                                        </button>
                                                    </form>
                                                }

                                                @if (acoes.PodeGerarPdf)
                                                {
                                                    <form method="post" asp-page-handler="GerarPdf" class="d-inline">
                                                        <input type="hidden" name="chaveAcesso" value="@acoes.ChaveFiscal" />
                                                        <input type="hidden" name="NotasPage" value="@Model.NotasEmitidasPaginadas.PageIndex" />
                                                        <input type="hidden" name="InutilizacoesPage" value="@Model.InutilizacoesPaginadas.PageIndex" />
                                                        <input type="hidden" name="Aba" value="notas" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Baixar PDF">
                                                            <i class="bi bi-file-pdf"></i>
                                                        </button>
                                                    </form>
                                                }

                                                @if (acoes.PodeCancelar)
                                                {
                                                    <button type="button" class="btn btn-outline-danger btn-sm" 
                                                            data-bs-toggle="modal" data-bs-target="#modalCancelar"
                                                            onclick="document.getElementById('chaveCancelarInput').value='@acoes.ChaveFiscal'; document.getElementById('chaveCancelarDisplay').value='@acoes.ChaveFiscal';">
                                                        <i class="bi bi-x-circle"></i>
                                                    </button>
                                                }

                                                @if (acoes.PodeCartaCorrecao)
                                                {
                                                    <button type="button" class="btn btn-outline-info btn-sm"
                                                            title="Carta de Correcao"
                                                            data-bs-toggle="modal" data-bs-target="#modalCorrecao"
                                                            onclick="document.getElementById('chaveCorrecaoInput').value='@acoes.ChaveFiscal'; document.getElementById('chaveCorrecaoDisplay').value='@acoes.ChaveFiscal';">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </button>
                                                }

                                                @if (acoes.PodeEnviarEmail)
                                                {
                                                    <button type="button" class="btn btn-outline-success btn-sm"
                                                            title="Enviar por E-mail"
                                                            data-bs-toggle="modal" data-bs-target="#modalEmailNota"
                                                            onclick="document.getElementById('chaveEmailInput').value='@acoes.ChaveFiscal'; document.getElementById('nomeEmailDisplay').value=''; document.getElementById('emailDestinoInput').value='';">
                                                        <i class="bi bi-envelope"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (Model.NotasEmitidas.Count == 0)
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">Nenhuma nota encontrada no histórico local.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (Model.NotasEmitidasPaginadas.TotalPages > 1)
                    {
                        <nav aria-label="Paginacao de notas recentes" class="mt-3">
                            <ul class="pagination pagination-sm justify-content-center mb-0">
                                <li class="page-item @(Model.NotasEmitidasPaginadas.HasPreviousPage ? "" : "disabled")">
                                    <a class="page-link"
                                       asp-page="/Fiscal/NotaFiscalAvulsa"
                                       asp-route-NotasPage="@(Model.NotasEmitidasPaginadas.PageIndex - 1)"
                                       asp-route-InutilizacoesPage="@Model.InutilizacoesPaginadas.PageIndex"
                                       asp-route-Aba="notas">Anterior</a>
                                </li>
                                <li class="page-item disabled">
                                    <span class="page-link">Pagina @Model.NotasEmitidasPaginadas.PageIndex de @Model.NotasEmitidasPaginadas.TotalPages</span>
                                </li>
                                <li class="page-item @(Model.NotasEmitidasPaginadas.HasNextPage ? "" : "disabled")">
                                    <a class="page-link"
                                       asp-page="/Fiscal/NotaFiscalAvulsa"
                                       asp-route-NotasPage="@(Model.NotasEmitidasPaginadas.PageIndex + 1)"
                                       asp-route-InutilizacoesPage="@Model.InutilizacoesPaginadas.PageIndex"
                                       asp-route-Aba="notas">Proxima</a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            </div>

            @if (Model.NotaHistoricoSelecionada != null)
            {
                <div class="mt-4" id="historico-nota-detalhe">
                    <div class="glass-card">
                        <div class="d-flex justify-content-between align-items-center mb-3">
