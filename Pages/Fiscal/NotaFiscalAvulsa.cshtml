                                            <tr>
                                                <th>Data</th>
                                                <th>Etapa</th>
                                                <th>Mensagem</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var log in Model.LogsHistorico)
                                            {
                                                <tr>
                                                    <td class="small">@log.DataHora.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                                    <td class="small">@log.TipoEvento</td>
                                                    <td class="small">@(string.IsNullOrWhiteSpace(log.Mensagem) ? "-" : log.Mensagem)</td>
                                                </tr>
