                                    <div class="border rounded-3 p-3 h-100 bg-light">
                                        <div class="small text-muted">Protocolo atual</div>
                                        <div class="fw-semibold text-break">@(Model.RetornoResumoHistorico.Protocolo ?? "-")</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="border rounded-3 p-3 h-100 bg-light">
                                        <div class="small text-muted">Chave vinculada</div>
                                        <div class="fw-semibold text-break">@(Model.RetornoResumoHistorico.ChaveAcesso ?? "-")</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="border rounded-3 p-3 h-100 bg-light">
