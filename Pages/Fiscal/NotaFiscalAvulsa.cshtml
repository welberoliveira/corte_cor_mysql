@section Scripts {
    <script>
        $(document).ready(function () {
            // Function to recalculate subtotal and total
            function calculateTotals() {
                let grandTotal = 0;
                $(".item-row").each(function () {
                    const qty = parseFloat($(this).find(".qty-input").val()) || 0;
                    const price = parseFloat($(this).find(".price-input").val()) || 0;
                    const subtotal = qty * price;
                    $(this).find(".subtotal-cell").text("R$ " + subtotal.toLocaleString('pt-BR', { minimumFractionDigits: 2 }));
                    $(this).find(".vprod-hidden").val(subtotal.toFixed(2));
                    grandTotal += subtotal;
                });
                $("#totalNotaValue").text("R$ " + grandTotal.toLocaleString('pt-BR', { minimumFractionDigits: 2 }));
            }

            window.calculateTotals = calculateTotals;

            // Bind calculation to inputs
            $(document).on("input", ".qty-input, .price-input", calculateTotals);

            // Add Item
            $("#addItemBtn").click(function () {
                const index = $(".item-row").length;
                const newRow = `
                    <tr class="item-row">
                        <td><input name="Input.Itens[${index}].CProd" class="form-control form-control-sm" /></td>
                        <td><input name="Input.Itens[${index}].XProd" class="form-control form-control-sm" /></td>
                        <td><input name="Input.Itens[${index}].NCM" class="form-control form-control-sm" value="00" /></td>
                        <td><input name="Input.Itens[${index}].CodigoTributacao" class="form-control form-control-sm" value="060101" /></td>
                        <td><input name="Input.Itens[${index}].AliquotaISS" class="form-control form-control-sm" value="5" /></td>
                        <td><input name="Input.Itens[${index}].qCom" class="form-control form-control-sm qty-input" value="1" /></td>
                        <td><input name="Input.Itens[${index}].vUnCom" class="form-control form-control-sm price-input" value="0" /></td>
                        <td class="subtotal-cell fw-bold">R$ 0,00</td>
                        <td><button type="button" class="btn btn-sm btn-danger remove-item"><i class="bi bi-trash"></i></button></td>
                        <input type="hidden" name="Input.Itens[${index}].vProd" class="vprod-hidden" />
                        <input type="hidden" name="Input.Itens[${index}].CSOSN" value="102" />
                        <input type="hidden" name="Input.Itens[${index}].vTotTrib" value="0" />
                    </tr>
                `;
                $("#itemsTable tbody").append(newRow);
                calculateTotals();
            });

            // Remove Item
            $(document).on("click", ".remove-item", function () {
                if ($(".item-row").length > 1) {
                    $(this).closest("tr").remove();
                    // Re-index inputs
                    $(".item-row").each(function (i) {
                        $(this).find("input").each(function () {
                            const name = $(this).attr("name");
                            if (name) {
                                const newName = name.replace(/\[\d+\]/, "[" + i + "]");
                                $(this).attr("name", newName).attr("id", newName.replace(/\./g, "_"));
                            }
                        });
                    });
                    calculateTotals();
                } else {
                    alert("A nota deve conter ao menos um item.");
                }
            });

            // Initial calculation
            calculateTotals();

            decorarAcoesNotasRecentes();
            sincronizarAbaFiscal();

            // Auto-scroll logs
            var logContent = document.getElementById("logContent");
            if(logContent) logContent.scrollTop = logContent.scrollHeight;
        });

        function decorarAcoesNotasRecentes() {
            const containers = document.querySelectorAll('#notas .custom-table tbody td .d-flex.gap-1.justify-content-end, #notas .custom-table tbody td .nota-acoes-wrap');

            containers.forEach((container) => {
                container.classList.add('nota-acoes-wrap');

                const cell = container.closest('td');
                if (cell) {
                    cell.classList.add('nota-acoes-cell');
                }

                container.querySelectorAll('form').forEach((form) => {
                    form.classList.add('nota-acao-form');
                });

                container.querySelectorAll('button').forEach((button) => {
                    const config = obterConfigBotaoNotaRecente(button);

                    button.classList.remove(
                        'btn-outline-primary',
                        'btn-outline-dark',
                        'btn-outline-secondary',
                        'btn-outline-danger',
                        'btn-outline-info',
                        'btn-outline-success'
                    );

                    button.classList.add('nota-acao-btn', config.classe);

                    if (!button.querySelector('.nota-acao-label')) {
                        const label = document.createElement('span');
                        label.className = 'nota-acao-label';
                        label.textContent = config.texto;
                        button.appendChild(label);
                    }
                });
            });
        }

        function obterConfigBotaoNotaRecente(button) {
            const title = (button.getAttribute('title') || '').toLowerCase();
            const target = button.getAttribute('data-bs-target') || '';

            if (title.includes('consultar')) {
                return { texto: 'Consultar', classe: 'nota-acao-primary' };
            }

            if (title.includes('hist')) {
                return { texto: 'Histórico', classe: 'nota-acao-dark' };
            }

            if (title.includes('xml')) {
                return { texto: 'XML', classe: 'nota-acao-secondary' };
            }

            if (title.includes('pdf')) {
                return { texto: 'PDF', classe: 'nota-acao-danger' };
            }

            if (target === '#modalCancelar') {
                return { texto: 'Cancelar', classe: 'nota-acao-danger' };
            }

            if (target === '#modalCorrecao' || title.includes('correc')) {
                return { texto: 'CC-e', classe: 'nota-acao-info' };
            }

            if (target === '#modalEmailNota' || title.includes('mail')) {
                return { texto: 'E-mail', classe: 'nota-acao-success' };
            }

            return { texto: 'Ação', classe: 'nota-acao-secondary' };
        }

        function sincronizarAbaFiscal() {
            const atualizarCampos = (aba) => {
                document.querySelectorAll('input[name="Aba"]').forEach((input) => {
                    input.value = aba;
                });
            };

            atualizarCampos('@Model.AbaAtiva');

            document.querySelectorAll('#fiscalTabs button[data-bs-toggle="tab"]').forEach((button) => {
                button.addEventListener('shown.bs.tab', function () {
                    const destino = this.getAttribute('data-bs-target')?.replace('#', '') || 'notas';
                    atualizarCampos(destino);
                });
            });
        }

        function copyChave() {
            var copyText = document.getElementById("chaveAcessoCopiada");
            copyText.select();
            copyText.setSelectionRange(0, 99999);
            navigator.clipboard.writeText(copyText.value);
            alert("Chave copiada: " + copyText.value);
        }

        function downloadXml(type) {
            const content = type === 'retorno' ? document.getElementById('xmlRetornoContent').value : document.getElementById('xmlEnvioContent').value;
            const filename = `NotaFiscal_${type}_${new Date().getTime()}.xml`;
            const blob = new Blob([content], { type: 'text/xml' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);
        }

        function preencherDadosTesteNfseAvulsa() {
            const setFieldValue = (field, value, options = {}) => {
                if (!field) {
                    return;
                }

                field.value = value;

                if (options.triggerInput !== false) {
                    field.dispatchEvent(new Event('input', { bubbles: true }));
                }

                if (options.triggerChange) {
                    field.dispatchEvent(new Event('change', { bubbles: true }));
                }
            };

            const setValue = (selector, value, options = {}) => {
                const field = document.querySelector(selector);
                if (!field) {
                    return;
                }

                setFieldValue(field, value, options);
            };

            const setIfEmpty = (selector, value) => {
                const field = document.querySelector(selector);
                if (!field || (field.value && field.value.trim() !== '')) {
                    return;
                }

                setValue(selector, value);
            };

            const setFirst = (selectors, value, options = {}) => {
                for (const selector of selectors) {
                    const field = document.querySelector(selector);
                    if (field) {
                        setFieldValue(field, value, options);
                        return;
                    }
                }
            };

            setFirst(['#Input_Ambiente', 'select[name="Input.Ambiente"]'], '2');
            // Estes selects possuem onchange com submit automatico, entao nao disparamos change aqui.
            setFirst(['#Input_Modelo', 'select[name="Input.Modelo"]'], 'NFSE', { triggerChange: false });
            setFirst(['#Input_NaturezaOperacao', 'select[name="Input.NaturezaOperacao"]'], 'Prestacao de servico', { triggerChange: false });
            setFirst(['#Input_Serie', 'input[name="Input.Serie"]'], '1');
            setIfEmpty('#Input_Numero', '1');
            setIfEmpty('input[name="Input.Numero"]', '1');

            const dataEmissaoField = document.querySelector('#Input_DataEmissao') ?? document.querySelector('input[name="Input.DataEmissao"]');
            if (dataEmissaoField && !dataEmissaoField.value) {
                const serverValue = dataEmissaoField.getAttribute('value');
                if (serverValue) {
                    setFieldValue(dataEmissaoField, serverValue, { triggerChange: false });
                }
            }

            setFirst(['#Input_EmitenteNome', 'input[name="Input.EmitenteNome"]'], 'TONNI TECNOLOGIA LTDA');
            setFirst(['#Input_EmitenteCnpj', 'input[name="Input.EmitenteCnpj"]'], '49358717000107');
            setFirst(['#Input_EmitenteIM', 'input[name="Input.EmitenteIM"]'], '101477');
            setFirst(['#Input_EmitenteCRT', 'select[name="Input.EmitenteCRT"]'], '1');
            setFirst(['#Input_EmitenteLogradouro', 'input[name="Input.EmitenteLogradouro"]'], 'M II');
            setFirst(['#Input_EmitenteNumero', 'input[name="Input.EmitenteNumero"]'], '601');
            setFirst(['#Input_EmitenteBairro', 'input[name="Input.EmitenteBairro"]'], 'SAO GERALDO II');
            setFirst(['#Input_EmitenteCidade', 'input[name="Input.EmitenteCidade"]'], 'Montes Claros');
            setFirst(['#Input_EmitenteUF', 'input[name="Input.EmitenteUF"]'], 'MG');
            setFirst(['#Input_EmitenteCodMun', 'select[name="Input.EmitenteCodMun"]'], '3143302');

            setFirst(['#Input_DestinatarioNome', 'input[name="Input.DestinatarioNome"]'], 'JEANE FERREIRA DA SILVA');
            setFirst(['#Input_DestinatarioCpfCnpj', 'input[name="Input.DestinatarioCpfCnpj"]'], '05528366640');
            setFirst(['#Input_DestinatarioLogradouro', 'input[name="Input.DestinatarioLogradouro"]'], 'rua joaquim pereira');
            setFirst(['#Input_DestinatarioNumero', 'input[name="Input.DestinatarioNumero"]'], '521');
            setFirst(['#Input_DestinatarioBairro', 'input[name="Input.DestinatarioBairro"]'], 'Santa Rita');
            setFirst(['#Input_DestinatarioCidade', 'input[name="Input.DestinatarioCidade"]'], 'Montes Claros');
            setFirst(['#Input_DestinatarioUF', 'input[name="Input.DestinatarioUF"]'], 'MG');
            setFirst(['#Input_DestinatarioCodMun', 'select[name="Input.DestinatarioCodMun"]'], '3143302');
            setFirst(['#Input_DestinatarioEmail', 'input[name="Input.DestinatarioEmail"]'], 'welberoliveira3@gmail.com');

            setValue('input[name="Input.Itens[0].CProd"]', '1');
            setValue('input[name="Input.Itens[0].XProd"]', 'Licenciamento de software em homologacao');
            setValue('input[name="Input.Itens[0].NCM"]', '00');
            setValue('input[name="Input.Itens[0].CodigoTributacao"]', '010501');
            setValue('input[name="Input.Itens[0].AliquotaISS"]', '5');
            setValue('input[name="Input.Itens[0].qCom"]', '1');
            setValue('input[name="Input.Itens[0].vUnCom"]', '100');
            setValue('input[name="Input.Itens[0].vProd"]', '100.00');

            if (typeof window.calculateTotals === 'function') {
                window.calculateTotals();
            }

            const firstTabButton = document.getElementById('ident-tab');
            if (firstTabButton && window.bootstrap?.Tab) {
                window.bootstrap.Tab.getOrCreateInstance(firstTabButton).show();
            }
        }
    </script>
}

<!-- Modal Cancelamento -->
<div class="modal fade" id="modalCancelar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-x-circle-fill me-2"></i> Cancelar Nota Fiscal</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Cancelar">
                <input type="hidden" name="NotasPage" value="@Model.NotasEmitidasPaginadas.PageIndex" />
                <input type="hidden" name="InutilizacoesPage" value="@Model.InutilizacoesPaginadas.PageIndex" />
                <input type="hidden" name="Aba" value="@Model.AbaAtiva" />
                <div class="modal-body">
                    <input type="hidden" name="ChaveAcesso" id="chaveCancelarInput" value="@Model.ChaveAcesso" />
                    <div class="alert alert-warning small">
                        <i class="bi bi-exclamation-triangle"></i> Atenção: O cancelamento é irreversível após autorizado pela SEFAZ.
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Chave de Acesso</label>
                        <input type="text" id="chaveCancelarDisplay" class="form-control font-monospace bg-light" value="@Model.ChaveAcesso" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Justificativa (Mínimo 15 caracteres)</label>
                        <textarea name="Justificativa" class="form-control" rows="3" required minlength="15" placeholder="Ex: Erro no preenchimento dos valores dos itens ou dados do destinatário."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                    <button type="submit" class="btn btn-danger">Confirmar Cancelamento</button>
                </div>
            </form>
        </div>
    </div>
</div>

