                                            {
                                                <tr>
                                                    <td colspan="3" class="text-center text-muted small py-3">Nenhum log técnico registrado para esta nota.</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="tab-pane fade @(Model.AbaAtiva == "inut" ? "show active" : "")" id="inut" role="tabpanel">
                <div class="glass-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Histórico de Inutilizações (NF-e/NFC-e)</h5>
                        <button type="button" class="btn btn-outline-warning btn-sm" data-bs-toggle="modal" data-bs-target="#modalInutilizar">
                            <i class="bi bi-slash-circle"></i> Nova Inutilização
                        </button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover custom-table">
                            <thead>
                                <tr>
                                    <th>Data</th>
                                    <th>Modelo/Série</th>
                                    <th>Faixa</th>
                                    <th>Status</th>
                                    <th>Protocolo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inut in Model.Inutilizacoes)
                                {
                                    <tr>
                                        <td>@inut.DataInutilizacao.ToString("dd/MM/yyyy")</td>
                                        <td>@inut.Modelo (Série @inut.Serie)</td>
                                        <td>@inut.NumeroInicial - @inut.NumeroFinal</td>
                                        <td><span class="badge @(inut.Status.Contains("102") ? "bg-success" : "bg-danger")">@inut.Status</span></td>
                                        <td class="small font-monospace">@inut.Protocolo</td>
                                    </tr>
                                }
                                @if (Model.Inutilizacoes.Count == 0)
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">Nenhuma inutilização registrada.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (Model.InutilizacoesPaginadas.TotalPages > 1)
                    {
                        <nav aria-label="Paginacao de inutilizacoes" class="mt-3">
                            <ul class="pagination pagination-sm justify-content-center mb-0">
                                <li class="page-item @(Model.InutilizacoesPaginadas.HasPreviousPage ? "" : "disabled")">
                                    <a class="page-link"
                                       asp-page="/Fiscal/NotaFiscalAvulsa"
                                       asp-route-NotasPage="@Model.NotasEmitidasPaginadas.PageIndex"
                                       asp-route-InutilizacoesPage="@(Model.InutilizacoesPaginadas.PageIndex - 1)"
                                       asp-route-Aba="inut">Anterior</a>
                                </li>
                                <li class="page-item disabled">
                                    <span class="page-link">Pagina @Model.InutilizacoesPaginadas.PageIndex de @Model.InutilizacoesPaginadas.TotalPages</span>
                                </li>
                                <li class="page-item @(Model.InutilizacoesPaginadas.HasNextPage ? "" : "disabled")">
                                    <a class="page-link"
                                       asp-page="/Fiscal/NotaFiscalAvulsa"
                                       asp-route-NotasPage="@Model.NotasEmitidasPaginadas.PageIndex"
                                       asp-route-InutilizacoesPage="@(Model.InutilizacoesPaginadas.PageIndex + 1)"
                                       asp-route-Aba="inut">Proxima</a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

