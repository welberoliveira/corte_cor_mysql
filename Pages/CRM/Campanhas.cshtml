@page
@model CorteCor.Pages.CRM.CampanhasModel
@{
    ViewData["Title"] = "Campanhas CRM";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h2 class="mb-1">Campanhas CRM</h2>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-page="/CRM/CampanhaCadastro">Cadastrar nova campanha</a>
        <a class="btn btn-secondary" asp-page="/CRM/Index">Voltar ao CRM</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-@(Model.FlashType ?? "info")">
        <div>@Model.FlashMessage</div>
        @if (!string.IsNullOrWhiteSpace(Model.FlashActionPage) && !string.IsNullOrWhiteSpace(Model.FlashActionText))
        {
            <a class="btn btn-sm btn-primary mt-2" asp-page="@Model.FlashActionPage">@Model.FlashActionText</a>
        }
    </div>
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white fw-semibold">Filtros</div>
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Pesquisa</label>
                <input class="form-control" asp-for="Pesquisa" placeholder="Nome ou assunto" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Canal</label>
                <select class="form-select" asp-for="Canal">
                    <option value="">Todos</option>
                    <option value="Email">Email</option>
                    <option value="SMS">SMS</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Segmento</label>
                <select class="form-select" asp-for="Segmento">
                    <option value="">Todos</option>
                    <option value="TodosClientes">Todos os clientes</option>
                    <option value="Inativos">Clientes inativos</option>
                    <option value="AniversariantesDoMes">Aniversariantes do mês</option>
                    <option value="PorTag">Por tag</option>
                    <option value="ClienteEspecifico">Cliente específico</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select class="form-select" asp-for="Status">
                    <option value="">Todos</option>
                    <option value="Rascunho">Rascunho</option>
                    <option value="Processada">Processada</option>
                    <option value="Enviada">Enviada</option>
                    <option value="Erro">Erro</option>
                </select>
            </div>
            <div class="col-md-1 d-flex gap-2 justify-content-end">
                <button class="btn btn-primary" type="submit">Filtrar</button>
            </div>
            <div class="col-12 text-end">
                <a class="btn btn-secondary" asp-page="/CRM/Campanhas">Limpar</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white fw-semibold">Campanhas cadastradas</div>
    <div class="card-body">
        @if (Model.Campanhas.Items.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Campanha</th>
                            <th>Canal</th>
                            <th>Segmento</th>
                            <th>Resultado</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var campanha in Model.Campanhas.Items)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@campanha.Nome</div>
                                    <div class="small text-muted">Criada em @campanha.DataCriacao.ToString("dd/MM/yyyy HH:mm")</div>
                                </td>
                                <td>@campanha.Canal</td>
                                <td>@campanha.Segmento</td>
                                <td>
                                    <div class="fw-semibold">@campanha.Status</div>
                                    <div class="small text-muted">Sucesso: @campanha.TotalSucesso | Falha: @campanha.TotalFalha</div>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end flex-wrap">
                                        <a class="btn btn-sm btn-dark"
                                           asp-page="/CRM/CampanhaCadastro"
                                           asp-route-IdCampanha="@campanha.IdCampanha">
                                            Editar
                                        </a>
                                        <a class="btn btn-sm btn-primary"
                                           asp-page="/CRM/Campanhas"
                                           asp-route-IdCampanhaView="@campanha.IdCampanha"
                                           asp-route-Pesquisa="@Model.Pesquisa"
                                           asp-route-Canal="@Model.Canal"
                                           asp-route-Segmento="@Model.Segmento"
                                           asp-route-Status="@Model.Status"
                                           asp-route-p="@Model.p">
                                            Ver detalhes
                                        </a>
                                        <form method="post" asp-page-handler="Enviar">
                                            <input type="hidden" name="idCampanha" value="@campanha.IdCampanha" />
                                            <input type="hidden" asp-for="Pesquisa" />
                                            <input type="hidden" asp-for="Canal" />
                                            <input type="hidden" asp-for="Segmento" />
                                            <input type="hidden" asp-for="Status" />
                                            <input type="hidden" asp-for="p" />
                                            <button class="btn btn-sm btn-success" type="submit">Enviar</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Campanhas.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(Model.Campanhas.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link"
                               asp-page="/CRM/Campanhas"
                               asp-route-p="@(Model.Campanhas.PageIndex - 1)"
                               asp-route-IdCampanhaView="@Model.IdCampanhaView"
                               asp-route-Pesquisa="@Model.Pesquisa"
                               asp-route-Canal="@Model.Canal"
                               asp-route-Segmento="@Model.Segmento"
                               asp-route-Status="@Model.Status">
                                Anterior
                            </a>
                        </li>
                        <li class="page-item disabled">
                            <span class="page-link">Página @Model.Campanhas.PageIndex de @Model.Campanhas.TotalPages</span>
                        </li>
                        <li class="page-item @(Model.Campanhas.HasNextPage ? "" : "disabled")">
                            <a class="page-link"
                               asp-page="/CRM/Campanhas"
                               asp-route-p="@(Model.Campanhas.PageIndex + 1)"
                               asp-route-IdCampanhaView="@Model.IdCampanhaView"
                               asp-route-Pesquisa="@Model.Pesquisa"
                               asp-route-Canal="@Model.Canal"
                               asp-route-Segmento="@Model.Segmento"
                               asp-route-Status="@Model.Status">
                                Próxima
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="text-muted">Nenhuma campanha cadastrada para os filtros informados.</div>
        }
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white fw-semibold">Últimos disparos da campanha</div>
    <div class="card-body">
        @if (Model.IdCampanhaView.HasValue)
        {
            if (Model.DestinosCampanha.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Destino</th>
                                <th>Canal</th>
                                <th>Status</th>
                                <th>Data</th>
                                <th>Mensagem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var destino in Model.DestinosCampanha)
                            {
                                <tr>
                                    <td>@destino.NomePessoa</td>
                                    <td>@destino.Destino</td>
                                    <td>@destino.Canal</td>
                                    <td><span class="badge @(destino.Status == "Sucesso" ? "bg-success" : destino.Status == "Ignorado" ? "bg-secondary" : "bg-danger")">@destino.Status</span></td>
                                    <td>@destino.DataEnvio.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="small text-muted">@destino.MensagemErro</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-muted">Ainda não há disparos registrados para a campanha selecionada.</div>
            }
        }
        else
        {
            <div class="text-muted">Selecione uma campanha na lista para ver o histórico de disparos.</div>
        }
    </div>
</div>
