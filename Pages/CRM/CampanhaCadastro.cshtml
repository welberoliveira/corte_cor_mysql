@page
@model CorteCor.Pages.CRM.CampanhaCadastroModel
@{
    ViewData["Title"] = "Cadastrar Campanha";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h2 class="mb-1">Cadastrar nova campanha</h2>
    <a class="btn btn-secondary" asp-page="/CRM/Campanhas">Voltar para campanhas</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-@(Model.FlashType ?? "info")">@Model.FlashMessage</div>
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white fw-semibold">Dados da campanha</div>
    <div class="card-body">
        <form method="post" asp-page-handler="Salvar" class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Nome</label>
                <input class="form-control" asp-for="CampanhaInput.Nome" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Canal</label>
                <select class="form-select" asp-for="CampanhaInput.Canal">
                    <option value="Email">Email</option>
                    <option value="SMS">SMS</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select class="form-select" asp-for="CampanhaInput.Status">
                    <option value="Rascunho">Rascunho</option>
                    <option value="Processada">Processada</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Segmento</label>
                <select class="form-select" asp-for="CampanhaInput.Segmento">
                    <option value="TodosClientes">Todos os clientes</option>
                    <option value="Inativos">Clientes inativos</option>
                    <option value="AniversariantesDoMes">Aniversariantes do mês</option>
                    <option value="PorTag">Por tag</option>
                    <option value="ClienteEspecifico">Cliente específico</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Cliente específico</label>
                <select class="form-select" asp-for="CampanhaInput.IdPessoa">
                    <option value="">Selecione...</option>
                    @foreach (var cliente in Model.Clientes)
                    {
                        <option value="@cliente.IdPessoa">@cliente.Nome</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Dias inativos</label>
                <input type="number" class="form-control" asp-for="CampanhaInput.DiasInatividade" min="1" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Tag</label>
                <input class="form-control" asp-for="CampanhaInput.FiltroTag" />
            </div>
            <div class="col-12">
                <label class="form-label">Assunto</label>
                <input class="form-control" asp-for="CampanhaInput.Assunto" />
            </div>
            <div class="col-12">
                <label class="form-label">Conteúdo</label>
                <textarea class="form-control" asp-for="CampanhaInput.Conteudo" rows="8"></textarea>
            </div>
            <div class="col-12 text-end">
                <button class="btn btn-primary" type="submit">Salvar campanha</button>
            </div>
        </form>
    </div>
</div>
