@page
@model CorteCor.Pages.CRM.TarefasModel
@{
    ViewData["Title"] = "Tarefas CRM";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h2 class="mb-1">CRM Tarefas</h2>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-page="/CRM/TarefaCadastro">Nova tarefa</a>
        <a class="btn btn-secondary" asp-page="/CRM/Index">Voltar ao CRM</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-@(Model.FlashType ?? "info")">@Model.FlashMessage</div>
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Cliente</label>
                <select class="form-select" asp-for="IdPessoa" data-smart-select data-smart-placeholder="Digite para pesquisar cliente...">
                    <option value="">Todos</option>
                    @foreach (var cliente in Model.Clientes)
                    {
                        <option value="@cliente.IdPessoa">@cliente.Nome</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select class="form-select" asp-for="Status">
                    <option value="">Todos</option>
                    <option value="Aberta">Aberta</option>
                    <option value="Concluida">Conclu&iacute;da</option>
                    <option value="Cancelada">Cancelada</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Pesquisar descri&ccedil;&atilde;o</label>
                <input class="form-control" asp-for="PesquisaDescricao" placeholder="T&iacute;tulo ou descri&ccedil;&atilde;o" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Vencimento inicial</label>
                <input type="date" class="form-control" asp-for="DataVencimentoInicio" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Vencimento final</label>
                <input type="date" class="form-control" asp-for="DataVencimentoFim" />
            </div>
            <div class="col-12 d-flex justify-content-end gap-2 flex-wrap">
                <button class="btn btn-primary" type="submit">Filtrar</button>
                <a class="btn btn-secondary" asp-page="/CRM/Tarefas">Limpar</a>
            </div>
        </form>
    </div>
    <div class="card-body">
        @if (Model.Tarefas.Items.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Tarefa</th>
                            <th>Cliente</th>
                            <th>Canal</th>
                            <th>Vencimento</th>
                            <th>Status</th>
                            <th class="text-end">A&ccedil;&otilde;es</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tarefa in Model.Tarefas.Items)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@tarefa.Titulo</div>
                                    <div class="small text-muted">@tarefa.Descricao</div>
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(tarefa.NomePessoa) ? "N&atilde;o vinculado" : tarefa.NomePessoa)</td>
                                <td>@(string.IsNullOrWhiteSpace(tarefa.CanalSugerido) ? "-" : tarefa.CanalSugerido)</td>
                                <td>@tarefa.DataVencimento.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge @(tarefa.Status == "Concluida" ? "bg-success" : tarefa.Status == "Cancelada" ? "bg-secondary" : "bg-warning text-dark")">
                                        @tarefa.Status
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end flex-wrap">
                                        <a class="btn btn-sm btn-dark"
                                           asp-page="/CRM/TarefaCadastro"
                                           asp-route-IdTarefa="@tarefa.IdTarefa">
                                            Editar
                                        </a>
                                        @if (tarefa.Status != "Concluida")
                                        {
                                            <form method="post" asp-page-handler="AtualizarStatus" class="d-inline-flex">
                                                <input type="hidden" name="idTarefa" value="@tarefa.IdTarefa" />
                                                <input type="hidden" name="status" value="Concluida" />
                                                <input type="hidden" name="IdPessoa" value="@Model.IdPessoa" />
                                                <input type="hidden" name="Status" value="@Model.Status" />
                                                <input type="hidden" name="PesquisaDescricao" value="@Model.PesquisaDescricao" />
                                                <input type="hidden" name="DataVencimentoInicio" value="@(Model.DataVencimentoInicio?.ToString("yyyy-MM-dd"))" />
                                                <input type="hidden" name="DataVencimentoFim" value="@(Model.DataVencimentoFim?.ToString("yyyy-MM-dd"))" />
                                                <input type="hidden" name="p" value="@Model.p" />
                                                <button class="btn btn-sm btn-success" type="submit">Concluir</button>
                                            </form>
                                        }
                                        @if (tarefa.Status != "Aberta")
                                        {
                                            <form method="post" asp-page-handler="AtualizarStatus" class="d-inline-flex">
                                                <input type="hidden" name="idTarefa" value="@tarefa.IdTarefa" />
                                                <input type="hidden" name="status" value="Aberta" />
                                                <input type="hidden" name="IdPessoa" value="@Model.IdPessoa" />
                                                <input type="hidden" name="Status" value="@Model.Status" />
                                                <input type="hidden" name="PesquisaDescricao" value="@Model.PesquisaDescricao" />
                                                <input type="hidden" name="DataVencimentoInicio" value="@(Model.DataVencimentoInicio?.ToString("yyyy-MM-dd"))" />
                                                <input type="hidden" name="DataVencimentoFim" value="@(Model.DataVencimentoFim?.ToString("yyyy-MM-dd"))" />
                                                <input type="hidden" name="p" value="@Model.p" />
                                                <button class="btn btn-sm btn-primary" type="submit">Reabrir</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-muted">Nenhuma tarefa de CRM encontrada.</div>
        }

        @if (Model.Tarefas.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item @(Model.Tarefas.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-page="/CRM/Tarefas"
                           asp-route-IdPessoa="@Model.IdPessoa"
                           asp-route-Status="@Model.Status"
                           asp-route-PesquisaDescricao="@Model.PesquisaDescricao"
                           asp-route-DataVencimentoInicio="@(Model.DataVencimentoInicio?.ToString("yyyy-MM-dd"))"
                           asp-route-DataVencimentoFim="@(Model.DataVencimentoFim?.ToString("yyyy-MM-dd"))"
                           asp-route-p="@(Model.Tarefas.PageIndex - 1)">
                            Anterior
                        </a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">P&aacute;gina @Model.Tarefas.PageIndex de @Model.Tarefas.TotalPages</span>
                    </li>
                    <li class="page-item @(Model.Tarefas.HasNextPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-page="/CRM/Tarefas"
                           asp-route-IdPessoa="@Model.IdPessoa"
                           asp-route-Status="@Model.Status"
                           asp-route-PesquisaDescricao="@Model.PesquisaDescricao"
                           asp-route-DataVencimentoInicio="@(Model.DataVencimentoInicio?.ToString("yyyy-MM-dd"))"
                           asp-route-DataVencimentoFim="@(Model.DataVencimentoFim?.ToString("yyyy-MM-dd"))"
                           asp-route-p="@(Model.Tarefas.PageIndex + 1)">
                            Pr&oacute;xima
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>
