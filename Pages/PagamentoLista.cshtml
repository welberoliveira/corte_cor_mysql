@page
@model CorteCor.Pages.PagamentoListaModel

<style>
    @@media (max-width: 768px) {
        table th:nth-child(2),
        table td:nth-child(2),
        table th:nth-child(3),
        table td:nth-child(3),
        table th:nth-child(4),
        table td:nth-child(4) {
            display: none;
        }
    }
</style>

<div class="container">
    <h4>Lista de Pagamentos</h4>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert">
            @Model.Mensagem
        </div>
    }

    <table>
        <thead>
            <tr>
                <th>Data</th>
                <th>Tipo</th>
                <th>Valor</th>
                <th>Id Agendamento</th>
                <th>Id Meio Pgto</th>
                <th>Contos</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var Pagamento in Model.Pagamentos)
            {
                <tr>
                    <td>@Pagamento.Data.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@Pagamento.Tipo</td>
                    <td>R$ @Pagamento.Valor.ToString("0.00")</td>
                    <td>@Pagamento.IdAgendamento</td>
                    <td>@Pagamento.IdMeioPagamento</td>
                    <td>@Pagamento.Contos</td>
                    <td class="actions">
                        <form method="post" style="display: inline;">
                            <input type="hidden" name="id" value="@Pagamento.IdPagamento">
                            <input type="hidden" name="action" value="alterar">
                            <button class="btn btn-info">Alterar</button>
                        </form>

                        <form method="post" style="display: inline;" onsubmit="return confirm('Tem certeza que deseja excluir este Pagamento?');">
                            <input type="hidden" name="id" value="@Pagamento.IdPagamento">
                            <input type="hidden" name="action" value="excluir">
                            <button class="btn btn-danger">Excluir</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
