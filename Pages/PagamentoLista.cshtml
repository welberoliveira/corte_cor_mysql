@page
@model CorteCor.Pages.PagamentoListaModel
@{
    ViewData["Title"] = "Pagamentos";
    var statusClass = new Func<string, string>(s => s switch
    {
        "approved" => "success",
        "pending" => "warning",
        "failure" => "danger",
        _ => "secondary"
    });
}

<div class="row mb-3">
    <div class="col-md-6">
        <h2>@ViewData["Title"]</h2>
    </div>
    <div class="col-md-6 text-right">
        <a class="btn btn-primary" href="/PagamentoCadastro">
            <i class="fas fa-plus"></i> Novo Pagamento
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Mensagem))
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @Model.Mensagem
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<div class="card mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0"><i class="fas fa-filter"></i> Filtros</h5>
    </div>
    <div class="card-body">
        <form method="get" class="form-inline">
            <label class="mr-2">De:</label>
            <input type="date" name="DataInicio" class="form-control mr-3" value="@Model.DataInicio?.ToString("yyyy-MM-dd")" />
            
            <label class="mr-2">Até:</label>
            <input type="date" name="DataFim" class="form-control mr-3" value="@Model.DataFim?.ToString("yyyy-MM-dd")" />
            
            <label class="mr-2">Status:</label>
            <select name="Status" class="form-control mr-3">
                <option value="">Todos</option>
                <option value="approved" selected="@(Model.Status == "approved")">Aprovado</option>
                <option value="pending" selected="@(Model.Status == "pending")">Pendente</option>
                <option value="failure" selected="@(Model.Status == "failure")">Falha</option>
            </select>

            <label class="mr-2">Cliente:</label>
            <input type="text" name="NomeCliente" class="form-control mr-3" value="@Model.NomeCliente" placeholder="Nome do Cliente" />

            <label class="mr-2">Data Agend.:</label>
            <input type="date" name="DataAgendamento" class="form-control mr-3" value="@Model.DataAgendamento?.ToString("yyyy-MM-dd")" />

            <button type="submit" class="btn btn-secondary">Filtrar</button>
            <a href="/PagamentoLista" class="btn btn-link">Limpar</a>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="thead-light">
                <tr>
                    <th>Data</th>
                    <th>Cliente</th>
                    <th>Serviço</th>
                    <th>Agendamento</th>
                    <th>Descrição</th>
                    <th>Valor</th>
                    <th>Status MP</th>
                    <th>Tipo</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Pagamentos.Items)
                {
                    <tr>
                        <td>@p.CriadoEm.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@p.NomeCliente</td>
                        <td>@p.NomeServico</td>
                        <td>@(p.DataAgendamento?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        <td>@p.Descricao</td>
                        <td>@p.Moeda @p.Valor.ToString("N2")</td>
                        <td>
                            <span class="badge badge-@statusClass(p.MpStatus)">
                                @(p.MpStatus ?? "N/A")
                            </span>
                            @if(!string.IsNullOrEmpty(p.MpStatusDetail))
                            {
                                <small class="d-block text-muted">@p.MpStatusDetail</small>
                            }
                        </td>
                        <td>@p.Tipo</td>
                        <td>
                            @if (!string.IsNullOrEmpty(p.CheckoutUrl) && p.Status == "pending")
                            {
                                <a href="@p.CheckoutUrl" target="_blank" class="btn btn-sm btn-success" title="Pagar">
                                    <i class="fas fa-money-bill-wave"></i>
                                </a>
                            }
                            
                            <form method="post" class="d-inline">
                                <input type="hidden" name="id" value="@p.IdPagamento">
                                <input type="hidden" name="action" value="sincronizar">
                                <button type="submit" class="btn btn-sm btn-info" title="Sincronizar Status">
                                    <i class="fas fa-sync"></i>
                                </button>
                            </form>

                            <a href="/PagamentoCadastro?id=@p.IdPagamento" class="btn btn-sm btn-primary" title="Editar">
                                <i class="fas fa-edit"></i>
                            </a>

                            <form method="post" class="d-inline" onsubmit="return confirm('Tem certeza que deseja excluir?');">
                                <input type="hidden" name="id" value="@p.IdPagamento">
                                <input type="hidden" name="action" value="excluir">
                                <button type="submit" class="btn btn-sm btn-danger" title="Excluir">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Pagamentos.Items.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center py-4 text-muted">Ainda não há pagamentos registrados com estes filtros.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Pagination Controls -->
@if (Model.Pagamentos.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-3">
        <ul class="pagination justify-content-center">
            @{
                var queryParams = new Dictionary<string, string>();
                if (Model.DataInicio.HasValue) queryParams.Add("DataInicio", Model.DataInicio.Value.ToString("yyyy-MM-dd"));
                if (Model.DataFim.HasValue) queryParams.Add("DataFim", Model.DataFim.Value.ToString("yyyy-MM-dd"));
                if (!string.IsNullOrEmpty(Model.Status)) queryParams.Add("Status", Model.Status);
                if (!string.IsNullOrEmpty(Model.NomeCliente)) queryParams.Add("NomeCliente", Model.NomeCliente);
                if (Model.DataAgendamento.HasValue) queryParams.Add("DataAgendamento", Model.DataAgendamento.Value.ToString("yyyy-MM-dd"));
                
                string GetLink(int page)
                {
                    var dict = new Dictionary<string, string>(queryParams);
                    dict["p"] = page.ToString();
                    return "?" + string.Join("&", dict.Select(kv => $"{kv.Key}={System.Net.WebUtility.UrlEncode(kv.Value)}"));
                }
            }

            <li class="page-item @(Model.Pagamentos.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="@GetLink(Model.Pagamentos.PageIndex - 1)" tabindex="-1">Anterior</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">Página @Model.Pagamentos.PageIndex de @Model.Pagamentos.TotalPages</span>
            </li>
            <li class="page-item @(Model.Pagamentos.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="@GetLink(Model.Pagamentos.PageIndex + 1)">Próxima</a>
            </li>
        </ul>
    </nav>
}
