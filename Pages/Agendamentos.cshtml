@page
@model CorteCor.Pages.AgendamentosModel

@{
    ViewData["Title"] = "Agendamentos";
    var initialDate = DateTime.Today.ToString("yyyy-MM-dd");
}

<div class="cc-agenda-page">
    <div class="cc-toolbar">
        <div class="cc-toolbar-left">
            <button type="button" class="btn btn-secondary btn-sm" id="btnPrev">◀</button>
            <button type="button" class="btn btn-secondary btn-sm" id="btnToday">Hoje</button>
            <button type="button" class="btn btn-secondary btn-sm" id="btnNext">▶</button>

            <div class="btn-group ms-2" role="group" aria-label="Visão">
                <button type="button" class="btn btn-primary btn-sm active" id="btnViewWeek">Semana</button>
                <button type="button" class="btn btn-primary btn-sm" id="btnViewDay">Dia</button>
            </div>

            <span class="cc-date-label ms-3" id="lblRange"></span>
        </div>


    </div>

    <div class="cc-content">
        <div class="cc-left">
            <div id="nav"></div>

            <div class="cc-legend mt-3">
                <div class="cc-legend-title">Legenda</div>
                <div class="cc-legend-item"><span class="cc-dot st-pendente"></span> Pendente</div>
                <div class="cc-legend-item"><span class="cc-dot st-confirmado"></span> Confirmado</div>
                <div class="cc-legend-item"><span class="cc-dot st-concluido"></span> Concluído</div>
                <div class="cc-legend-item"><span class="cc-dot st-cancelado"></span> Cancelado</div>
                <div class="cc-legend-item"><span class="cc-dot st-faltou"></span> Faltou</div>
            </div>
        </div>

        <div class="cc-right">
            <div id="dp"></div>
        </div>
    </div>
</div>

<form method="post" id="antiForgeryForm" class="d-none">
    @Html.AntiForgeryToken()
</form>

<!-- Modal Agendamento -->
<div class="modal fade" id="agModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="agModalTitle">Agendamento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="agId" value="" />
                <input type="hidden" id="agStartIso" value="" />
                <input type="hidden" id="agEndIso" value="" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Início</label>
                        <input class="form-control" id="agStartLabel" readonly />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Fim (pela duração do serviço)</label>
                        <input class="form-control" id="agEndLabel" readonly />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Funcionário</label>
                        <select class="form-select" id="agEmployee" required></select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Cliente</label>
                        <select class="form-select" id="agClient" required>
                            <option value="">Carregando...</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Serviço</label>
                        <select class="form-select" id="agService" required>
                            <option value="">Carregando...</option>
                        </select>
                        <div class="form-text">A duração do agendamento será definida pelo serviço.</div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Valor (R$)</label>
                        <input class="form-control" id="agValue" inputmode="decimal" placeholder="0,00" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Status</label>
                        <select class="form-select" id="agStatus" required>
                            <option value="Pendente">Pendente</option>
                            <option value="Confirmado">Confirmado</option>
                            <option value="Concluido">Concluído</option>
                            <option value="Cancelado">Cancelado</option>
                            <option value="Faltou">Faltou</option>
                        </select>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Observação</label>
                        <textarea class="form-control" id="agObs" rows="3" placeholder="Ex.: preferência, alergia, instruções..."></textarea>
                    </div>
                </div>

                <div class="alert alert-danger mt-3 d-none" id="agError"></div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-danger me-auto d-none" id="btnDelete">Excluir</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSave">Salvar</button>
            </div>

        </div>
    </div>
</div>

@section Styles {
    <style>
        .cc-agenda-page { display:flex; flex-direction:column; gap:12px; }
        .cc-toolbar { display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap:wrap; }
        .cc-toolbar-left, .cc-toolbar-right { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
        .cc-date-label { font-weight:600; color:#444; }

        .cc-content { display:grid; grid-template-columns: 260px 1fr; gap: 12px; min-height: 680px; }
        .cc-left { border:1px solid #e5e5e5; border-radius: 10px; padding: 10px; background:#fff; }
        .cc-right { border:1px solid #e5e5e5; border-radius: 10px; padding: 10px; background:#fff; overflow:hidden; }

        #nav { width: 100%; }
        #dp { width: 100%; height: 720px; }

        .cc-legend-title { font-weight: 600; margin-bottom: 6px; }
        .cc-legend-item { display:flex; align-items:center; gap:8px; margin: 4px 0; color:#555; }
        .cc-dot { width: 10px; height: 10px; border-radius: 999px; display:inline-block; }
        .st-pendente { background: #f0ad4e; }
        .st-confirmado { background: #0d6efd; }
        .st-concluido { background: #198754; }
        .st-cancelado { background: #dc3545; }
        .st-faltou { background: #6c757d; }

        /* Classes aplicadas nos eventos (sem depender de cores inline) */
        .dp-evt-pendente .calendar_default_event_inner { border-left: 4px solid #f0ad4e; }
        .dp-evt-confirmado .calendar_default_event_inner { border-left: 4px solid #0d6efd; }
        .dp-evt-concluido .calendar_default_event_inner { border-left: 4px solid #198754; }
        .dp-evt-cancelado .calendar_default_event_inner { border-left: 4px solid #dc3545; opacity: 0.7; }
        .dp-evt-faltou .calendar_default_event_inner { border-left: 4px solid #6c757d; opacity: 0.8; }
    </style>
}

@section Scripts {
    <script>
        (function () {
            const initialDate = "@initialDate";
            const pageUrl = "@Url.Page("/Agendamentos")";

            const endpoints = {
                resources: () => `${pageUrl}?handler=Resources`,
                events: (start, end) => {
                    const emp = document.getElementById("fEmployee").value || "";
                    const st = document.getElementById("fStatus").value || "";
                    const q = document.getElementById("fSearch").value || "";
                    const p = new URLSearchParams({
                        start: start,
                        end: end,
                        employeeId: emp,
                        status: st,
                        q: q
                    });
                    return `${pageUrl}?handler=Events&${p.toString()}`;
                },
                timeRanges: (start, end) => {
                    const emp = document.getElementById("fEmployee").value || "";
                    const p = new URLSearchParams({ start, end, employeeId: emp });
                    return `${pageUrl}?handler=TimeRanges&${p.toString()}`;
                },
                get: (id) => `${pageUrl}?handler=Get&id=${encodeURIComponent(id)}`,
                save: () => `${pageUrl}?handler=Save`,
                del: () => `${pageUrl}?handler=Delete`,
                servicos: () => `${pageUrl}?handler=Servicos`,
                clientes: () => `${pageUrl}?handler=Clientes`
            };

            const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value || "";

            // ---- DayPilot Navigator (calendário lateral)
            const nav = new DayPilot.Navigator("nav", {
                selectMode: "day",
                showMonths: 2,
                skipMonths: 2,
                onTimeRangeSelected: function (args) {
                    dp.startDate = args.day;
                    dp.update();
                    refresh();
                }
            });
            nav.init();

            // ---- Scheduler principal
            const dp = new DayPilot.Calendar("dp", {
                startDate: initialDate,
                viewType: "Week",      // Semana (Seg–Dom)
                // opcional: ajuste visual
                cellDuration: 30,      // slots de 15min
                hourWidth: 60,         // largura da coluna de horas (se quiser)
                weekStarts: 1,
                // desabilitar mover/resize
                eventMoveHandling: "Disabled",
                eventResizeHandling: "Disabled",

                timeRangeSelectedHandling: "Enabled",
                onTimeRangeSelected: function (args) {
                    dp.clearSelection();
                    openCreateModal(args);
                },
                onEventClick: async function (args) {
                    openEditModal(args.e.id());
                },

                onBeforeEventRender: function (args) {
                    const st = (args.data.status || "").toString().toLowerCase();

                    // classe CSS por status (para borda/estilo)
                    if (st === "pendente") args.data.cssClass = "dp-evt-pendente";
                    else if (st === "confirmado") args.data.cssClass = "dp-evt-confirmado";
                    else if (st === "concluido" || st === "concluído") args.data.cssClass = "dp-evt-concluido";
                    else if (st === "cancelado") args.data.cssClass = "dp-evt-cancelado";
                    else if (st === "faltou") args.data.cssClass = "dp-evt-faltou";

                    // tooltip
                    const t = [];
                    if (args.data.clientName) t.push(`Cliente: ${args.data.clientName}`);
                    if (args.data.serviceName) t.push(`Serviço: ${args.data.serviceName}`);
                    if (args.data.value) t.push(`Valor: R$ ${args.data.value}`);
                    if (args.data.status) t.push(`Status: ${args.data.status}`);
                    args.data.toolTip = t.join("\n");
                },

                onTimeRangeSelected: function (args) {
                    dp.clearSelection();
                    openCreateModal(args);
                },

                onEventClick: async function (args) {
                    openEditModal(args.e.id());
                }
            });

            dp.init();

            // ---- Modal helpers
            const modalEl = document.getElementById("agModal");
            const agModal = new bootstrap.Modal(modalEl);

            let serviceDurationMap = {}; // { serviceId: minutes }

            function setError(msg) {
                const el = document.getElementById("agError");
                if (!msg) { el.classList.add("d-none"); el.textContent = ""; return; }
                el.classList.remove("d-none");
                el.textContent = msg;
            }

            function formatLabel(iso) {
                // iso: "yyyy-MM-ddTHH:mm:ss"
                const d = new Date(iso);
                const pad = (n) => String(n).padStart(2, "0");
                return `${pad(d.getDate())}/${pad(d.getMonth() + 1)}/${d.getFullYear()} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
            }

            function setStartEnd(startDpDate, endDpDate) {
                const startIso = startDpDate.toString(); // DayPilot ISO
                const endIso = endDpDate.toString();

                document.getElementById("agStartIso").value = startIso;
                document.getElementById("agEndIso").value = endIso;

                document.getElementById("agStartLabel").value = formatLabel(startIso);
                document.getElementById("agEndLabel").value = formatLabel(endIso);
            }

            async function ensureModalLookupsLoaded() {
                // Serviços
                const svcSel = document.getElementById("agService");
                const cliSel = document.getElementById("agClient");

                if (svcSel.dataset.loaded !== "1") {
                    const r = await fetch(endpoints.servicos(), { headers: { "Accept": "application/json" } });
                    const list = await r.json(); // esperado: [{id, nome, duracaoMin, valorPadrao}]
                    serviceDurationMap = {};
                    svcSel.innerHTML = `<option value="">Selecione...</option>`;
                    for (const s of list) {
                        serviceDurationMap[String(s.id)] = Number(s.duracaoMin || 0);
                        const opt = document.createElement("option");
                        opt.value = s.id;
                        opt.textContent = s.nome;
                        opt.dataset.valorPadrao = s.valorPadrao ?? "";
                        svcSel.appendChild(opt);
                    }
                    svcSel.dataset.loaded = "1";
                }

                if (cliSel.dataset.loaded !== "1") {
                    const r = await fetch(endpoints.clientes(), { headers: { "Accept": "application/json" } });
                    const list = await r.json(); // esperado: [{id, nome}]
                    cliSel.innerHTML = `<option value="">Selecione...</option>`;
                    for (const c of list) {
                        const opt = document.createElement("option");
                        opt.value = c.id;
                        opt.textContent = c.nome;
                        cliSel.appendChild(opt);
                    }
                    cliSel.dataset.loaded = "1";
                }
            }

            function fillEmployeeSelect(resources) {
                const f = document.getElementById("fEmployee");
                const m = document.getElementById("agEmployee");

                // filtro
                f.innerHTML = `<option value="">Todos os funcionários</option>`;
                // modal (obrigatório)
                m.innerHTML = `<option value="">Selecione...</option>`;

                for (const r of resources) {
                    const opt1 = document.createElement("option");
                    opt1.value = r.id;
                    opt1.textContent = r.name;
                    f.appendChild(opt1);

                    const opt2 = document.createElement("option");
                    opt2.value = r.id;
                    opt2.textContent = r.name;
                    m.appendChild(opt2);
                }
            }

            async function openCreateModal(args) {
                setError(null);
                document.getElementById("agModalTitle").textContent = "Novo agendamento";
                document.getElementById("agId").value = "";
                document.getElementById("btnDelete").classList.add("d-none");

                await ensureModalLookupsLoaded();

                // funcionário do clique (resource)
                document.getElementById("agEmployee").value = args.resource || "";

                // start/end inicial: 1 slot (será ajustado pelo serviço)
                const start = args.start;
                const end = args.start.addMinutes(dp.cellDuration);
                setStartEnd(start, end);

                // defaults
                document.getElementById("agClient").value = "";
                document.getElementById("agService").value = "";
                document.getElementById("agObs").value = "";
                document.getElementById("agStatus").value = "Pendente";
                document.getElementById("agValue").value = "";

                agModal.show();
            }

            async function openEditModal(id) {
                setError(null);
                document.getElementById("agModalTitle").textContent = "Editar agendamento";
                document.getElementById("btnDelete").classList.remove("d-none");

                await ensureModalLookupsLoaded();

                const r = await fetch(endpoints.get(id), { headers: { "Accept": "application/json" } });
                if (!r.ok) {
                    setError("Não foi possível carregar o agendamento.");
                    agModal.show();
                    return;
                }
                const data = await r.json(); // esperado: { id, start, end, employeeId, clientId, serviceId, obs, value, status }
                document.getElementById("agId").value = data.id;
                document.getElementById("agEmployee").value = data.employeeId;
                document.getElementById("agClient").value = data.clientId;
                document.getElementById("agService").value = data.serviceId;
                document.getElementById("agObs").value = data.obs || "";
                document.getElementById("agValue").value = data.value || "";
                document.getElementById("agStatus").value = data.status || "Pendente";

                setStartEnd(new DayPilot.Date(data.start), new DayPilot.Date(data.end));

                agModal.show();
            }

            // serviço -> ajusta fim pela duração + opcional valor padrão
            document.getElementById("agService").addEventListener("change", function () {
                const sid = this.value;
                if (!sid) return;

                const minutes = serviceDurationMap[String(sid)] || 0;
                if (minutes > 0) {
                    const startIso = document.getElementById("agStartIso").value;
                    const start = new DayPilot.Date(startIso);
                    const end = start.addMinutes(minutes);
                    setStartEnd(start, end);
                }

                // valor padrão (se vier do backend)
                const selected = this.options[this.selectedIndex];
                const v = selected?.dataset?.valorPadrao;
                if (v && !document.getElementById("agValue").value) {
                    document.getElementById("agValue").value = v;
                }
            });

            // ---- Save / Delete
            async function postJson(url, payload) {
                const r = await fetch(url, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": token
                    },
                    body: JSON.stringify(payload)
                });
                return r;
            }

            document.getElementById("btnSave").addEventListener("click", async function () {
                setError(null);

                const payload = {
                    id: document.getElementById("agId").value || null,
                    start: document.getElementById("agStartIso").value,
                    end: document.getElementById("agEndIso").value,
                    employeeId: document.getElementById("agEmployee").value,
                    clientId: document.getElementById("agClient").value,
                    serviceId: document.getElementById("agService").value,
                    obs: document.getElementById("agObs").value || "",
                    value: document.getElementById("agValue").value || "",
                    status: document.getElementById("agStatus").value
                };

                // validação mínima no front
                if (!payload.employeeId || !payload.clientId || !payload.serviceId || !payload.status) {
                    setError("Preencha Funcionário, Cliente, Serviço e Status.");
                    return;
                }

                const r = await postJson(endpoints.save(), payload);
                if (!r.ok) {
                    const msg = await r.text();
                    setError(msg || "Não foi possível salvar.");
                    return;
                }

                agModal.hide();
                refresh();
            });

            document.getElementById("btnDelete").addEventListener("click", async function () {
                setError(null);
                const id = document.getElementById("agId").value;
                if (!id) return;

                const r = await postJson(endpoints.del(), { id: id });
                if (!r.ok) {
                    const msg = await r.text();
                    setError(msg || "Não foi possível excluir.");
                    return;
                }

                agModal.hide();
                refresh();
            });

            // ---- load / refresh
            async function loadResources() {
                const r = await fetch(endpoints.resources(), { headers: { "Accept": "application/json" } });
                const resources = await r.json(); // esperado: [{id, name}]
                dp.resources = resources;
                fillEmployeeSelect(resources);
                dp.update();
            }

            async function loadEventsAndRanges() {
                const start = dp.visibleStart().toString();
                const end = dp.visibleEnd().toString();

                // eventos
                const ev = await fetch(endpoints.events(start, end), { headers: { "Accept": "application/json" } });
                const events = await ev.json(); // esperado: [{id, text, start, end, resource, status, clientName, serviceName, value}]

                // timeranges/bloqueios
                const tr = await fetch(endpoints.timeRanges(start, end), { headers: { "Accept": "application/json" } });
                const ranges = await tr.json(); // esperado: [{start, end, resource, text, cssClass}]

                dp.events.list = events;
                dp.timeRanges = ranges;

                updateRangeLabel();
                dp.update();
            }

            function updateRangeLabel() {
                const s = dp.visibleStart();
                const e = dp.visibleEnd().addDays(-1);
                document.getElementById("lblRange").textContent =
                    `${s.toString("dd/MM/yyyy")} – ${e.toString("dd/MM/yyyy")}`;
            }

            async function refresh() {
                await loadEventsAndRanges();
            }

            // ---- toolbar actions
            document.getElementById("btnPrev").addEventListener("click", function () {
                dp.startDate = dp.startDate.addDays(dp.days * -1);
                nav.select(dp.startDate);
                refresh();
            });
            document.getElementById("btnNext").addEventListener("click", function () {
                dp.startDate = dp.startDate.addDays(dp.days);
                nav.select(dp.startDate);
                refresh();
            });
            document.getElementById("btnToday").addEventListener("click", function () {
                dp.startDate = new DayPilot.Date();
                nav.select(dp.startDate);
                refresh();
            });

            document.getElementById("btnViewWeek").addEventListener("click", function () {
                setView("week");
            });
            document.getElementById("btnViewDay").addEventListener("click", function () {
                setView("day");
            });

            function setView(view) {
                document.getElementById("btnViewWeek").classList.toggle("active", view === "week");
                document.getElementById("btnViewDay").classList.toggle("active", view === "day");

                dp.viewType = (view === "day") ? "Day" : "Week";
                dp.update();
                refresh();
            }

            document.getElementById("btnRefresh").addEventListener("click", refresh);
            document.getElementById("fEmployee").addEventListener("change", refresh);
            document.getElementById("fStatus").addEventListener("change", refresh);

            let searchTimer = null;
            document.getElementById("fSearch").addEventListener("input", function () {
                clearTimeout(searchTimer);
                searchTimer = setTimeout(refresh, 350);
            });

            // init
            (async function init() {
                await loadResources();
                nav.select(dp.startDate);
                await refresh();
            })();

        })();
    </script>
}
