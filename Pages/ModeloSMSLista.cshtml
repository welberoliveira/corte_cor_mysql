@page
@model CorteCor.Pages.ModeloSMSListaModel
@{
    ViewData["Title"] = "Modelos de SMS";
}

<div class="row mb-3">
    <div class="col-md-6">
        <h4>Modelos de SMS</h4>
    </div>
    <div class="col-md-6 text-right">
        <a asp-page="/ModeloSMSCadastro" class="btn btn-success">Cadastrar Novo</a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Mensagem))
{
    <div class="alert alert-warning">@Model.Mensagem</div>
}

<table class="">
    <thead>
        <tr>
            <th>Evento</th>
            <th>Conteúdo</th>
            <th>Ativo</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model.Modelos)
        {
            <tr>
                <td>@m.TipoEvento</td>
                <td>
                    @(m.Conteudo.Length > 50 ? m.Conteudo.Substring(0, 50) + "..." : m.Conteudo)
                </td>
                <td>@(m.Ativo ? "Sim" : "Não")</td>
                <td>
                    <a asp-page="/ModeloSMSCadastro" asp-route-id="@m.IdModelo" class="btn btn-primary btn-sm">Editar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
