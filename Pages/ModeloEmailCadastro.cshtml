@page
@model CorteCor.Pages.ModeloEmailCadastroModel
@{
    ViewData["Title"] = "Cadastro de Modelo de E-mail";
}

<div class="container">
    <h4>Cadastro de Modelo de E-mail</h4>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert alert-info">
            @Model.Mensagem
            @if (Model.ModeloExistenteId.HasValue)
            {
                <a class="alert-link ms-2" asp-page="/ModeloEmailCadastro" asp-route-id="@Model.ModeloExistenteId.Value">Editar modelo existente</a>
            }
        </div>
    }

    <form method="post">
        <input type="hidden" asp-for="Modelo.IdModelo" />
        <input type="hidden" asp-for="Modelo.IdSalao" />

        <div class="form-group">
            <label asp-for="Modelo.TipoEvento">Tipo de Evento</label>
            <select asp-for="Modelo.TipoEvento" class="form-control" asp-items="Model.EventosOptions"></select>
        </div>

        <div class="form-group">
            <label asp-for="Modelo.Assunto">Assunto</label>
            <input asp-for="Modelo.Assunto" class="form-control" required />
            <small class="form-text text-muted">Variáveis disponíveis: {NomeCliente}, {DataAgendamento}, {NomeServico}, {NomeFuncionario}</small>
        </div>

        <div class="form-group">
            <label asp-for="Modelo.CorpoHTML">Corpo do E-mail (HTML)</label>
            <div id="editor-container" style="height: 400px; background: white;"></div>
            <textarea asp-for="Modelo.CorpoHTML" class="form-control" style="display:none;"></textarea>
            <small class="form-text text-muted">Variáveis: {NomeCliente}, {DataAgendamento}, {NomeServico}, {NomeFuncionario}</small>
        </div>

        <div class="form-group form-check">
            <input type="checkbox" class="form-check-input" asp-for="Modelo.Ativo" />
            <label class="form-check-label" asp-for="Modelo.Ativo">Ativo</label>
        </div>

        <button type="submit" class="btn btn-primary" id="btnSalvar">Salvar</button>
        <a asp-page="/ModeloEmailLista" class="btn btn-secondary">Voltar</a>
    </form>
</div>

@section Scripts {
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
        var quill = new Quill('#editor-container', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'color': [] }, { 'background': [] }],
                    [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                    [{ 'align': [] }],
                    ['link', 'image'],
                    ['clean'],
                    ['code-block']
                ]
            }
        });

        // Preenche o editor com o valor inicial do textarea
        var initialContent = document.getElementById('Modelo_CorpoHTML').value;
        quill.root.innerHTML = initialContent;

        // Ao enviar o formulário, sincroniza o conteúdo do Quill para o textarea
        document.querySelector('form').onsubmit = function() {
            var html = quill.root.innerHTML;
            
            // Validação manual já que o campo está oculto
            if (quill.getText().trim().length === 0) {
                Swal.fire({
                    icon: 'error',
                    title: 'Campo Obrigatório',
                    text: 'O corpo do e-mail não pode estar vazio.'
                });
                return false;
            }

            document.getElementById('Modelo_CorpoHTML').value = html;
        };
    </script>
}
