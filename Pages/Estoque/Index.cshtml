@page
@model CorteCor.Pages.Estoque.IndexModel
@using CorteCor.Models
@{
    ViewData["Title"] = "Controle de Estoque";
}

@section Styles {
    <style>
        .estoque-shell-card {
            border: 0;
            border-radius: 20px;
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
        }

        .estoque-hero {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 24px;
            padding: 1.6rem;
            margin-bottom: 1.5rem;
        }

        .estoque-kpi {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 1rem 1.1rem;
            height: 100%;
        }

        .estoque-kpi-label {
            font-size: 0.74rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #6b7280;
            margin-bottom: 0.35rem;
        }

        .estoque-kpi-value {
            font-size: 1.55rem;
            font-weight: 700;
            color: #111827;
        }

        .estoque-table td {
            vertical-align: top;
        }

        .estoque-actions {
            display: flex;
            justify-content: flex-end;
        }
    </style>
}

<div class="estoque-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h2 class="mb-1">Controle de Estoque</h2>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" asp-page="/Estoque/AjusteManual">Ajuste Manual</a>
            <a class="btn btn-dark" asp-page="/Estoque/Movimentacoes">Movimentações</a>
            <a class="btn btn-secondary" asp-page="/Vendas/Index">Ir para Vendas</a>
            <a class="btn btn-dark" asp-page="/ProdutoLista">Produtos</a>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-@(Model.FlashType ?? "info")">@Model.FlashMessage</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="estoque-kpi">
            <div class="estoque-kpi-label">Produtos com controle</div>
            <div class="estoque-kpi-value">@Model.Resumo.ProdutosComControle</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="estoque-kpi">
            <div class="estoque-kpi-label">Estoque baixo</div>
            <div class="estoque-kpi-value text-warning">@Model.Resumo.ProdutosComEstoqueBaixo</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="estoque-kpi">
            <div class="estoque-kpi-label">Valor de custo</div>
            <div class="estoque-kpi-value fs-4">R$ @Model.Resumo.ValorCustoEstoque.ToString("N2")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="estoque-kpi">
            <div class="estoque-kpi-label">Valor de venda</div>
            <div class="estoque-kpi-value fs-4">R$ @Model.Resumo.ValorVendaEstoque.ToString("N2")</div>
        </div>
    </div>
</div>

<div class="card estoque-shell-card">
    <div class="card-header bg-white fw-semibold">Posição do estoque</div>
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end mb-3">
            <div class="col-md-7">
                <label class="form-label">Pesquisar produto</label>
                <input class="form-control" type="text" name="q" value="@Model.q" placeholder="Nome ou código interno" />
            </div>
            <div class="col-md-3">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" id="somenteBaixo" name="somenteBaixo" value="true" checked="@Model.somenteBaixo" />
                    <label class="form-check-label" for="somenteBaixo">Somente estoque baixo</label>
                </div>
            </div>
            <div class="col-md-2 text-end">
                <button class="btn btn-primary" type="submit">Filtrar</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-sm align-middle estoque-table">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th>Categoria</th>
                        <th class="text-end">Estoque</th>
                        <th class="text-end">Mínimo</th>
                        <th class="text-end">Preço</th>
                        <th class="text-end">Status</th>
                        <th class="text-end">Movimentações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.PosicaoEstoque.Items)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.Nome</div>
                                <div class="small text-muted">@item.CodigoProprio</div>
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(item.CategoriaNome) ? "-" : item.CategoriaNome)</td>
                            <td class="text-end">@item.EstoqueAtual.ToString("N3")</td>
                            <td class="text-end">@item.EstoqueMinimo.ToString("N3")</td>
                            <td class="text-end">R$ @item.PrecoVenda.ToString("N2")</td>
                            <td class="text-end">
                                @if (!item.ControlarEstoque)
                                {
                                    <span class="badge bg-secondary">Sem controle</span>
                                }
                                else if (item.EstoqueBaixo)
                                {
                                    <span class="badge bg-warning text-dark">Baixo</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Ok</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="estoque-actions">
                                    <a class="btn btn-sm btn-primary" href="@Model.ObterUrlMovimentacoes(item.IdProduto)">Ver</a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.PosicaoEstoque.Items.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">Nenhum produto encontrado.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.PosicaoEstoque.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    @for (var i = 1; i <= Model.PosicaoEstoque.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PosicaoEstoque.PageIndex ? "active" : "")">
                            <a class="page-link" asp-page="/Estoque/Index" asp-route-posPage="@i" asp-route-q="@Model.q" asp-route-somenteBaixo="@Model.somenteBaixo">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>
