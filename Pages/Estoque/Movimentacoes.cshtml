@page
@model CorteCor.Pages.Estoque.MovimentacoesModel
@using CorteCor.Models
@{
    ViewData["Title"] = "Movimentações de Estoque";
}

@section Styles {
    <style>
        .estoque-shell-card {
            border: 0;
            border-radius: 20px;
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
        }

        .estoque-hero {
            background: linear-gradient(135deg, #ecfdf5 0%, #ffffff 45%, #eff6ff 100%);
            border-radius: 24px;
            padding: 1.6rem;
            margin-bottom: 1.5rem;
        }

        .estoque-note {
            border-radius: 14px;
            padding: 0.9rem 1rem;
            background: #eff6ff;
            border: 1px solid #93c5fd;
            color: #1d4ed8;
            font-size: 0.95rem;
        }

        .estoque-table td {
            vertical-align: top;
        }
    </style>
}

<div class="estoque-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h2 class="mb-1">Movimentações de Estoque</h2>
            <div class="text-muted">Audite entradas, saídas, estornos e ajustes do estoque com filtros por produto, tipo e período.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" asp-page="/Estoque/AjusteManual">Ajuste Manual</a>
            <a class="btn btn-secondary" asp-page="/Estoque/Index">Voltar para estoque</a>
        </div>
    </div>
</div>

@if (Model.ProdutoSelecionado != null)
{
    <div class="estoque-note mb-4">
        Exibindo movimentações do produto <strong>@Model.ProdutoSelecionado.Nome</strong>.
    </div>
}

<div class="card estoque-shell-card">
    <div class="card-header bg-white fw-semibold">Movimentações</div>
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end mb-3">
            <div class="col-md-4">
                <label class="form-label">Produto</label>
                <select class="form-select" name="idProduto">
                    <option value="">Todos</option>
                    @foreach (var produto in Model.ProdutosFiltro)
                    {
                        if (Model.idProduto == produto.IdProduto)
                        {
                            <option value="@produto.IdProduto" selected>@produto.Nome</option>
                        }
                        else
                        {
                            <option value="@produto.IdProduto">@produto.Nome</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Tipo</label>
                <select class="form-select" name="movTipo">
                    <option value="">Todos</option>
                    @if (Model.movTipo == MovimentoEstoqueTipo.Entrada)
                    {
                        <option value="@MovimentoEstoqueTipo.Entrada" selected>Entrada</option>
                    }
                    else
                    {
                        <option value="@MovimentoEstoqueTipo.Entrada">Entrada</option>
                    }
                    @if (Model.movTipo == MovimentoEstoqueTipo.Saida)
                    {
                        <option value="@MovimentoEstoqueTipo.Saida" selected>Saída</option>
                    }
                    else
                    {
                        <option value="@MovimentoEstoqueTipo.Saida">Saída</option>
                    }
                    @if (Model.movTipo == MovimentoEstoqueTipo.Estorno)
                    {
                        <option value="@MovimentoEstoqueTipo.Estorno" selected>Estorno</option>
                    }
                    else
                    {
                        <option value="@MovimentoEstoqueTipo.Estorno">Estorno</option>
                    }
                    @if (Model.movTipo == MovimentoEstoqueTipo.Ajuste)
                    {
                        <option value="@MovimentoEstoqueTipo.Ajuste" selected>Ajuste</option>
                    }
                    else
                    {
                        <option value="@MovimentoEstoqueTipo.Ajuste">Ajuste</option>
                    }
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label">Pesquisar movimento</label>
                <input class="form-control" type="text" name="movQ" value="@Model.movQ" placeholder="Produto, observação ou venda" />
            </div>
            <div class="col-md-5">
                <label class="form-label">Período</label>
                <div class="d-flex gap-2">
                    <input class="form-control" type="date" name="movDataInicio" value="@Model.movDataInicio?.ToString("yyyy-MM-dd")" />
                    <input class="form-control" type="date" name="movDataFim" value="@Model.movDataFim?.ToString("yyyy-MM-dd")" />
                </div>
            </div>
            <div class="col-md-7 text-end">
                <button class="btn btn-primary" type="submit">Filtrar movimentações</button>
                <a class="btn btn-secondary" asp-page="/Estoque/Movimentacoes">Limpar</a>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-sm align-middle estoque-table">
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Produto</th>
                        <th>Origem</th>
                        <th class="text-end">Qtd.</th>
                        <th class="text-end">Saldo</th>
                        <th>Observação</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Movimentos.Items)
                    {
                        <tr>
                            <td>@item.DataMovimento.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.NomeProduto</td>
                            <td>
                                <div class="fw-semibold">@item.TipoMovimento</div>
                                <div class="small text-muted">@item.Origem</div>
                            </td>
                            <td class="text-end">@item.Quantidade.ToString("N3")</td>
                            <td class="text-end">@item.SaldoPosterior.ToString("N3")</td>
                            <td>@item.Observacao</td>
                        </tr>
                    }
                    @if (!Model.Movimentos.Items.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Nenhuma movimentação encontrada.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Movimentos.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    @for (var i = 1; i <= Model.Movimentos.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Movimentos.PageIndex ? "active" : "")">
                            <a class="page-link"
                               asp-page="/Estoque/Movimentacoes"
                               asp-route-movPage="@i"
                               asp-route-idProduto="@Model.idProduto"
                               asp-route-movQ="@Model.movQ"
                               asp-route-movTipo="@Model.movTipo"
                               asp-route-movDataInicio="@Model.movDataInicio?.ToString("yyyy-MM-dd")"
                               asp-route-movDataFim="@Model.movDataFim?.ToString("yyyy-MM-dd")">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>
