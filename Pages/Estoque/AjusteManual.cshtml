@page
@model CorteCor.Pages.Estoque.AjusteManualModel
@using CorteCor.Models
@{
    ViewData["Title"] = "Ajuste Manual";
}

@section Styles {
    <style>
        .estoque-shell-card {
            border: 0;
            border-radius: 20px;
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
        }

        .estoque-hero {
            background: linear-gradient(135deg, #ecfdf5 0%, #ffffff 45%, #eff6ff 100%);
            border-radius: 24px;
            padding: 1.6rem;
            margin-bottom: 1.5rem;
        }

        .estoque-note {
            border-radius: 14px;
            padding: 0.9rem 1rem;
            background: #eff6ff;
            border: 1px solid #93c5fd;
            color: #1d4ed8;
            font-size: 0.95rem;
        }
    </style>
}

<div class="estoque-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h2 class="mb-1">Ajuste Manual</h2>
            <div class="text-muted">Registre entradas e saídas manuais com observação e rastreabilidade completa no histórico do estoque.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-secondary" asp-page="/Estoque/Index">Voltar para estoque</a>
            <a class="btn btn-dark" asp-page="/Estoque/Movimentacoes">Movimentações</a>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-@(Model.FlashType ?? "info")">@Model.FlashMessage</div>
}

<div class="card estoque-shell-card">
    <div class="card-header bg-white fw-semibold">Registrar ajuste manual</div>
    <div class="card-body">
        <form method="post" class="row g-3">
            <div class="col-12">
                <label class="form-label">Produto</label>
                <select class="form-select" name="idProduto" required>
                    <option value="">Selecione...</option>
                    @foreach (var produto in Model.ProdutosAjuste)
                    {
                        if (Model.idProduto == produto.IdProduto)
                        {
                            <option value="@produto.IdProduto" selected>@produto.Nome</option>
                        }
                        else
                        {
                            <option value="@produto.IdProduto">@produto.Nome</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Tipo</label>
                <select class="form-select" name="tipoMovimento">
                    <option value="@MovimentoEstoqueTipo.Entrada">Entrada</option>
                    <option value="@MovimentoEstoqueTipo.Saida">Saída</option>
                </select>
            </div>
            <div class="col-md-8">
                <label class="form-label">Quantidade</label>
                <input class="form-control" type="number" name="quantidade" min="0.001" step="0.001" value="1" required />
            </div>
            <div class="col-12">
                <label class="form-label">Observação</label>
                <textarea class="form-control" name="observacao" rows="4" maxlength="500" placeholder="Motivo do ajuste"></textarea>
            </div>
            <div class="col-12">
                <div class="estoque-note">
                    O ajuste manual registra histórico completo e não substitui as baixas automáticas geradas por vendas e pós-venda.
                </div>
            </div>
            <div class="col-12 text-end">
                <button class="btn btn-primary" type="submit">Registrar ajuste</button>
            </div>
        </form>
    </div>
</div>
