@page
@model CorteCor.Pages.SalaoConfigFiscalModel
@{
    ViewData["Title"] = "Configuração Fiscal";
}

<div class="container mt-4">
    <h2>Configuração Fiscal (NFC-e / NFS-e)</h2>
    <hr />

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
                <div class="alert alert-success">@Model.Mensagem</div>
    }
    @if (!string.IsNullOrEmpty(Model.Erro))
    {
                <div class="alert alert-danger">@Model.Erro</div>
    }

    <form method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Configuracao.IdConfigFiscal" />
        <input type="hidden" asp-for="Configuracao.IdSalao" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Razão Social</label>
                <input type="text" asp-for="Configuracao.RazaoSocial" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">CNPJ</label>
                <input type="text" asp-for="Configuracao.Cnpj" class="form-control cnpj" required />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Inscrição Estadual</label>
                <input type="text" asp-for="Configuracao.InscricaoEstadual" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Inscrição Municipal</label>
                <input type="text" asp-for="Configuracao.InscricaoMunicipal" class="form-control" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Ambiente Sefaz/Prefeitura</label>
                <select asp-for="Configuracao.Ambiente" class="form-control">
                    <option value="2">Homologação (Testes)</option>
                    <option value="1">Produção (Oficial)</option>
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Regime Tributário</label>
                <select asp-for="Configuracao.RegimeTributario" class="form-control">
                    <option value="1">Simples Nacional</option>
                    <option value="2">Simples Nacional - Excesso Receita Bruta</option>
                    <option value="3">Regime Normal (Lucro Presumido/Real)</option>
                </select>
            </div>
            <div class="col-md-2 mb-3">
                <label class="form-label">Cód. UF (IBGE)</label>
                <input type="number" asp-for="Configuracao.CodigoUFIBGE" class="form-control" required />
            </div>
            <div class="col-md-2 mb-3">
                <label class="form-label">Cód. Município (IBGE)</label>
                <input type="number" asp-for="Configuracao.CodigoMunicipioIBGE" class="form-control" required />
            </div>
        </div>

        <div class="row">
            <div class="col-md-12 mb-3">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="emissaoAuto" asp-for="Configuracao.EmissaoAutomatica">
                    <label class="form-check-label" for="emissaoAuto">
                        <strong>Emissão Automática ao Pagar</strong> <br>
                        <small class="text-muted">Gera e envia a nota fiscal automaticamente para a Sefaz/Prefeitura assim que o agendamento for registrado como "Pago".</small>
                    </label>
                </div>
            </div>
        </div>

        <h4 class="mt-4">Certificado Digital (A1)</h4>
        <div class="card p-3 bg-light mb-4">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Upload do arquivo (.pfx)</label>
                    <input type="file" name="certificadoFile" class="form-control" accept=".pfx" />
                    @if (Model.PossuiCertificadoSalvo)
                    {
                                <small class="text-success fw-bold d-block mt-1">O Salão já possui um certificado salvo. Envie outro apenas para substituí-lo.</small>
                    }
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Senha do Certificado</label>
                    <input type="password" name="senhaCertificado" class="form-control" />
                </div>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary px-4">Salvar Configurações</button>
            <a href="/" class="btn btn-secondary ms-2">Voltar</a>
        </div>
    </form>
</div>

@section Scripts {
            <script>
                $(document).ready(function () {
                     $('.cnpj').inputmask('99.999.999/9999-99');
                });
            </script>
}
