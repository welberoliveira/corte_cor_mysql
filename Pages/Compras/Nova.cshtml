@page
@model CorteCor.Pages.Compras.NovaModel
@{
    ViewData["Title"] = "Nova compra";
}

<style>
    .search-wrap { position: relative; }
    .search-results {
        position: absolute;
        z-index: 1050;
        top: 100%;
        left: 0;
        right: 0;
        max-height: 260px;
        overflow-y: auto;
        background: #fff;
        border: 1px solid #cbd5e1;
        border-radius: 0 0 10px 10px;
        box-shadow: 0 16px 30px rgba(15, 23, 42, 0.12);
        display: none;
    }
    .search-option {
        width: 100%;
        border: 0;
        background: #fff;
        text-align: left;
        padding: 0.65rem 0.8rem;
    }
    .search-option:hover, .search-option:focus { background: #eff6ff; }
</style>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <h2 class="mb-1">Nova compra</h2>
        <div class="text-muted">Registre entrada de estoque e gere a conta a pagar da compra.</div>
    </div>
    <a class="btn btn-secondary" asp-page="/Compras/Index">Voltar para compras</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-@(Model.FlashType ?? "info")">@Model.FlashMessage</div>
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white fw-semibold">Dados da compra</div>
    <div class="card-body">
        <form method="post" asp-page-handler="Salvar" id="compraForm" class="row g-3">
            <input type="hidden" id="payloadJson" name="payloadJson" />

            <div class="col-md-6">
                <label class="form-label">Fornecedor</label>
                <div class="search-wrap">
                    <input type="hidden" id="fornecedorId" />
                    <input class="form-control" id="fornecedorBusca" placeholder="Digite nome, CPF/CNPJ, e-mail ou telefone" autocomplete="off" />
                    <div class="search-results" id="fornecedorResultados"></div>
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Documento</label>
                <input class="form-control" id="documentoInput" maxlength="60" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Data da compra</label>
                <input type="date" class="form-control" id="dataCompraInput" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Vencimento</label>
                <input type="date" class="form-control" id="dataVencimentoInput" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Conta caixa</label>
                <select class="form-select" id="contaCaixaSelect">
                    <option value="">Sem conta</option>
                    @foreach (var conta in Model.ContasCaixa)
                    {
                        <option value="@conta.IdConta">@conta.Nome</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="pagaNaHoraCheck" />
                    <label class="form-check-label" for="pagaNaHoraCheck">Compra paga na hora</label>
                </div>
            </div>

            <div class="col-md-6">
                <label class="form-label">Grupo do Plano de Contas</label>
                <select class="form-select" id="grupoPlanoContaSelect" data-smart-select data-smart-placeholder="Digite para pesquisar grupo...">
                    <option value="">Selecione o grupo</option>
                    @foreach (var grupo in Model.GruposPlano)
                    {
                        <option value="@grupo.IdPlano" selected="@(Model.GrupoPlanoContaId == grupo.IdPlano)">@grupo.Codigo - @grupo.NomeExibicao</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Conta do Plano de Contas</label>
                <select class="form-select" id="planoContaSelect" data-smart-select data-smart-placeholder="Digite para pesquisar conta...">
                    <option value="">Selecione a conta</option>
                    @foreach (var plano in Model.ContasPlano)
                    {
                        <option value="@plano.IdPlano">@plano.Codigo - @plano.NomeExibicao</option>
                    }
                </select>
            </div>

            <div class="col-md-5">
                <label class="form-label">Produto</label>
                <select class="form-select" id="produtoSelect" data-smart-select data-smart-placeholder="Digite para pesquisar produto..."></select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Quantidade</label>
                <input type="number" class="form-control" id="quantidadeInput" value="1" min="1" step="1" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Valor unitário</label>
                <input type="number" class="form-control" id="valorUnitarioInput" value="0" min="0" step="0.01" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="button" class="btn btn-primary w-100" id="addItemBtn">Adicionar</button>
            </div>

            <div class="col-12">
                <div class="table-responsive">
                    <table class="table table-sm align-middle" id="itensTable">
                        <thead><tr><th>Produto</th><th class="text-end">Qtd.</th><th class="text-end">Unitário</th><th class="text-end">Total</th><th></th></tr></thead>
                        <tbody><tr><td colspan="5" class="text-center text-muted py-4">Nenhum item adicionado.</td></tr></tbody>
                    </table>
                </div>
            </div>

            <div class="col-12">
                <label class="form-label">Observações</label>
                <textarea class="form-control" id="observacoesInput" rows="3"></textarea>
            </div>

            <div class="col-12 d-flex justify-content-between align-items-center">
                <div class="fs-4 fw-bold" id="totalLabel">R$ 0,00</div>
                <button type="submit" class="btn btn-primary">Registrar compra</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const produtos = @Html.Raw(Model.ProdutosJson);
        const fornecedoresBuscaUrl = '@Url.Page("/API/Clientes")';
        const carrinho = [];
        const fornecedorId = document.getElementById('fornecedorId');
        const fornecedorBusca = document.getElementById('fornecedorBusca');
        const fornecedorResultados = document.getElementById('fornecedorResultados');
        const produtoSelect = document.getElementById('produtoSelect');
        const quantidadeInput = document.getElementById('quantidadeInput');
        const valorUnitarioInput = document.getElementById('valorUnitarioInput');
        const itensTableBody = document.querySelector('#itensTable tbody');
        const totalLabel = document.getElementById('totalLabel');
        const grupoPlanoContaSelect = document.getElementById('grupoPlanoContaSelect');
        const planoContaSelect = document.getElementById('planoContaSelect');
        let fornecedorTimer = null;

        function moeda(valor) {
            return Number(valor || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
        }

        function preencherProdutos() {
            produtoSelect.innerHTML = '';
            produtos.forEach(produto => {
                const option = document.createElement('option');
                option.value = produto.id;
                option.dataset.valor = produto.valor;
                option.textContent = `${produto.nome} | estoque: ${Math.trunc(produto.estoqueAtual)}`;
                produtoSelect.appendChild(option);
            });
            atualizarValorProduto();
        }

        function atualizarValorProduto() {
            const selected = produtoSelect.options[produtoSelect.selectedIndex];
            valorUnitarioInput.value = selected?.dataset?.valor ? Number(selected.dataset.valor).toFixed(2) : '0.00';
        }

        function renderCarrinho() {
            if (!carrinho.length) {
                itensTableBody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">Nenhum item adicionado.</td></tr>';
                totalLabel.textContent = moeda(0);
                return;
            }

            itensTableBody.innerHTML = carrinho.map((item, index) => `
                <tr>
                    <td>${item.nomeProduto}</td>
                    <td class="text-end">${Math.trunc(item.quantidade)}</td>
                    <td class="text-end">${moeda(item.valorUnitario)}</td>
                    <td class="text-end fw-semibold">${moeda(item.quantidade * item.valorUnitario)}</td>
                    <td class="text-end"><button type="button" class="btn btn-sm btn-danger" onclick="removerItem(${index})">Remover</button></td>
                </tr>
            `).join('');
            totalLabel.textContent = moeda(carrinho.reduce((acc, item) => acc + item.quantidade * item.valorUnitario, 0));
        }

        window.removerItem = index => {
            carrinho.splice(index, 1);
            renderCarrinho();
        };

        document.getElementById('addItemBtn').addEventListener('click', () => {
            const produto = produtos.find(p => String(p.id) === String(produtoSelect.value));
            const quantidade = Number(quantidadeInput.value || 0);
            const valorUnitario = Number(valorUnitarioInput.value || 0);
            if (!produto || quantidade <= 0 || !Number.isInteger(quantidade) || valorUnitario < 0) {
                alert('Selecione produto, quantidade inteira e valor validos.');
                return;
            }
            carrinho.push({ idProduto: produto.id, nomeProduto: produto.nome, quantidade, valorUnitario });
            quantidadeInput.value = '1';
            renderCarrinho();
        });

        async function carregarContasPlano(idGrupo) {
            planoContaSelect.innerHTML = '<option value="">Selecione a conta</option>';
            if (!idGrupo) return;
            const response = await fetch(`${window.location.pathname}?handler=ContasFilhas&idGrupo=${encodeURIComponent(idGrupo)}`, { headers: { 'Accept': 'application/json' } });
            const contas = response.ok ? await response.json() : [];
            contas.forEach(conta => {
                const option = document.createElement('option');
                option.value = conta.id;
                option.textContent = conta.rotulo;
                planoContaSelect.appendChild(option);
            });
        }

        async function buscarFornecedores(termo) {
            const response = await fetch(`${fornecedoresBuscaUrl}?q=${encodeURIComponent(termo || '')}&somenteClientes=false&somenteFornecedores=true`, { headers: { 'Accept': 'application/json' } });
            return response.ok ? await response.json() : [];
        }

        function renderFornecedores(lista) {
            fornecedorResultados.innerHTML = lista.length
                ? lista.map(item => `<button type="button" class="search-option" data-id="${item.id}" data-nome="${item.nome}"><span class="fw-semibold">${item.nome}</span><span class="d-block small text-muted">${item.rotulo}</span></button>`).join('')
                : '<div class="px-3 py-2 text-muted">Nenhum fornecedor encontrado.</div>';
            fornecedorResultados.querySelectorAll('.search-option').forEach(botao => {
                botao.addEventListener('click', () => {
                    fornecedorId.value = botao.dataset.id;
                    fornecedorBusca.value = botao.dataset.nome;
                    fornecedorResultados.style.display = 'none';
                });
            });
            fornecedorResultados.style.display = 'block';
        }

        fornecedorBusca.addEventListener('input', () => {
            fornecedorId.value = '';
            clearTimeout(fornecedorTimer);
            fornecedorTimer = setTimeout(async () => renderFornecedores(await buscarFornecedores(fornecedorBusca.value.trim())), 250);
        });
        fornecedorBusca.addEventListener('focus', async () => renderFornecedores(await buscarFornecedores(fornecedorBusca.value.trim())));
        document.addEventListener('click', event => {
            if (!event.target.closest('.search-wrap')) fornecedorResultados.style.display = 'none';
        });
        produtoSelect.addEventListener('change', atualizarValorProduto);
        grupoPlanoContaSelect.addEventListener('change', () => carregarContasPlano(grupoPlanoContaSelect.value));

        document.getElementById('compraForm').addEventListener('submit', event => {
            if (!carrinho.length) {
                event.preventDefault();
                alert('Adicione ao menos um produto.');
                return;
            }
            if (!planoContaSelect.value) {
                event.preventDefault();
                alert('Selecione uma conta analitica do plano de contas.');
                return;
            }
            if (document.getElementById('pagaNaHoraCheck').checked && !document.getElementById('contaCaixaSelect').value) {
                event.preventDefault();
                alert('Selecione de qual conta caixa saiu o dinheiro.');
                return;
            }
            document.getElementById('payloadJson').value = JSON.stringify({
                idPessoaFornecedor: fornecedorId.value ? Number(fornecedorId.value) : null,
                idPlano: Number(planoContaSelect.value),
                idConta: document.getElementById('contaCaixaSelect').value ? Number(document.getElementById('contaCaixaSelect').value) : null,
                pagaNaHora: document.getElementById('pagaNaHoraCheck').checked,
                dataCompra: document.getElementById('dataCompraInput').value,
                dataVencimento: document.getElementById('dataVencimentoInput').value,
                documento: document.getElementById('documentoInput').value || null,
                observacoes: document.getElementById('observacoesInput').value || null,
                itens: carrinho.map(item => ({ idProduto: item.idProduto, quantidade: item.quantidade, valorUnitario: item.valorUnitario }))
            });
        });

        preencherProdutos();
        renderCarrinho();
    </script>
}
