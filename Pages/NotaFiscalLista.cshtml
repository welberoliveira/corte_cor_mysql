@page
@model CorteCor.Pages.NotaFiscalListaModel
@{
    ViewData["Title"] = "Notas Emitidas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Notas Emitidas (NFC-e / NFS-e)</h2>
        <div>
            <a asp-page="/NotaFiscalInutilizacao" class="btn btn-warning me-2">
                <i class="bi bi-x-octagon"></i> Inutilizar NÂº (NFC-e)
            </a>
            <a asp-page="/EmpresaConfigFiscal" class="btn btn-primary">
                <i class="bi bi-gear"></i> CFG. Fiscal
            </a>
        </div>
    </div>
    <hr />

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
            <div class="alert alert-success">@Model.Mensagem</div>
    }
    @if (!string.IsNullOrEmpty(Model.Erro))
    {
            <div class="alert alert-danger">@Model.Erro</div>
    }
    @if (!string.IsNullOrEmpty(Model.FiltroDescricao))
    {
            <div class="alert alert-info d-flex justify-content-between align-items-center">
                <span>@Model.FiltroDescricao</span>
                <a asp-page="/NotaFiscalLista" class="btn btn-sm btn-secondary">Limpar filtro</a>
            </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Data</th>
                    <th>Tipo</th>
                    <th>NÃºmero</th>
                    <th>Valor</th>
                    <th>Status</th>
                    <th>AÃ§Ãµes</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Notas != null && Model.Notas.Any())
                {
                    foreach (var nota in Model.Notas)
                    {
                                <tr>
                                    <td>@nota.DataEmissao.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td><span class="badge bg-secondary">@nota.TipoNota</span></td>
                                    <td>@nota.Numero</td>
                                    <td>R$ @nota.ValorTotal.ToString("0.00")</td>
                                    <td>
                                @if (nota.Status == "Autorizada")
                                {
                                                <span class="badge bg-success">@nota.Status</span>
                                }
                                else if (nota.Status == "Processando")
                                {
                                                <span class="badge bg-warning text-dark">@nota.Status</span>
                                }
                                else if (nota.Status == "Rejeitada")
                                {
                                                <span class="badge bg-danger">@nota.Status</span>
                                }
                                else
                                {
                                                <span class="badge bg-info text-dark">@nota.Status</span>
                                }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                    @if (!string.IsNullOrEmpty(nota.XmlRetorno) && nota.Status == "Autorizada")
                                    {
                                                    <form method="post" asp-page-handler="DownloadXml" style="display:inline;">
                                                        <input type="hidden" name="idNota" value="@nota.IdNotaFiscal" />
                                                        <button type="submit" class="btn btn-sm btn-primary" title="Download XML">
                                                            <i class="bi bi-file-earmark-code"></i> XML
                                                        </button>
                                                    </form>

                                                    <form method="post" asp-page-handler="GerarPdf" style="display:inline;" target="_blank">
                                                        <input type="hidden" name="idNota" value="@nota.IdNotaFiscal" />
                                                        <button type="submit" class="btn btn-sm btn-danger" title="Gerar PDF">
                                                            <i class="bi bi-file-earmark-pdf"></i> PDF
                                                        </button>
                                                    </form>

                                                    <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#emailModal-@nota.IdNotaFiscal" title="Enviar por E-mail">
                                                        <i class="bi bi-envelope"></i> E-mail
                                                    </button>

                                                    <button type="button" class="btn btn-sm btn-dark" data-bs-toggle="modal" data-bs-target="#cancelModal-@nota.IdNotaFiscal" title="Cancelar Nota">
                                                        <i class="bi bi-x-circle"></i> Cancelar
                                                    </button>
                                    }

                                    @if (nota.Status == "Processando")
                                    {
                                                    <form method="post" asp-page-handler="Consultar" style="display:inline;">
                                                        <input type="hidden" name="idNota" value="@nota.IdNotaFiscal" />
                                                        <button type="submit" class="btn btn-sm btn-warning"
                                                            title="Consultar Sefaz/Prefeitura">
                                                            <i class="bi bi-arrow-clockwise"></i> Recibo
                                                        </button>
                                                    </form>
                                    }
                                        </div>

                                        <!-- Modal Cancelamento -->
                                        <div class="modal fade" id="cancelModal-@nota.IdNotaFiscal" tabindex="-1" aria-labelledby="cancelModalLabel-@nota.IdNotaFiscal" aria-hidden="true">
                                          <div class="modal-dialog">
                                            <div class="modal-content">
                                              <form method="post" asp-page-handler="CancelarNota">
                                                  <div class="modal-header">
                                                    <h5 class="modal-title" id="cancelModalLabel-@nota.IdNotaFiscal">Cancelar Nota @nota.Numero</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                  </div>
                                                  <div class="modal-body">
                                                    <input type="hidden" name="idNota" value="@nota.IdNotaFiscal" />
                                                    <div class="mb-3">
                                                        <label class="form-label text-start d-block">Justificativa de Cancelamento (MÃ­nimo 15 caracteres):</label>
                                                        <textarea class="form-control" name="justificativa" rows="3" required minlength="15"></textarea>
                                                    </div>
                                                  </div>
                                                  <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                                                    <button type="submit" class="btn btn-danger">Confirmar Cancelamento</button>
                                                  </div>
                                              </form>
                                            </div>
                                          </div>
                                        </div>

                                        <!-- Modal Envio de Email -->
                                        <div class="modal fade" id="emailModal-@nota.IdNotaFiscal" tabindex="-1" aria-labelledby="emailModalLabel-@nota.IdNotaFiscal" aria-hidden="true">
                                          <div class="modal-dialog">
                                            <div class="modal-content">
                                              <form method="post" asp-page-handler="EnviarEmail">
                                                  <div class="modal-header">
                                                    <h5 class="modal-title" id="emailModalLabel-@nota.IdNotaFiscal">Enviar Nota @nota.Numero por E-mail</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                  </div>
                                                  <div class="modal-body">
                                                    <input type="hidden" name="idNota" value="@nota.IdNotaFiscal" />
                                                    <div class="mb-3">
                                                        <label class="form-label text-start d-block">Nome do destinatario</label>
                                                        <input class="form-control" name="nomeDestino" value="" />
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label text-start d-block">E-mail do destinatario</label>
                                                        <input class="form-control" name="emailDestino" type="email" required />
                                                        <div class="form-text">O envio anexara o PDF e os XMLs disponiveis da nota.</div>
                                                    </div>
                                                  </div>
                                                  <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                                                    <button type="submit" class="btn btn-success">Enviar E-mail</button>
                                                  </div>
                                              </form>
                                            </div>
                                          </div>
                                        </div>
                                    </td>
                                </tr>
                    }
                }
                else
                {
                        <tr>
                            <td colspan="6" class="text-center text-muted">Nenhuma nota fiscal emitida atÃ© o momento.</td>
                        </tr>
                }
            </tbody>
        </table>
    </div>
</div>

