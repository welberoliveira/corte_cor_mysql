@page
@model CorteCor.Pages.ServicoListaModel

<div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h4>Lista de Servicos</h4>
        <a asp-page="/ServicoCadastro" class="btn btn-primary">Cadastrar Novo</a>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="q" class="form-label">Buscar por nome ou tags</label>
                    <input type="text" id="q" name="q" value="@Model.q" class="form-control" placeholder="Digite sua busca">
                </div>
                <div class="col-md-3">
                    <label for="idCategoria" class="form-label">Filtrar por categoria</label>
                    <select name="idCategoria" id="idCategoria" class="form-select">
                        <option value="">-- Todas --</option>
                        @foreach (var cat in Model.Categorias)
                        {
                            var isSelected = Model.IdCategoria == cat.IdCategoria ? "selected" : "";
                            @Html.Raw($"<option value='{cat.IdCategoria}' {isSelected}>{cat.Nome}</option>")
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" id="incluirArquivados" name="incluirArquivados" value="true" @(Model.incluirArquivados ? "checked" : "")>
                        <label class="form-check-label" for="incluirArquivados">Mostrar arquivados</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert alert-@Model.MensagemTipo mt-3">
            @Model.Mensagem
        </div>
    }

    <div class="table-responsive mt-3">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>Preco</th>
                    <th>Duracao</th>
                    <th>Status</th>
                    <th>Acoes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var servico in Model.Servicos.Items)
                {
                    <tr>
                        <td>@servico.Nome</td>
                        <td>@(string.IsNullOrWhiteSpace(servico.CategoriaNome) ? "-" : servico.CategoriaNome)</td>
                        <td>R$ @servico.Preco.ToString("0.00")</td>
                        <td>@servico.Duracao.ToString(@"hh\:mm")</td>
                        <td>
                            @if (servico.Arquivado)
                            {
                                <span class="badge bg-secondary">Arquivado</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Ativo</span>
                            }
                        </td>
                        <td class="actions">
                            <form method="post" style="display: inline;">
                                <input type="hidden" name="id" value="@servico.IdServico">
                                <input type="hidden" name="action" value="alterar">
                                <input type="hidden" name="idCategoria" value="@Model.IdCategoria">
                                <input type="hidden" name="q" value="@Model.q">
                                <input type="hidden" name="incluirArquivados" value="@Model.incluirArquivados">
                                <input type="hidden" name="p" value="@Model.Servicos.PageIndex">
                                <button class="btn btn-info">Alterar</button>
                            </form>

                            <form method="post" style="display: inline;" onsubmit="return confirm('Tem certeza que deseja excluir este servico?');">
                                <input type="hidden" name="id" value="@servico.IdServico">
                                <input type="hidden" name="action" value="excluir">
                                <input type="hidden" name="idCategoria" value="@Model.IdCategoria">
                                <input type="hidden" name="q" value="@Model.q">
                                <input type="hidden" name="incluirArquivados" value="@Model.incluirArquivados">
                                <input type="hidden" name="p" value="@Model.Servicos.PageIndex">
                                <button class="btn btn-danger">Excluir</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Servicos.TotalPages > 1)
    {
        <nav aria-label="Paginacao de servicos">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Servicos.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="?p=@(Model.Servicos.PageIndex - 1)&q=@Model.q&idCategoria=@Model.IdCategoria&incluirArquivados=@Model.incluirArquivados">Anterior</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Pagina @Model.Servicos.PageIndex de @Model.Servicos.TotalPages</span>
                </li>
                <li class="page-item @(Model.Servicos.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="?p=@(Model.Servicos.PageIndex + 1)&q=@Model.q&idCategoria=@Model.IdCategoria&incluirArquivados=@Model.incluirArquivados">Proxima</a>
                </li>
            </ul>
        </nav>
    }
</div>
