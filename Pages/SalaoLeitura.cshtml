@page
@model CorteCor.Pages.SalaoLeituraModel
@{
    ViewData["Title"] = "Cadastro de Saloes";
}

<div class="container">
    <h4>@Model.ButtonText Salao</h4>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert alert-success">
            @Model.Mensagem
        </div>
    }

    <form method="post">
        <input type="hidden" name="id" value="@Model.Salao?.IdSalao">

        <div class="form-group">
            <label for="nome">Cidade</label>
            <input type="text" id="nome" name="nome" class="form-control" required value="@Model.Salao?.Nome" readonly>
        </div>

        <div class="form-group">
            <label for="responsavel">Responsável</label>
            <input type="text" id="responsavel" name="responsavel" class="form-control" required value="@Model.Salao?.Responsavel" readonly>
        </div>

        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" class="form-control" required value="@Model.Salao?.Email" readonly>
        </div>

        <div class="form-group">
            <label for="telefone">Telefone</label>
            <input type="text" id="telefone" name="telefone" class="form-control" required value="@Model.Salao?.Telefone" readonly>
        </div>

        <div class="form-group">
            <label for="endereco">Endereço</label>
            <input type="text" id="endereco" name="endereco" class="form-control" value="@Model.Salao?.Endereco" readonly>
        </div>

        <div class="form-group">
            <label for="cnpj">CNPJ</label>
            <input type="text" id="cnpj" name="cnpj" class="form-control" value="@Model.Salao?.CNPJ" readonly>
        </div>

        <div class="form-group">
            <label for="observacao">Observação</label>
            <textarea id="observacao" name="observacao" class="form-control" readonly>@Model.Salao?.Observacao</textarea>
        </div>


        <div class="form-group">
            <label for="dataCadastro">Data de Cadastro</label>
            <input type="date" id="dataCadastro" name="dataCadastro" class="form-control" required
                   value="@(Model.Salao?.DataCadastro.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))" readonly>
        </div>

        <small class="form-text text-muted">
            Informações para simples conferência. Caso deseje alterar, contate o Administrador do Sistema.
        </small>
    </form>
</div>

<script>
    $(document).ready(function () {
        $("#telefone").inputmask("(99) 99999-9999"); // Máscara para telefone
        $("#cnpj").inputmask("99.999.999/9999-99");   // Máscara para CNPJ
    });
</script>
