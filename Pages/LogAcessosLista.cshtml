@page
@model CorteCor.Pages.LogAcessosListaModel
@{
    ViewData["Title"] = "Log de Acessos";
}

<div class="container">
    <h4>Log de Acessos</h4>
    <p class="text-muted">Registro de tentativas de login no sistema.</p>

    @* ── Filtros ── *@
    <form method="get" class="card card-body mb-3 bg-light">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small mb-0">Usuário</label>
                <input type="text" name="FiltroUsuario" class="form-control form-control-sm" value="@Model.FiltroUsuario" placeholder="E-mail...">
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">Data Início</label>
                <input type="date" name="FiltroDataInicio" class="form-control form-control-sm" value="@Model.FiltroDataInicio">
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">Data Fim</label>
                <input type="date" name="FiltroDataFim" class="form-control form-control-sm" value="@Model.FiltroDataFim">
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">IP Origem</label>
                <input type="text" name="FiltroIP" class="form-control form-control-sm" value="@Model.FiltroIP" placeholder="IP...">
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">Credencial</label>
                <input type="text" name="FiltroCredencial" class="form-control form-control-sm" value="@Model.FiltroCredencial" placeholder="Tipo...">
            </div>
            <div class="col-md-1">
                <label class="form-label small mb-0">Resultado</label>
                <select name="FiltroResultado" class="form-control form-control-sm">
                    <option value="todos" selected="@(Model.FiltroResultado == "todos" || string.IsNullOrEmpty(Model.FiltroResultado))">Todos</option>
                    <option value="sucesso" selected="@(Model.FiltroResultado == "sucesso")">Sucesso</option>
                    <option value="falha" selected="@(Model.FiltroResultado == "falha")">Falha</option>
                </select>
            </div>
            <div class="col-md-1 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm" title="Filtrar">
                    <i class="bi bi-search"></i>
                </button>
                <a href="@Url.Page("/LogAcessosLista")" class="btn btn-secondary btn-sm" title="Limpar">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>
    </form>

    <p class="text-muted small">@Model.Logs.Count registro(s) encontrado(s).</p>

    <table class="table table-striped table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Usuário</th>
                <th>Data/Hora</th>
                <th>IP Origem</th>
                <th>Credencial</th>
                <th>Resultado</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Logs.Any())
            {
                @foreach (var log in Model.Logs)
                {
                    <tr class="@(log.Sucesso ? "" : "table-danger")">
                        <td>@log.Id</td>
                        <td>@log.Usuario</td>
                        <td>@log.DataHora.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@log.IP_Origem</td>
                        <td>@log.CredencialUsada</td>
                        <td>
                            @if (log.Sucesso)
                            {
                                <span class="badge bg-success">Sucesso</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Falha</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">Nenhum registro de acesso encontrado.</td>
                </tr>
            }
        </tbody>
    </table>

    <a href="@Url.Content("~/Painel")" class="btn btn-secondary mt-2">
        <i class="bi bi-arrow-left"></i> Voltar ao Painel
    </a>
</div>
