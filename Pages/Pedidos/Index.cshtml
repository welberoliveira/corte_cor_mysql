@page
@model CorteCor.Pages.Pedidos.IndexModel
@using CorteCor.Models
@{
    ViewData["Title"] = "Pedidos";
}

@section Styles {
    <style>
        .pedido-card, .venda-refino-card, .estoque-refino-card {
            border: 0;
            border-radius: 18px;
            box-shadow: 0 14px 35px rgba(15, 23, 42, 0.08);
        }

        .pedido-hero {
            background: linear-gradient(135deg, #fff7ed 0%, #ffffff 55%, #eef6ff 100%);
            border-radius: 22px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .pedido-kpi {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 1rem 1.1rem;
            height: 100%;
        }

        .pedido-kpi-label {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #6b7280;
            margin-bottom: 0.35rem;
        }

        .pedido-kpi-value {
            font-size: 1.6rem;
            font-weight: 700;
            color: #111827;
        }

        .pedido-note {
            border-radius: 14px;
            padding: 0.9rem 1rem;
            background: #fff7ed;
            border: 1px solid #fdba74;
            color: #9a3412;
            font-size: 0.95rem;
        }

        .pedido-summary {
            background: #0f172a;
            color: #fff;
            border-radius: 16px;
            padding: 1rem;
        }

        .pedido-summary small {
            color: rgba(255,255,255,0.72);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .pedido-actions {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 0.5rem;
        }

        .pedido-actions .btn {
            min-width: 140px;
        }

        .pedido-status-inline {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.35rem 0.65rem;
            border-radius: 999px;
            font-size: 0.82rem;
            font-weight: 600;
        }

        .pedido-status-aberto { background: #dcfce7; color: #166534; }
        .pedido-status-vencido { background: #fef3c7; color: #92400e; }
        .pedido-status-convertido { background: #dbeafe; color: #1d4ed8; }
        .pedido-status-cancelado { background: #e5e7eb; color: #374151; }

        .pedido-table td {
            vertical-align: top;
        }

        @@media (max-width: 991.98px) {
            .pedido-actions .btn {
                min-width: 100%;
            }
        }
    </style>
}

<div class="pedido-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h2 class="mb-1">Pedidos de Produtos e Servi&ccedil;os</h2>
            <div class="text-muted">Registre propostas e pedidos com validade, acompanhe o relacionamento no CRM e converta em venda quando o cliente fechar.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-primary" asp-page="/Vendas/Index">Ir para Vendas</a>
            <a class="btn btn-outline-dark" asp-page="/Estoque/Index">Controle de Estoque</a>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-@(Model.FlashType ?? "info")">@Model.FlashMessage</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="pedido-kpi">
            <div class="pedido-kpi-label">Pedidos listados</div>
            <div class="pedido-kpi-value">@Model.PainelResumo.PedidosListados</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pedido-kpi">
            <div class="pedido-kpi-label">Pedidos vigentes</div>
            <div class="pedido-kpi-value">@Model.PainelResumo.PedidosVigentes</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pedido-kpi">
            <div class="pedido-kpi-label">Vencendo hoje</div>
            <div class="pedido-kpi-value">@Model.PainelResumo.PedidosVencendoHoje</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pedido-kpi">
            <div class="pedido-kpi-label">Valor na listagem</div>
            <div class="pedido-kpi-value">R$ @Model.PainelResumo.ValorListagem.ToString("N2")</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-5">
        <div class="card pedido-card">
            <div class="card-header bg-white fw-semibold">Novo pedido</div>
            <div class="card-body">
                <form method="post" asp-page-handler="Salvar" id="pedidoForm" class="row g-3">
                    <input type="hidden" id="payloadJson" name="payloadJson" />
                    <input type="hidden" name="q" value="@Model.q" />
                    <input type="hidden" name="idPessoaFiltro" value="@Model.idPessoaFiltro" />
                    <input type="hidden" name="statusFiltro" value="@Model.statusFiltro" />
                    <input type="hidden" name="dataInicio" value="@Model.dataInicio?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="dataFim" value="@Model.dataFim?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="somenteVigentes" value="@Model.somenteVigentes" />
                    <input type="hidden" name="p" value="@Model.p" />

                    <div class="col-md-8">
                        <label class="form-label">Cliente</label>
                        <select class="form-select" id="clienteSelect" required>
                            <option value="">Selecione...</option>
                            @foreach (var cliente in Model.Contexto.Clientes)
                            {
                                <option value="@cliente.IdPessoa">@cliente.Nome</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Validade</label>
                        <input class="form-control" type="date" id="validadeInput" name="validoAte" value="@DateTime.Today.AddDays(7).ToString("yyyy-MM-dd")" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Meio de pagamento sugerido</label>
                        <select class="form-select" id="meioPagamentoSelect">
                            <option value="">Livre</option>
                            @foreach (var meio in Model.Contexto.MeiosPagamento)
                            {
                                <option value="@meio.IdMeioPagamento" data-nome="@meio.Nome">@meio.Nome</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Tipo do item</label>
                        <select class="form-select" id="tipoItemSelect">
                            <option value="Produto">Produto</option>
                            <option value="Servico">Servi&ccedil;o</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Item</label>
                        <select class="form-select" id="catalogoSelect"></select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Quantidade</label>
                        <input type="number" id="quantidadeInput" class="form-control" value="1" min="0.001" step="0.001" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Valor unit&aacute;rio</label>
                        <input type="number" id="valorUnitarioInput" class="form-control" value="0" min="0" step="0.01" />
                    </div>

                    <div class="col-md-8">
                        <label class="form-label">Observa&ccedil;&otilde;es</label>
                        <input type="text" id="observacoesInput" class="form-control" maxlength="500" placeholder="Observa&ccedil;&otilde;es para a proposta ou pedido" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Desconto</label>
                        <input type="number" id="descontoInput" class="form-control" value="0" min="0" step="0.01" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Acr&eacute;scimo</label>
                        <input type="number" id="acrescimoInput" class="form-control" value="0" min="0" step="0.01" />
                    </div>

                    <div class="col-12">
                        <div class="pedido-note">
                            Cada pedido fica vinculado ao cliente no CRM e pode ser convertido em venda. A convers&atilde;o reaproveita as integra&ccedil;&otilde;es com financeiro, estoque e, para servi&ccedil;os, emiss&atilde;o fiscal em homologa&ccedil;&atilde;o.
                        </div>
                    </div>

                    <div class="col-12 d-flex justify-content-end">
                        <button type="button" class="btn btn-outline-primary" id="addItemBtn">Adicionar item</button>
                    </div>

                    <div class="col-12">
                        <div class="table-responsive">
                            <table class="table table-sm align-middle" id="carrinhoTable">
                                <thead>
                                    <tr>
                                        <th>Tipo</th>
                                        <th>Descri&ccedil;&atilde;o</th>
                                        <th class="text-end">Qtd.</th>
                                        <th class="text-end">Unit&aacute;rio</th>
                                        <th class="text-end">Total</th>
                                        <th class="text-end">A&ccedil;&otilde;es</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">Nenhum item adicionado.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="pedido-summary d-flex justify-content-between align-items-center flex-wrap gap-3">
                            <div>
                                <small>Resumo do pedido</small>
                                <div class="fs-4 fw-semibold" id="totalPedidoLabel">R$ 0,00</div>
                            </div>
                            <div class="text-end">
                                <div id="resumoPedidoItems">0 item(ns) no pedido</div>
                                <div class="small text-white-50">Produtos e servi&ccedil;os podem coexistir no mesmo pedido.</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-primary" id="salvarPedidoBtn">Salvar pedido</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="card pedido-card mb-4">
            <div class="card-header bg-white fw-semibold">Filtros de pedidos</div>
            <div class="card-body">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Pesquisa</label>
                        <input class="form-control" name="q" value="@Model.q" placeholder="Cliente, pagamento ou pedido" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Cliente</label>
                        <select class="form-select" name="idPessoaFiltro">
                            <option value="">Todos</option>
                            @foreach (var cliente in Model.Contexto.Clientes)
                            {
                                if (Model.idPessoaFiltro == cliente.IdPessoa)
                                {
                                    <option value="@cliente.IdPessoa" selected>@cliente.Nome</option>
                                }
                                else
                                {
                                    <option value="@cliente.IdPessoa">@cliente.Nome</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Status</label>
                        <select class="form-select" name="statusFiltro">
                            <option value="">Todos</option>
                            @if (Model.statusFiltro == PedidoStatus.Aberto)
                            {
                                <option value="@PedidoStatus.Aberto" selected>Aberto</option>
                            }
                            else
                            {
                                <option value="@PedidoStatus.Aberto">Aberto</option>
                            }
                            @if (Model.statusFiltro == PedidoStatus.Vencido)
                            {
                                <option value="@PedidoStatus.Vencido" selected>Vencido</option>
                            }
                            else
                            {
                                <option value="@PedidoStatus.Vencido">Vencido</option>
                            }
                            @if (Model.statusFiltro == PedidoStatus.Convertido)
                            {
                                <option value="@PedidoStatus.Convertido" selected>Convertido</option>
                            }
                            else
                            {
                                <option value="@PedidoStatus.Convertido">Convertido</option>
                            }
                            @if (Model.statusFiltro == PedidoStatus.Cancelado)
                            {
                                <option value="@PedidoStatus.Cancelado" selected>Cancelado</option>
                            }
                            else
                            {
                                <option value="@PedidoStatus.Cancelado">Cancelado</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Per&iacute;odo</label>
                        <div class="d-flex gap-2">
                            <input type="date" class="form-control" name="dataInicio" value="@Model.dataInicio?.ToString("yyyy-MM-dd")" />
                            <input type="date" class="form-control" name="dataFim" value="@Model.dataFim?.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" name="somenteVigentes" value="true" checked="@Model.somenteVigentes" />
                            <label class="form-check-label">Somente vigentes</label>
                        </div>
                    </div>
                    <div class="col-12 text-end">
                        <button class="btn btn-outline-primary" type="submit">Filtrar</button>
                        <a class="btn btn-outline-secondary" asp-page="/Pedidos/Index">Limpar</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="card pedido-card">
            <div class="card-header bg-white fw-semibold">Pedidos recentes</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle pedido-table">
                        <thead>
                            <tr>
                                <th>Pedido</th>
                                <th>Cliente</th>
                                <th>Status</th>
                                <th>Validade</th>
                                <th>Fiscal</th>
                                <th class="text-end">Total</th>
                                <th class="text-end">A&ccedil;&otilde;es</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pedido in Model.Contexto.PedidosRecentes.Items)
                            {
                                var statusClass = pedido.Status switch
                                {
                                    "Aberto" => "pedido-status-aberto",
                                    "Vencido" => "pedido-status-vencido",
                                    "Convertido" => "pedido-status-convertido",
                                    _ => "pedido-status-cancelado"
                                };

                                <tr>
                                    <td>
                                        <div class="fw-semibold">#@pedido.IdPedido</div>
                                        <div class="small text-muted">@pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")</div>
                                        <div class="small text-muted">@pedido.QuantidadeItens item(ns)</div>
                                    </td>
                                    <td>
                                        <div>@pedido.NomeCliente</div>
                                        <div class="small text-muted">Pagamento: @(string.IsNullOrWhiteSpace(pedido.TipoPagamento) ? "Livre" : pedido.TipoPagamento)</div>
                                    </td>
                                    <td>
                                        <span class="pedido-status-inline @statusClass">@pedido.Status</span>
                                    </td>
                                    <td>
                                        <div>@pedido.ValidoAte.ToString("dd/MM/yyyy")</div>
                                        @if (pedido.Expirado)
                                        {
                                            <div class="small text-warning">Pedido fora do prazo.</div>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(pedido.StatusFiscal))
                                        {
                                            <span class="badge @(pedido.ClasseStatusFiscal ?? "bg-secondary")">@pedido.StatusFiscal</span>
                                        }
                                        else if (pedido.Status == "Convertido")
                                        {
                                            <span class="badge bg-light text-dark">Venda sem nota</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark">N&atilde;o emitido</span>
                                        }
                                    </td>
                                    <td class="text-end fw-semibold">R$ @pedido.ValorTotal.ToString("N2")</td>
                                    <td class="text-end">
                                        <div class="pedido-actions">
                                            @if (pedido.IdVendaProduto.HasValue)
                                            {
                                                <a class="btn btn-sm btn-outline-dark" href="@Model.ObterUrlNotas(pedido)">Notas</a>
                                            }
                                            @if (pedido.PodeConverter)
                                            {
                                                <form method="post" asp-page-handler="Converter" class="d-inline">
                                                    <input type="hidden" name="idPedido" value="@pedido.IdPedido" />
                                                    <input type="hidden" name="q" value="@Model.q" />
                                                    <input type="hidden" name="idPessoaFiltro" value="@Model.idPessoaFiltro" />
                                                    <input type="hidden" name="statusFiltro" value="@Model.statusFiltro" />
                                                    <input type="hidden" name="dataInicio" value="@Model.dataInicio?.ToString("yyyy-MM-dd")" />
                                                    <input type="hidden" name="dataFim" value="@Model.dataFim?.ToString("yyyy-MM-dd")" />
                                                    <input type="hidden" name="somenteVigentes" value="@Model.somenteVigentes" />
                                                    <input type="hidden" name="p" value="@Model.p" />
                                                    <button class="btn btn-sm btn-outline-primary" type="submit">Converter em venda</button>
                                                </form>
                                                @if (pedido.PossuiServico)
                                                {
                                                    <form method="post" asp-page-handler="Converter" class="d-inline">
                                                        <input type="hidden" name="idPedido" value="@pedido.IdPedido" />
                                                        <input type="hidden" name="emitirNotaFiscalServico" value="true" />
                                                        <input type="hidden" name="q" value="@Model.q" />
                                                        <input type="hidden" name="idPessoaFiltro" value="@Model.idPessoaFiltro" />
                                                        <input type="hidden" name="statusFiltro" value="@Model.statusFiltro" />
                                                        <input type="hidden" name="dataInicio" value="@Model.dataInicio?.ToString("yyyy-MM-dd")" />
                                                        <input type="hidden" name="dataFim" value="@Model.dataFim?.ToString("yyyy-MM-dd")" />
                                                        <input type="hidden" name="somenteVigentes" value="@Model.somenteVigentes" />
                                                        <input type="hidden" name="p" value="@Model.p" />
                                                        <button class="btn btn-sm btn-primary" type="submit">Converter + NFS-e</button>
                                                    </form>
                                                }
                                            }
                                            @if (pedido.Status != "Cancelado" && pedido.Status != "Convertido")
                                            {
                                                <form method="post" asp-page-handler="Cancelar" class="d-inline" onsubmit="return confirm('Confirma o cancelamento deste pedido?');">
                                                    <input type="hidden" name="idPedido" value="@pedido.IdPedido" />
                                                    <input type="hidden" name="q" value="@Model.q" />
                                                    <input type="hidden" name="idPessoaFiltro" value="@Model.idPessoaFiltro" />
                                                    <input type="hidden" name="statusFiltro" value="@Model.statusFiltro" />
                                                    <input type="hidden" name="dataInicio" value="@Model.dataInicio?.ToString("yyyy-MM-dd")" />
                                                    <input type="hidden" name="dataFim" value="@Model.dataFim?.ToString("yyyy-MM-dd")" />
                                                    <input type="hidden" name="somenteVigentes" value="@Model.somenteVigentes" />
                                                    <input type="hidden" name="p" value="@Model.p" />
                                                    <button class="btn btn-sm btn-outline-danger" type="submit">Cancelar</button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Contexto.PedidosRecentes.Items.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">Nenhum pedido encontrado.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.Contexto.PedidosRecentes.TotalPages > 1)
                {
                    <nav class="mt-3">
                        <ul class="pagination justify-content-center">
                            @for (var i = 1; i <= Model.Contexto.PedidosRecentes.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Contexto.PedidosRecentes.PageIndex ? "active" : "")">
                                    <a class="page-link" asp-page="/Pedidos/Index" asp-route-p="@i" asp-route-q="@Model.q" asp-route-idPessoaFiltro="@Model.idPessoaFiltro" asp-route-statusFiltro="@Model.statusFiltro" asp-route-dataInicio="@Model.dataInicio?.ToString("yyyy-MM-dd")" asp-route-dataFim="@Model.dataFim?.ToString("yyyy-MM-dd")" asp-route-somenteVigentes="@Model.somenteVigentes">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const produtos = @Html.Raw(Model.ProdutosJson);
        const servicos = @Html.Raw(Model.ServicosJson);
        let carrinho = [];

        const clienteSelect = document.getElementById('clienteSelect');
        const tipoItemSelect = document.getElementById('tipoItemSelect');
        const catalogoSelect = document.getElementById('catalogoSelect');
        const quantidadeInput = document.getElementById('quantidadeInput');
        const valorUnitarioInput = document.getElementById('valorUnitarioInput');
        const observacoesInput = document.getElementById('observacoesInput');
        const descontoInput = document.getElementById('descontoInput');
        const acrescimoInput = document.getElementById('acrescimoInput');
        const meioPagamentoSelect = document.getElementById('meioPagamentoSelect');
        const payloadJsonInput = document.getElementById('payloadJson');
        const addItemBtn = document.getElementById('addItemBtn');
        const carrinhoTableBody = document.querySelector('#carrinhoTable tbody');
        const totalPedidoLabel = document.getElementById('totalPedidoLabel');
        const resumoPedidoItems = document.getElementById('resumoPedidoItems');
        const pedidoForm = document.getElementById('pedidoForm');

        function moeda(valor) {
            return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(valor || 0);
        }

        function getCatalogoAtual() {
            return tipoItemSelect.value === 'Servico' ? servicos : produtos;
        }

        function preencherCatalogo() {
            const catalogo = getCatalogoAtual();
            catalogoSelect.innerHTML = '';

            if (!catalogo.length) {
                const option = document.createElement('option');
                option.value = '';
                option.textContent = 'Nenhum item disponivel';
                catalogoSelect.appendChild(option);
                valorUnitarioInput.value = '0';
                return;
            }

            for (const item of catalogo) {
                const option = document.createElement('option');
                option.value = item.id;
                option.textContent = item.tipo === 'Produto'
                    ? `${item.nome} | ${moeda(item.valor)} | estoque: ${Number(item.estoqueAtual || 0).toFixed(3)}`
                    : `${item.nome} | ${moeda(item.valor)}`;
                catalogoSelect.appendChild(option);
            }

            atualizarValorDoCatalogo();
        }

        function atualizarValorDoCatalogo() {
            const catalogo = getCatalogoAtual();
            const selected = catalogo.find(item => String(item.id) === String(catalogoSelect.value)) || catalogo[0];
            valorUnitarioInput.value = selected ? Number(selected.valor || 0).toFixed(2) : '0';
        }

        function calcularResumo() {
            const subtotal = carrinho.reduce((acc, item) => acc + item.valorTotal, 0);
            const desconto = Number(descontoInput.value || 0);
            const acrescimo = Number(acrescimoInput.value || 0);
            const total = subtotal - desconto + acrescimo;
            totalPedidoLabel.textContent = moeda(total);
            resumoPedidoItems.textContent = `${carrinho.length} item(ns) no pedido`;
        }

        function renderCarrinho() {
            if (!carrinho.length) {
                carrinhoTableBody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">Nenhum item adicionado.</td></tr>';
                calcularResumo();
                return;
            }

            carrinhoTableBody.innerHTML = '';
            carrinho.forEach((item, index) => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${item.tipoItem === 'Servico' ? 'Serviço' : 'Produto'}</td>
                    <td>
                        <div class="fw-semibold">${item.descricao}</div>
                        <div class="small text-muted">${item.tipoItem === 'Produto' ? 'Item de estoque' : 'Item de serviço'}</div>
                    </td>
                    <td class="text-end">${Number(item.quantidade).toFixed(3)}</td>
                    <td class="text-end">${moeda(item.valorUnitario)}</td>
                    <td class="text-end">${moeda(item.valorTotal)}</td>
                    <td class="text-end"><button type="button" class="btn btn-sm btn-outline-danger" data-index="${index}">Remover</button></td>
                `;
                carrinhoTableBody.appendChild(tr);
            });

            carrinhoTableBody.querySelectorAll('button[data-index]').forEach(button => {
                button.addEventListener('click', () => {
                    carrinho.splice(Number(button.dataset.index), 1);
                    renderCarrinho();
                });
            });

            calcularResumo();
        }

        addItemBtn.addEventListener('click', () => {
            const catalogo = getCatalogoAtual();
            const selected = catalogo.find(item => String(item.id) === String(catalogoSelect.value));
            if (!selected) {
                alert('Selecione um item valido.');
                return;
            }

            const quantidade = Number(quantidadeInput.value || 0);
            const valorUnitario = Number(valorUnitarioInput.value || 0);

            if (quantidade <= 0) {
                alert('Informe uma quantidade maior que zero.');
                return;
            }

            if (valorUnitario < 0) {
                alert('Informe um valor unitario valido.');
                return;
            }

            carrinho.push({
                tipoItem: tipoItemSelect.value,
                idProduto: tipoItemSelect.value === 'Produto' ? selected.id : null,
                idServico: tipoItemSelect.value === 'Servico' ? selected.id : null,
                descricao: selected.nome,
                quantidade,
                valorUnitario,
                valorTotal: Number((quantidade * valorUnitario).toFixed(2))
            });

            renderCarrinho();
        });

        pedidoForm.addEventListener('submit', (event) => {
            if (!clienteSelect.value) {
                event.preventDefault();
                alert('Selecione um cliente para registrar o pedido.');
                return;
            }

            if (!carrinho.length) {
                event.preventDefault();
                alert('Adicione ao menos um item ao pedido.');
                return;
            }

            payloadJsonInput.value = JSON.stringify({
                idPessoa: clienteSelect.value ? Number(clienteSelect.value) : null,
                idMeioPagamento: meioPagamentoSelect.value ? Number(meioPagamentoSelect.value) : null,
                tipoPagamento: meioPagamentoSelect.selectedOptions[0]?.dataset?.nome || null,
                desconto: Number(descontoInput.value || 0),
                acrescimo: Number(acrescimoInput.value || 0),
                observacoes: observacoesInput.value || null,
                itens: carrinho.map(item => ({
                    tipoItem: item.tipoItem,
                    idProduto: item.idProduto,
                    idServico: item.idServico,
                    quantidade: item.quantidade,
                    valorUnitario: item.valorUnitario
                }))
            });
        });

        tipoItemSelect.addEventListener('change', preencherCatalogo);
        catalogoSelect.addEventListener('change', atualizarValorDoCatalogo);
        descontoInput.addEventListener('input', calcularResumo);
        acrescimoInput.addEventListener('input', calcularResumo);

        preencherCatalogo();
        renderCarrinho();
    </script>
}
