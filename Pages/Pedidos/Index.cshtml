@page
@model CorteCor.Pages.Pedidos.IndexModel
@using CorteCor.Models
@{
    ViewData["Title"] = "Pedidos";
}

@section Styles {
    <style>
        .pedido-card {
            border: 0;
            border-radius: 18px;
            box-shadow: 0 14px 35px rgba(15, 23, 42, 0.08);
        }

        .pedido-hero {
            background: linear-gradient(135deg, #fff7ed 0%, #ffffff 55%, #eef6ff 100%);
            border-radius: 22px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .pedido-kpi {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 1rem 1.1rem;
            height: 100%;
        }

        .pedido-kpi-label {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #6b7280;
            margin-bottom: 0.35rem;
        }

        .pedido-kpi-value {
            font-size: 1.6rem;
            font-weight: 700;
            color: #111827;
        }

        .pedido-actions {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 0.5rem;
        }

        .pedido-actions .btn {
            min-width: 140px;
        }

        .pedido-status-inline {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.35rem 0.65rem;
            border-radius: 999px;
            font-size: 0.82rem;
            font-weight: 600;
        }

        .pedido-status-aberto { background: #dcfce7; color: #166534; }
        .pedido-status-vencido { background: #fef3c7; color: #92400e; }
        .pedido-status-convertido { background: #dbeafe; color: #1d4ed8; }
        .pedido-status-cancelado { background: #e5e7eb; color: #374151; }

        .pedido-table td {
            vertical-align: top;
        }

        .pedido-filtros-grid {
            display: grid;
            grid-template-columns: minmax(260px, 2fr) minmax(180px, 1fr) minmax(180px, 1fr);
            gap: 1rem;
        }

        .pedido-filtro-periodo {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.5rem;
        }

        .pedido-filtros-rodape {
            display: flex;
            justify-content: space-between;
            align-items: end;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .pedido-filtros-botoes {
            display: flex;
            justify-content: flex-end;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        @@media (max-width: 991.98px) {
            .pedido-filtros-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .pedido-actions .btn {
                min-width: 100%;
            }
        }

        @@media (max-width: 767.98px) {
            .pedido-filtros-grid,
            .pedido-filtro-periodo {
                grid-template-columns: 1fr;
            }

            .pedido-filtros-rodape,
            .pedido-filtros-botoes {
                flex-direction: column;
                align-items: stretch;
            }

            .pedido-filtros-botoes .btn {
                width: 100%;
            }
        }
    </style>
}

<div class="pedido-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h2 class="mb-1">Pedidos de Produtos e Serviços</h2>
            <div class="text-muted">Registre propostas e pedidos com validade, acompanhe o relacionamento no CRM e converta em venda quando o cliente fechar.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" asp-page="/Pedidos/Novo">Novo pedido</a>
            <a class="btn btn-dark" asp-page="/Vendas/Index">Ir para Vendas</a>
            <a class="btn btn-secondary" asp-page="/Estoque/Index">Controle de Estoque</a>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-@(Model.FlashType ?? "info")">@Model.FlashMessage</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="pedido-kpi">
            <div class="pedido-kpi-label">Pedidos listados</div>
            <div class="pedido-kpi-value">@Model.PainelResumo.PedidosListados</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pedido-kpi">
            <div class="pedido-kpi-label">Pedidos vigentes</div>
            <div class="pedido-kpi-value">@Model.PainelResumo.PedidosVigentes</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pedido-kpi">
            <div class="pedido-kpi-label">Vencendo hoje</div>
            <div class="pedido-kpi-value">@Model.PainelResumo.PedidosVencendoHoje</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pedido-kpi">
            <div class="pedido-kpi-label">Valor na listagem</div>
            <div class="pedido-kpi-value">R$ @Model.PainelResumo.ValorListagem.ToString("N2")</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12">
        <div class="card pedido-card mb-4">
            <div class="card-header bg-white fw-semibold">Filtros de pedidos</div>
            <div class="card-body">
                <form method="get" class="d-flex flex-column gap-3">
                    <div class="pedido-filtros-grid">
                        <div>
                            <label class="form-label">Pesquisa</label>
                            <input class="form-control" name="q" value="@Model.q" placeholder="Cliente, pagamento ou pedido" />
                        </div>
                        <div>
                            <label class="form-label">Cliente</label>
                            <select class="form-select" name="idPessoaFiltro">
                                <option value="">Todos</option>
                                @foreach (var cliente in Model.Contexto.Clientes)
                                {
                                    if (Model.idPessoaFiltro == cliente.IdPessoa)
                                    {
                                        <option value="@cliente.IdPessoa" selected>@cliente.Nome</option>
                                    }
                                    else
                                    {
                                        <option value="@cliente.IdPessoa">@cliente.Nome</option>
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <label class="form-label">Status</label>
                            <select class="form-select" name="statusFiltro">
                                <option value="">Todos</option>
                                @if (Model.statusFiltro == PedidoStatus.Aberto)
                                {
                                    <option value="@PedidoStatus.Aberto" selected>Aberto</option>
                                }
                                else
                                {
                                    <option value="@PedidoStatus.Aberto">Aberto</option>
                                }
                                @if (Model.statusFiltro == PedidoStatus.Vencido)
                                {
                                    <option value="@PedidoStatus.Vencido" selected>Vencido</option>
                                }
                                else
                                {
                                    <option value="@PedidoStatus.Vencido">Vencido</option>
                                }
                                @if (Model.statusFiltro == PedidoStatus.Convertido)
                                {
                                    <option value="@PedidoStatus.Convertido" selected>Convertido</option>
                                }
                                else
                                {
                                    <option value="@PedidoStatus.Convertido">Convertido</option>
                                }
                                @if (Model.statusFiltro == PedidoStatus.Cancelado)
                                {
                                    <option value="@PedidoStatus.Cancelado" selected>Cancelado</option>
                                }
                                else
                                {
                                    <option value="@PedidoStatus.Cancelado">Cancelado</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="pedido-filtros-rodape">
                        <div>
                            <label class="form-label">Período</label>
                            <div class="pedido-filtro-periodo">
                                <input type="date" class="form-control" name="dataInicio" value="@Model.dataInicio?.ToString("yyyy-MM-dd")" />
                                <input type="date" class="form-control" name="dataFim" value="@Model.dataFim?.ToString("yyyy-MM-dd")" />
                            </div>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="somenteVigentes" value="true" checked="@Model.somenteVigentes" />
                            <label class="form-check-label">Somente vigentes</label>
                        </div>
                        <div class="pedido-filtros-botoes">
                            <button class="btn btn-primary" type="submit">Filtrar</button>
                            <a class="btn btn-secondary" asp-page="/Pedidos/Index">Limpar</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="card pedido-card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span class="fw-semibold">Pedidos recentes</span>
                <a class="btn btn-primary btn-sm" asp-page="/Pedidos/Novo">Novo pedido</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle pedido-table">
                        <thead>
                            <tr>
                                <th>Pedido</th>
                                <th>Cliente</th>
                                <th>Status</th>
                                <th>Validade</th>
                                <th>Fiscal</th>
                                <th class="text-end">Total</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pedido in Model.Contexto.PedidosRecentes.Items)
                            {
                                var statusClass = pedido.Status switch
                                {
                                    "Aberto" => "pedido-status-aberto",
                                    "Vencido" => "pedido-status-vencido",
                                    "Convertido" => "pedido-status-convertido",
                                    _ => "pedido-status-cancelado"
                                };

                                <tr>
                                    <td>
                                        <div class="fw-semibold">#@pedido.IdPedido</div>
                                        <div class="small text-muted">@pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")</div>
                                        <div class="small text-muted">@pedido.QuantidadeItens item(ns)</div>
                                    </td>
                                    <td>
                                        <div>@pedido.NomeCliente</div>
                                        <div class="small text-muted">Pagamento: @(string.IsNullOrWhiteSpace(pedido.TipoPagamento) ? "Livre" : pedido.TipoPagamento)</div>
                                    </td>
                                    <td>
                                        <span class="pedido-status-inline @statusClass">@pedido.Status</span>
                                    </td>
                                    <td>
                                        <div>@pedido.ValidoAte.ToString("dd/MM/yyyy")</div>
                                        @if (pedido.Expirado)
                                        {
                                            <div class="small text-warning">Pedido fora do prazo.</div>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(pedido.StatusFiscal))
                                        {
                                            <span class="badge @(pedido.ClasseStatusFiscal ?? "bg-secondary")">@pedido.StatusFiscal</span>
                                        }
                                        else if (pedido.Status == "Convertido")
                                        {
                                            <span class="badge bg-light text-dark">Venda sem nota</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark">Não emitido</span>
                                        }
                                    </td>
                                    <td class="text-end fw-semibold">R$ @pedido.ValorTotal.ToString("N2")</td>
                                    <td class="text-end">
                                        <div class="pedido-actions">
                                            @if (pedido.IdVendaProduto.HasValue)
                                            {
                                                <a class="btn btn-sm btn-dark" href="@Model.ObterUrlNotas(pedido)">Notas</a>
                                            }
                                            @if (pedido.PodeConverter)
                                            {
                                                <form method="post" asp-page-handler="Converter" class="d-inline">
                                                    <input type="hidden" name="idPedido" value="@pedido.IdPedido" />
                                                    <input type="hidden" name="q" value="@Model.q" />
                                                    <input type="hidden" name="idPessoaFiltro" value="@Model.idPessoaFiltro" />
                                                    <input type="hidden" name="statusFiltro" value="@Model.statusFiltro" />
                                                    <input type="hidden" name="dataInicio" value="@Model.dataInicio?.ToString("yyyy-MM-dd")" />
                                                    <input type="hidden" name="dataFim" value="@Model.dataFim?.ToString("yyyy-MM-dd")" />
                                                    <input type="hidden" name="somenteVigentes" value="@Model.somenteVigentes" />
                                                    <input type="hidden" name="p" value="@Model.p" />
                                                    <button class="btn btn-sm btn-primary" type="submit">Converter em venda</button>
                                                </form>
                                                @if (pedido.PossuiServico)
                                                {
                                                    <form method="post" asp-page-handler="Converter" class="d-inline">
                                                        <input type="hidden" name="idPedido" value="@pedido.IdPedido" />
                                                        <input type="hidden" name="emitirNotaFiscalServico" value="true" />
                                                        <input type="hidden" name="q" value="@Model.q" />
                                                        <input type="hidden" name="idPessoaFiltro" value="@Model.idPessoaFiltro" />
                                                        <input type="hidden" name="statusFiltro" value="@Model.statusFiltro" />
                                                        <input type="hidden" name="dataInicio" value="@Model.dataInicio?.ToString("yyyy-MM-dd")" />
                                                        <input type="hidden" name="dataFim" value="@Model.dataFim?.ToString("yyyy-MM-dd")" />
                                                        <input type="hidden" name="somenteVigentes" value="@Model.somenteVigentes" />
                                                        <input type="hidden" name="p" value="@Model.p" />
                                                        <button class="btn btn-sm btn-primary" type="submit">Converter + NFS-e</button>
                                                    </form>
                                                }
                                            }
                                            @if (pedido.Status != "Cancelado" && pedido.Status != "Convertido")
                                            {
                                                <form method="post" asp-page-handler="Cancelar" class="d-inline" onsubmit="return confirm('Confirma o cancelamento deste pedido?');">
                                                    <input type="hidden" name="idPedido" value="@pedido.IdPedido" />
                                                    <input type="hidden" name="q" value="@Model.q" />
                                                    <input type="hidden" name="idPessoaFiltro" value="@Model.idPessoaFiltro" />
                                                    <input type="hidden" name="statusFiltro" value="@Model.statusFiltro" />
                                                    <input type="hidden" name="dataInicio" value="@Model.dataInicio?.ToString("yyyy-MM-dd")" />
                                                    <input type="hidden" name="dataFim" value="@Model.dataFim?.ToString("yyyy-MM-dd")" />
                                                    <input type="hidden" name="somenteVigentes" value="@Model.somenteVigentes" />
                                                    <input type="hidden" name="p" value="@Model.p" />
                                                    <button class="btn btn-sm btn-danger" type="submit">Cancelar</button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Contexto.PedidosRecentes.Items.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">Nenhum pedido encontrado.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.Contexto.PedidosRecentes.TotalPages > 1)
                {
                    <nav class="mt-3">
                        <ul class="pagination justify-content-center">
                            @for (var i = 1; i <= Model.Contexto.PedidosRecentes.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Contexto.PedidosRecentes.PageIndex ? "active" : "")">
                                    <a class="page-link" asp-page="/Pedidos/Index" asp-route-p="@i" asp-route-q="@Model.q" asp-route-idPessoaFiltro="@Model.idPessoaFiltro" asp-route-statusFiltro="@Model.statusFiltro" asp-route-dataInicio="@Model.dataInicio?.ToString("yyyy-MM-dd")" asp-route-dataFim="@Model.dataFim?.ToString("yyyy-MM-dd")" asp-route-somenteVigentes="@Model.somenteVigentes">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>
