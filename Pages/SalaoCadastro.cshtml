@page
@model CorteCor.Pages.SalaoCadastroModel
@{
    ViewData["Title"] = "Cadastro de Salões";
}

<div class="container">
    <h4>@Model.ButtonText Salão</h4>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert alert-success">
            @Model.Mensagem
        </div>
    }

    <form method="post">
        <input type="hidden" name="id" value="@Model.Salao?.IdSalao">

        <div class="form-group">
            <label for="nome">Nome do Salão</label>
            <input type="text" id="nome" name="nome" class="form-control" required value="@Model.Salao?.Nome">
        </div>

        <div class="form-group">
            <label for="responsavel">Responsável</label>
            <input type="text" id="responsavel" name="responsavel" class="form-control" required value="@Model.Salao?.Responsavel">
        </div>

        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" class="form-control" required value="@Model.Salao?.Email">
        </div>

        <div class="form-group">
            <label for="telefone">Telefone</label>
            <input type="text" id="telefone" name="telefone" class="form-control" required value="@Model.Salao?.Telefone">
        </div>

        <div class="form-group">
            <label for="endereco">Endereço</label>
            <input type="text" id="endereco" name="endereco" class="form-control" value="@Model.Salao?.Endereco">
        </div>

        <div class="form-group">
            <label for="cnpj">CNPJ</label>
            <input type="text" id="cnpj" name="cnpj" class="form-control" value="@Model.Salao?.CNPJ">
        </div>

        <div class="form-group">
            <label for="observacao">Observação</label>
            <textarea id="observacao" name="observacao" class="form-control">@Model.Salao?.Observacao</textarea>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label for="limiteEnvioEmail">Limite Envio E-mail</label>
                    <input type="number" id="limiteEnvioEmail" name="limiteEnvioEmail" class="form-control" value="@(Model.Salao?.LimiteEnvioEmail ?? 0)" min="0">
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label for="limiteEnvioSMS">Limite Envio SMS</label>
                    <input type="number" id="limiteEnvioSMS" name="limiteEnvioSMS" class="form-control" value="@(Model.Salao?.LimiteEnvioSMS ?? 0)" min="0">
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label for="limiteEnvioWhatsapp">Limite Envio Whatsapp</label>
                    <input type="number" id="limiteEnvioWhatsapp" name="limiteEnvioWhatsapp" class="form-control" value="@(Model.Salao?.LimiteEnvioWhatsapp ?? 0)" min="0">
                </div>
            </div>
        </div>

        <div class="form-group">
            <label for="dataCadastro">Data de Cadastro</label>
            <input type="date" id="dataCadastro" name="dataCadastro" class="form-control" required
                   value="@(Model.Salao?.DataCadastro.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))">
        </div>

        <button type="submit" class="btn btn-primary">@Model.ButtonText</button>
    </form>
</div>

<script>
    $(document).ready(function () {
        $("#telefone").inputmask("(99) 99999-9999"); // Máscara para telefone
        $("#cnpj").inputmask("99.999.999/9999-99");   // Máscara para CNPJ
    });
</script>
