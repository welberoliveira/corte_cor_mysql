@page
@model CorteCor.Pages.NotaFiscalEmitirModel
@{
    ViewData["Title"] = "Emitir NFS-e Manual (Padrão Nacional)";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12 col-xl-8 offset-xl-2">
            
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show text-white" role="alert">
                    <span class="alert-icon"><i class="ni ni-fat-remove"></i></span>
                    <span class="alert-text"><strong>Erro!</strong> @TempData["ErrorMessage"]</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <div class="mt-2 text-sm text-white">
                        <a href="/SistemaLogLista" class="text-white text-decoration-underline">Consulte os Logs do Sistema para ver o XML da Sefaz detalhado.</a>
                    </div>
                </div>
            }

            <div class="card">
                <div class="card-header pb-0 border-bottom">
                    <div class="d-flex align-items-center">
                        <p class="mb-0 font-weight-bolder">Emissão Avulsa de NFS-e (Portal de Gestão Nacional)</p>
                    </div>
                </div>
                <div class="card-body">
                    <p class="text-uppercase text-sm">Dados do Tomador (Cliente)</p>
                    <form method="post">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Input.CpfCnpjDestinatario" class="form-control-label"></label>
                                    <input asp-for="Input.CpfCnpjDestinatario" class="form-control" type="text" placeholder="Apenas números">
                                    <span asp-validation-for="Input.CpfCnpjDestinatario" class="text-danger text-xs"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Input.NomeRazaoSocial" class="form-control-label"></label>
                                    <input asp-for="Input.NomeRazaoSocial" class="form-control" type="text" placeholder="Nome ou Consumidor Final">
                                    <span asp-validation-for="Input.NomeRazaoSocial" class="text-danger text-xs"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="horizontal dark">
                        <p class="text-uppercase text-sm">Dados do Serviço Prestado</p>
                        
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="Input.ValorServico" class="form-control-label"></label>
                                    <div class="input-group">
                                        <span class="input-group-text">R$</span>
                                        <input asp-for="Input.ValorServico" class="form-control" type="number" step="0.01" min="0.01" value="0.00">
                                    </div>
                                    <span asp-validation-for="Input.ValorServico" class="text-danger text-xs"></span>
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="form-group">
                                    <label asp-for="Input.CodigoTributacaoNacional" class="form-control-label"></label>
                                    <input asp-for="Input.CodigoTributacaoNacional" class="form-control" type="text" placeholder="Ex: 06.01.01">
                                    <span class="text-xs text-muted">A tabela LC 116/03 mapeada no Padrão Nacional.</span>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-2">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label asp-for="Input.DescricaoServico" class="form-control-label"></label>
                                    <textarea asp-for="Input.DescricaoServico" class="form-control" rows="3" placeholder="Descreva os serviços prestados..."></textarea>
                                    <span asp-validation-for="Input.DescricaoServico" class="text-danger text-xs"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-md-12 text-end">
                                <a asp-page="/NotaFiscalLogLista" class="btn btn-secondary me-2">Cancelar e Voltar</a>
                                <button type="submit" class="btn bg-gradient-success">
                                    <i class="fas fa-file-invoice me-2"></i>Emitir NFS-e (Nacional)
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
