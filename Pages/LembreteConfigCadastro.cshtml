@page
@model CorteCor.Pages.LembreteConfigCadastroModel
@{
    ViewData["Title"] = "Cadastro de Regra de Lembrete";
}

<style>
    .cc-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        padding: 24px;
        border: 1px solid #f3f4f6;
    }
    .tipo-selector {
        display: flex;
        gap: 16px;
        margin-bottom: 20px;
    }
    .tipo-option {
        flex: 1;
        position: relative;
    }
    .tipo-option input {
        position: absolute;
        opacity: 0;
        cursor: pointer;
        height: 0;
        width: 0;
    }
    .tipo-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 20px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        background: #f9fafb;
    }
    .tipo-card i {
        font-size: 24px;
        margin-bottom: 8px;
        color: #6b7280;
    }
    .tipo-card span {
        font-weight: 600;
        color: #4b5563;
    }
    .tipo-option input:checked + .tipo-card {
        border-color: #3b82f6;
        background-color: #eff6ff;
    }
    .tipo-option input:checked + .tipo-card i {
        color: #3b82f6;
    }
    .tipo-option input:checked + .tipo-card span {
        color: #1e40af;
    }
    .tipo-card:hover {
        border-color: #d1d5db;
        transform: translateY(-2px);
    }
    
    /* Custom Toggle Switch */
    .switch-wrapper {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 28px;
    }
    .switch-wrapper input { 
        opacity: 0;
        width: 0;
        height: 0;
    }
    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        -webkit-transition: .4s;
        transition: .4s;
        border-radius: 34px;
    }
    .slider:before {
        position: absolute;
        content: "";
        height: 20px;
        width: 20px;
        left: 4px;
        bottom: 4px;
        background-color: white;
        -webkit-transition: .4s;
        transition: .4s;
        border-radius: 50%;
    }
    input:checked + .slider {
        background-color: #10b981;
    }
    input:focus + .slider {
        box-shadow: 0 0 1px #10b981;
    }
    input:checked + .slider:before {
        -webkit-transform: translateX(22px);
        -ms-transform: translateX(22px);
        transform: translateX(22px);
    }
    .toggle-text {
        font-weight: 600;
        color: #374151;
        user-select: none;
        margin-left: 10px;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="cc-card">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mr-3" style="width: 40px; height: 40px;">
                        <i class="fas fa-bell"></i>
                    </div>
                    <h4 class="mb-0">@(Model.IsViewMode ? "Visualização da Regra" : "Configuração de Lembrete")</h4>
                </div>

                @if (!string.IsNullOrEmpty(Model.Mensagem))
                {
                    <div class="alert alert-info alert-dismissible fade show" role="alert">
                        @Model.Mensagem
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                }

                <form method="post">
                    <input type="hidden" asp-for="Config.IdConfig" />
                    <input type="hidden" asp-for="Config.IdSalao" />

                    <fieldset disabled="@(Model.IsViewMode ? "disabled" : null)">

                    <div class="row">
                        <div class="col-md-7">
                            <div class="form-group">
                                <label class="font-weight-bold">Antecedência</label>
                                <div class="input-group">
                                    <input asp-for="Config.AntecedenciaValor" class="form-control" type="number" required min="1" step="1" placeholder="Ex: 30" />
                                    <div class="input-group-append" style="width: 150px;">
                                        <select asp-for="Config.AntecedenciaUnidade" class="form-control" asp-items="Model.UnidadeOptions"></select>
                                    </div>
                                </div>
                                <span asp-validation-for="Config.AntecedenciaValor" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="font-weight-bold">Meio de Envio</label>
                        <div class="tipo-selector">
                            <label class="tipo-option">
                                <input type="radio" asp-for="Config.TipoLembrete" value="Email" id="tipoEmail" onchange="toggleModelo()">
                                <div class="tipo-card">
                                    <i class="fas fa-envelope"></i>
                                    <span>E-mail</span>
                                </div>
                            </label>
                            <label class="tipo-option">
                                <input type="radio" asp-for="Config.TipoLembrete" value="SMS" id="tipoSMS" onchange="toggleModelo()">
                                <div class="tipo-card">
                                    <i class="fas fa-sms"></i>
                                    <span>SMS</span>
                                </div>
                            </label>
                        </div>
                    </div>

                    <div id="divModeloEmail" class="form-group transition-all">
                        <label asp-for="Config.IdModeloEmail" class="font-weight-bold">Modelo de E-mail</label>
                        <select asp-for="Config.IdModeloEmail" class="form-control custom-select" asp-items="Model.ModeloEmailOptions">
                            <option value="">-- Selecione um Modelo --</option>
                        </select>
                    </div>

                    <div id="divModeloSMS" class="form-group transition-all" style="display:none;">
                        <label asp-for="Config.IdModeloSMS" class="font-weight-bold">Modelo de SMS</label>
                        <select asp-for="Config.IdModeloSMS" class="form-control custom-select" asp-items="Model.ModeloSmsOptions">
                            <option value="">-- Selecione um Modelo --</option>
                        </select>
                    </div>

                    <hr class="my-4">

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Config.DataInicio" class="font-weight-bold">Data de Início</label>
                                <input asp-for="Config.DataInicio" class="form-control" type="date" required />
                                <small class="text-muted">A validade da regra no sistema.</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Config.DataFim" class="font-weight-bold">Data de Fim (Opcional)</label>
                                <input asp-for="Config.DataFim" class="form-control" type="date" />
                                <small class="text-muted">Vazio para regra contínua.</small>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4 p-3 bg-light rounded border" style="opacity: 0.8; cursor: not-allowed;">
                        <label class="switch-wrapper mb-0">
                            <input type="checkbox" asp-for="Config.Ativo" disabled checked>
                            <span class="slider round" style="cursor: not-allowed;"></span>
                        </label>
                        <input type="hidden" asp-for="Config.Ativo" value="true" />
                        <span class="toggle-text">Regra Ativa</span>
                        <small class="text-muted ml-3">(Esta regra permanecerá ativa)</small>
                    </div>
                    </fieldset>

                    <div class="d-flex justify-content-between">
                        <a asp-page="/LembreteConfigLista" class="btn btn-secondary px-4">
                            <i class="fas fa-arrow-left mr-2"></i> Voltar
                        </a>
                        @if (!Model.IsViewMode)
                        {
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">
                                <i class="fas fa-save mr-2"></i> Salvar Regra
                            </button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleModelo() {
            var isEmail = document.getElementById('tipoEmail').checked;
            var divEmail = document.getElementById('divModeloEmail');
            var divSMS = document.getElementById('divModeloSMS');

            if (isEmail) {
                divEmail.style.display = 'block';
                divSMS.style.display = 'none';
            } else {
                divEmail.style.display = 'none';
                divSMS.style.display = 'block';
            }
        }

        // Init
        document.addEventListener('DOMContentLoaded', function() {
            toggleModelo();
        });
    </script>
}

