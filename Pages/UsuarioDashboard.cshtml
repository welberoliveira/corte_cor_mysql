@page
@model UsuarioDashboardModel

<style>
    .tdStatusPendente {
        color: red;
    }

    .tdStatusAprovado {
        color: green;
    }
</style>

<style>
    .charts-container {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
    }

    .chart {
        flex: 1 1 300px;
        max-width: 400px;
        height: 250px;
        margin: 10px;
    }
</style>

<div class="container mt-1">
    @{
        string saudacao;
        int horaAtual = DateTime.Now.Hour;

        if (horaAtual >= 5 && horaAtual < 12)
        {
            saudacao = "Bom dia";
        }
        else if (horaAtual >= 12 && horaAtual < 18)
        {
            saudacao = "Boa tarde";
        }
        else
        {
            saudacao = "Boa noite";
        }
    }

    <h4 class="">@Model.NomeSalao</h4>
    <h5 class="">@saudacao, @Model.NomeUsuario!</h5>
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger text-center">
            @Model.ErrorMessage
        </div>
    }
