@page
@model CorteCor.Pages.FuncionarioCadastroModel
@{
    ViewData["Title"] = "Cadastro de Funcionários";
}

<div class="container">
    <h4>@Model.ButtonText Funcionário</h4>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert alert-success">
            @Model.Mensagem
        </div>
    }

    <form method="post">
        <input type="hidden" name="id" value="@Model.Funcionario?.IdFuncionario">

        <div class="form-group">
            <label for="nome">Nome</label>
            <input type="text" id="nome" name="nome" class="form-control" required value="@Model.Funcionario?.Nome">
        </div>

        <hr />

        <h5>Disponibilidade</h5>

        <!-- SEG -->
        <div class="border rounded p-3 mb-3">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="seg" name="seg" value="true" @(Model.Funcionario?.seg == true ? "checked" : "")>
                <label class="form-check-label" for="seg">Segunda-feira</label>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label for="seg_ini">Início</label>
                    <input type="time" id="seg_ini" name="seg_ini" class="form-control"
                           value="@(Model.Funcionario?.seg_ini?.ToString(@"hh\:mm") ?? "")">
                </div>
                <div class="col-md-6">
                    <label for="seg_fim">Fim</label>
                    <input type="time" id="seg_fim" name="seg_fim" class="form-control"
                           value="@(Model.Funcionario?.seg_fim?.ToString(@"hh\:mm") ?? "")">
                </div>
            </div>
        </div>

        <!-- TER -->
        <div class="border rounded p-3 mb-3">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="ter" name="ter" value="true" @(Model.Funcionario?.ter == true ? "checked" : "")>
                <label class="form-check-label" for="ter">Terça-feira</label>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label for="ter_ini">Início</label>
                    <input type="time" id="ter_ini" name="ter_ini" class="form-control"
                           value="@(Model.Funcionario?.ter_ini?.ToString(@"hh\:mm") ?? "")">
                </div>
                <div class="col-md-6">
                    <label for="ter_fim">Fim</label>
                    <input type="time" id="ter_fim" name="ter_fim" class="form-control"
                           value="@(Model.Funcionario?.ter_fim?.ToString(@"hh\:mm") ?? "")">
                </div>
            </div>
        </div>

        <!-- QUA -->
        <div class="border rounded p-3 mb-3">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="qua" name="qua" value="true" @(Model.Funcionario?.qua == true ? "checked" : "")>
                <label class="form-check-label" for="qua">Quarta-feira</label>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label for="qua_ini">Início</label>
                    <input type="time" id="qua_ini" name="qua_ini" class="form-control"
                           value="@(Model.Funcionario?.qua_ini?.ToString(@"hh\:mm") ?? "")">
                </div>
                <div class="col-md-6">
                    <label for="qua_fim">Fim</label>
                    <input type="time" id="qua_fim" name="qua_fim" class="form-control"
                           value="@(Model.Funcionario?.qua_fim?.ToString(@"hh\:mm") ?? "")">
                </div>
            </div>
        </div>

        <!-- QUI -->
        <div class="border rounded p-3 mb-3">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="qui" name="qui" value="true" @(Model.Funcionario?.qui == true ? "checked" : "")>
                <label class="form-check-label" for="qui">Quinta-feira</label>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label for="qui_ini">Início</label>
                    <input type="time" id="qui_ini" name="qui_ini" class="form-control"
                           value="@(Model.Funcionario?.qui_ini?.ToString(@"hh\:mm") ?? "")">
                </div>
                <div class="col-md-6">
                    <label for="qui_fim">Fim</label>
                    <input type="time" id="qui_fim" name="qui_fim" class="form-control"
                           value="@(Model.Funcionario?.qui_fim?.ToString(@"hh\:mm") ?? "")">
                </div>
            </div>
        </div>

        <!-- SEX -->
        <div class="border rounded p-3 mb-3">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="sex" name="sex" value="true" @(Model.Funcionario?.sex == true ? "checked" : "")>
                <label class="form-check-label" for="sex">Sexta-feira</label>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label for="sex_ini">Início</label>
                    <input type="time" id="sex_ini" name="sex_ini" class="form-control"
                           value="@(Model.Funcionario?.sex_ini?.ToString(@"hh\:mm") ?? "")">
                </div>
                <div class="col-md-6">
                    <label for="sex_fim">Fim</label>
                    <input type="time" id="sex_fim" name="sex_fim" class="form-control"
                           value="@(Model.Funcionario?.sex_fim?.ToString(@"hh\:mm") ?? "")">
                </div>
            </div>
        </div>

        <!-- SAB -->
        <div class="border rounded p-3 mb-3">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="sab" name="sab" value="true" @(Model.Funcionario?.sab == true ? "checked" : "")>
                <label class="form-check-label" for="sab">Sábado</label>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label for="sab_ini">Início</label>
                    <input type="time" id="sab_ini" name="sab_ini" class="form-control"
                           value="@(Model.Funcionario?.sab_ini?.ToString(@"hh\:mm") ?? "")">
                </div>
                <div class="col-md-6">
                    <label for="sab_fim">Fim</label>
                    <input type="time" id="sab_fim" name="sab_fim" class="form-control"
                           value="@(Model.Funcionario?.sab_fim?.ToString(@"hh\:mm") ?? "")">
                </div>
            </div>
        </div>

        <!-- DOM -->
        <div class="border rounded p-3 mb-3">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="dom" name="dom" value="true" @(Model.Funcionario?.dom == true ? "checked" : "")>
                <label class="form-check-label" for="dom">Domingo</label>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label for="dom_ini">Início</label>
                    <input type="time" id="dom_ini" name="dom_ini" class="form-control"
                           value="@(Model.Funcionario?.dom_ini?.ToString(@"hh\:mm") ?? "")">
                </div>
                <div class="col-md-6">
                    <label for="dom_fim">Fim</label>
                    <input type="time" id="dom_fim" name="dom_fim" class="form-control"
                           value="@(Model.Funcionario?.dom_fim?.ToString(@"hh\:mm") ?? "")">
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">@Model.ButtonText</button>
    </form>
</div>

<script>
    // Checkbox não enviado quando desmarcado; garantimos campos vazios no back-end.
</script>
