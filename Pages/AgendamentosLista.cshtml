@page
@model CorteCor.Pages.AgendamentosListaModel
@{
    ViewData["Title"] = "Lista de Agendamentos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@ViewData["Title"]</h2>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            Filtros
        </div>
        <div class="card-body">
            <form method="get">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="DataInicio">Data Início</label>
                            <input asp-for="DataInicio" class="form-control" type="date" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="DataFim">Data Fim</label>
                            <input asp-for="DataFim" class="form-control" type="date" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Status">Status</label>
                            <select asp-for="Status" class="form-control">
                                <option value="">Todos</option>
                                @foreach (var s in Model.StatusOptions)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="IdServico">Serviço</label>
                            <select asp-for="IdServico" class="form-control" asp-items="@(new SelectList(Model.ServicosOptions, "IdServico", "Nome"))">
                                <option value="">Todos</option>
                            </select>
                        </div>
                    </div>
                 </div>
                 <div class="row mt-2">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="IdPessoa">Cliente</label>
                            <select asp-for="IdPessoa" class="form-control" asp-items="@(new SelectList(Model.PessoasOptions, "IdPessoa", "Nome"))">
                                <option value="">Todos</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="IdFuncionario">Funcionário</label>
                            <select asp-for="IdFuncionario" class="form-control" asp-items="@(new SelectList(Model.FuncionariosOptions, "IdFuncionario", "Nome"))">
                                <option value="">Todos</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                         <div class="form-check mb-2 mr-3">
                            <input asp-for="MostrarExcluidos" class="form-check-input" />
                            <label asp-for="MostrarExcluidos" class="form-check-label">Mostrar Excluídos</label>
                        </div>
                        <button type="submit" class="btn btn-primary mr-2">Filtrar</button>
                        <a href="/AgendamentosLista" class="btn btn-secondary">Limpar</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert alert-info">@Model.Mensagem</div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Data/Hora</th>
                    <th>Status</th>
                    <th>Serviço</th>
                    <th>Cliente</th>
                    <th>Funcionário</th>
                    <th>Excluído?</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Agendamentos)
                {
                    <tr class="@(item.Excluido ? "table-danger text-decoration-line-through" : "")">
                        <td>@item.DataHora.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.Status</td>
                        <td>@Model.GetServicoNome(item.IdServico)</td>
                        <td>@Model.GetPessoaNome(item.IdPessoa)</td>
                        <td>@Model.GetFuncionarioNome(item.IdFuncionario)</td>
                        <td>@(item.Excluido ? "Sim" : "Não")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
