@page
@model CorteCor.Pages.EstabelecimentosModel
@{ViewData["Title"] = "Estabelecimentos (CNPJ)";
}

<h4 class="mb-3">Estabelecimentos (CNPJ)</h4>

@if (!string.IsNullOrWhiteSpace(Model.AvisoBaseCnpj))
{
    <div class="alert alert-warning">
        @Model.AvisoBaseCnpj
    </div>
}

<form method="get" class="card mb-3">
    <div class="card-body">

        <!-- IMPORTANTE: só pesquisa quando Pesquisar=1 -->
        <input type="hidden" name="Pesquisar" value="true" />

        <div class="row g-2">

            <!-- Empresa -->
            <div class="col-md-4">
                <label class="form-label">Razão Social (contém)</label>
                <input class="form-control" name="RazaoSocial" value="@Model.RazaoSocial" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Nome Fantasia (contém)</label>
                <input class="form-control" name="NomeFantasia" value="@Model.NomeFantasia" />
            </div>

            <!-- CNPJ -->
            <div class="col-md-2">
                <label class="form-label">CNPJ Básico</label>
                <input class="form-control" name="CnpjBasico" value="@Model.CnpjBasico" placeholder="8 dígitos" />
            </div>

            <div class="col-md-2">
                <label class="form-label">CNPJ Completo</label>
                <input class="form-control" name="CnpjCompleto" value="@Model.CnpjCompleto" placeholder="14 dígitos" />
            </div>

            <!-- Padronizados -->
            <div class="col-md-2">
                <label class="form-label">UF</label>
                <select class="form-select" name="Uf">
                    <option value="">(todas)</option>
                    @foreach (var uf in Model.Ufs)
                    {
                        <option value="@uf" selected="@(Model.Uf == uf)">@uf</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Matriz/Filial</label>
                <select class="form-select" name="IdentificadorMatrizFilial">
                    <option value="">(todos)</option>
                    <option value="1" selected="@(Model.IdentificadorMatrizFilial == 1)">Matriz</option>
                    <option value="2" selected="@(Model.IdentificadorMatrizFilial == 2)">Filial</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Situação Cadastral</label>
                <select class="form-select" name="SituacaoCadastral">
                    <option value="">(todas)</option>
                    @foreach (var s in Model.SituacoesCadastrais)
                    {
                        <option value="@s.Codigo" selected="@(Model.SituacaoCadastral == s.Codigo)">
                            @s.Codigo - @s.Descricao
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Porte (Empresa)</label>
                <select class="form-select" name="PorteCodigo">
                    <option value="">(todos)</option>
                    @foreach (var p in Model.Portes)
                    {
                        <option value="@p.Codigo" selected="@(Model.PorteCodigo == p.Codigo)">
                            @p.Codigo - @p.Descricao
                        </option>
                    }
                </select>
            </div>

            <!-- Domínios -->
            <div class="col-md-4">
                <label class="form-label">CNAE Principal</label>
                <select class="form-select" name="CnaeFiscalPrincipal">
                    <option value="">(todos)</option>
                    @foreach (var it in Model.Cnaes)
                    {
                        <option value="@it.Codigo" selected="@(Model.CnaeFiscalPrincipal == it.Codigo)">
                            @it.Codigo - @it.Descricao
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Município</label>
                <select class="form-select" name="MunicipioCodigo">
                    <option value="">(todos)</option>
                    @foreach (var it in Model.Municipios)
                    {
                        <option value="@it.Codigo" selected="@(Model.MunicipioCodigo == it.Codigo)">
                            @it.Codigo - @it.Descricao
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Motivo Situação</label>
                <select class="form-select" name="MotivoSituacaoCodigo">
                    <option value="">(todos)</option>
                    @foreach (var it in Model.Motivos)
                    {
                        <option value="@it.Codigo" selected="@(Model.MotivoSituacaoCodigo == it.Codigo)">
                            @it.Codigo - @it.Descricao
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">País</label>
                <select class="form-select" name="PaisCodigo">
                    <option value="">(todos)</option>
                    @foreach (var it in Model.Paises)
                    {
                        <option value="@it.Codigo" selected="@(Model.PaisCodigo == it.Codigo)">
                            @it.Codigo - @it.Descricao
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Natureza Jurídica (Empresa)</label>
                <select class="form-select" name="NaturezaJuridicaCodigo">
                    <option value="">(todas)</option>
                    @foreach (var it in Model.Naturezas)
                    {
                        <option value="@it.Codigo" selected="@(Model.NaturezaJuridicaCodigo == it.Codigo)">
                            @it.Codigo - @it.Descricao
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Qualificação Resp. (Empresa)</label>
                <select class="form-select" name="QualificacaoRespCodigo">
                    <option value="">(todas)</option>
                    @foreach (var it in Model.Qualificacoes)
                    {
                        <option value="@it.Codigo" selected="@(Model.QualificacaoRespCodigo == it.Codigo)">
                            @it.Codigo - @it.Descricao
                        </option>
                    }
                </select>
            </div>

            <!-- Email/Telefone -->
            <div class="col-md-3">
                <label class="form-label">Email contém (opcional)</label>
                <input class="form-control" name="Email" value="@Model.Email" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Telefone contém (opcional)</label>
                <input class="form-control" name="Telefone" value="@Model.Telefone" />
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="SomenteComEmail" value="true" id="SomenteComEmail"
                           @(Model.SomenteComEmail ? "checked" : "") />
                    <label class="form-check-label" for="SomenteComEmail">Somente com e-mail</label>
                </div>
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="SomenteComTelefone" value="true" id="SomenteComTelefone"
                           @(Model.SomenteComTelefone ? "checked" : "") />
                    <label class="form-check-label" for="SomenteComTelefone">Somente com telefone</label>
                </div>
            </div>
        </div>

        <details class="mt-3">
            <summary>Filtros avançados</summary>

            <div class="row g-2 mt-2">
                <div class="col-md-3">
                    <label class="form-label">CEP</label>
                    <input class="form-control" name="Cep" value="@Model.Cep" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Bairro (contém)</label>
                    <input class="form-control" name="Bairro" value="@Model.Bairro" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Logradouro (contém)</label>
                    <input class="form-control" name="Logradouro" value="@Model.Logradouro" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Número</label>
                    <input class="form-control" name="Numero" value="@Model.Numero" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Complemento (contém)</label>
                    <input class="form-control" name="Complemento" value="@Model.Complemento" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tipo Logradouro (contém)</label>
                    <input class="form-control" name="TipoLogradouro" value="@Model.TipoLogradouro" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Cidade Exterior (contém)</label>
                    <input class="form-control" name="NomeCidadeExterior" value="@Model.NomeCidadeExterior" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">CNAE Secundário (contém)</label>
                    <input class="form-control" name="CnaeSecundaria" value="@Model.CnaeSecundaria" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Início Atividade (de)</label>
                    <input type="date" class="form-control" name="DataInicioDe" value="@Model.DataInicioDeString" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Início Atividade (até)</label>
                    <input type="date" class="form-control" name="DataInicioAte" value="@Model.DataInicioAteString" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Data Situação (início)</label>
                    <input type="date" class="form-control" name="DataSituacaoDe" value="@Model.DataSituacaoDeString" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Data Situação (fim)</label>
                    <input type="date" class="form-control" name="DataSituacaoAte" value="@Model.DataSituacaoAteString" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Situação Especial (contém)</label>
                    <input class="form-control" name="SituacaoEspecial" value="@Model.SituacaoEspecial" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Data Sit. Especial (de)</label>
                    <input type="date" class="form-control" name="DataSitEspecialDe" value="@Model.DataSitEspecialDeString" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Data Sit. Especial (até)</label>
                    <input type="date" class="form-control" name="DataSitEspecialAte" value="@Model.DataSitEspecialAteString" />
                </div>
            </div>
        </details>

        <div class="row g-2 mt-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label">Tamanho página</label>
                <select class="form-select" name="PageSize">
                    @{
                        int[] sizes = new[] { 25, 50, 100, 200 };
                        foreach (var s in sizes)
                        {
                            <option value="@s" selected="@(Model.PageSize == s)">@s</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-10 d-flex gap-2 flex-wrap">
                <button class="btn btn-primary" type="submit">Filtrar</button>
                <a class="btn btn-secondary" href="@Url.Page(null)">Abrir sem listar</a>

                @if (Model.PesquisarExecutado && Model.Total > 0)
                {
                    <a class="btn btn-success" href="@Model.BuildExportUrl("ExportExcel")">Exportar Excel</a>
                    <a class="btn btn-success" href="@Model.BuildExportUrl("ExportCsv")">Exportar CSV</a>

                    @if (Model.ExportTruncado)
                    {
                        <span class="text-danger align-self-center">
                            Exportação limitada a @Model.ExportMaxRows linhas (resultado total: @Model.Total).
                        </span>
                    }
                }
            </div>
        </div>

        @if (Model.PesquisarExecutado)
        {
            <div class="mt-3 text-muted">
                Total: <b>@Model.Total</b> registros | Página <b>@Model.Page</b> de <b>@Model.TotalPages</b>
            </div>
        }
        else
        {
            <div class="mt-3 text-muted">
                A lista não carrega automaticamente. Use os filtros e clique em <b>Filtrar</b>.
            </div>
        }
    </div>
</form>

@if (Model.PesquisarExecutado)
{
    <div class="d-flex justify-content-end align-items-center mb-2 gap-2">
        @if (Model.Page > 1)
        {
            <a class="btn btn-sm btn-primary" href="@Model.BuildPageUrl(Model.Page - 1)">Anterior</a>
        }
        @if (Model.Page < Model.TotalPages)
        {
            <a class="btn btn-sm btn-primary" href="@Model.BuildPageUrl(Model.Page + 1)">Próxima</a>
        }
    </div>

    <div class="table-responsive">
        <table class="table-sm table-bordered align-middle">
            <thead class="">
                <tr>
                    <th>Possui Email</th>
                    <th>Possui Tel</th>

                    <th>CNPJ</th>
                    <th>Razão Social</th>
                    <th>Nome Fantasia</th>
                    <th>M/F</th>

                    <th>Situação</th>
                    <th>Data Sit.</th>
                    <th>Motivo</th>

                    <th>Início</th>

                    <th>CNAE</th>
                    <th>CNAE Desc.</th>
                    <th>CNAE Sec.</th>

                    <th>Município</th>
                    <th>UF</th>
                    <th>CEP</th>

                    <th>Tipo Log.</th>
                    <th>Logradouro</th>
                    <th>Número</th>
                    <th>Complemento</th>
                    <th>Bairro</th>

                    <th>DDD1</th>
                    <th>Tel1</th>
                    <th>DDD2</th>
                    <th>Tel2</th>

                    <th>Email</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in Model.Itens)
            {
                <tr>
                    <td>@(r.PossuiEmail ? "Sim" : "Não")</td>
                    <td>@(r.PossuiTelefone ? "Sim" : "Não")</td>

                    <td>@r.Cnpj</td>
                    <td>@r.RazaoSocial</td>
                    <td>@r.NomeFantasia</td>
                    <td>@r.IdentificadorMatrizFilial</td>

                    <td>@r.SituacaoCadastral</td>
                    <td>@(r.DataSituacaoCadastral?.ToString("yyyy-MM-dd") ?? "")</td>
                    <td>@r.MotivoSituacaoDescricao</td>

                    <td>@(r.DataInicioAtividade?.ToString("yyyy-MM-dd") ?? "")</td>

                    <td>@r.CnaeFiscalPrincipal</td>
                    <td>@r.CnaeDescricao</td>
                    <td>@r.CnaeFiscalSecundaria</td>

                    <td>@r.MunicipioDescricao</td>
                    <td>@r.Uf</td>
                    <td>@r.Cep</td>

                    <td>@r.TipoLogradouro</td>
                    <td>@r.Logradouro</td>
                    <td>@r.Numero</td>
                    <td>@r.Complemento</td>
                    <td>@r.Bairro</td>

                    <td>@r.Ddd1</td>
                    <td>@r.Telefone1</td>
                    <td>@r.Ddd2</td>
                    <td>@r.Telefone2</td>

                    <td>@r.CorreioEletronico</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
