@page
@using CorteCor.Models
@model CorteCor.Pages.Vendas.NovoModel
@{
    ViewData["Title"] = Model.TituloTela;
    var modoSomenteLeitura = Model.ModoSomenteLeitura;
}

@section Styles {
    <style>
        .venda-shell-card {
            border: 0;
            border-radius: 20px;
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
        }

        .venda-hero {
            background: linear-gradient(135deg, #eff6ff 0%, #ffffff 48%, #ecfeff 100%);
            border-radius: 24px;
            padding: 1.6rem;
            margin-bottom: 1.5rem;
        }

        .venda-note {
            border-radius: 14px;
            padding: 0.9rem 1rem;
            background: #fff7ed;
            border: 1px solid #fdba74;
            color: #9a3412;
            font-size: 0.95rem;
        }

        .venda-view-note {
            background: #eff6ff;
            border-color: #93c5fd;
            color: #1d4ed8;
        }

        .venda-summary {
            background: #0f172a;
            color: #fff;
            border-radius: 18px;
            padding: 1rem 1.1rem;
        }

        .venda-summary small {
            color: rgba(255,255,255,0.72);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .cliente-search-wrap {
            position: relative;
        }

        .cliente-search-results {
            position: absolute;
            z-index: 1050;
            top: 100%;
            left: 0;
            right: 0;
            max-height: 260px;
            overflow-y: auto;
            background: #fff;
            border: 1px solid #cbd5e1;
            border-radius: 0 0 10px 10px;
            box-shadow: 0 16px 30px rgba(15, 23, 42, 0.12);
            display: none;
        }

        .cliente-search-option {
            width: 100%;
            border: 0;
            background: #fff;
            text-align: left;
            padding: 0.65rem 0.8rem;
        }

        .cliente-search-option:hover,
        .cliente-search-option:focus {
            background: #eff6ff;
        }
    </style>
}

<div class="venda-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h2 class="mb-1">@Model.TituloTela</h2>
            <div class="text-muted">@Model.DescricaoTela</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-secondary" asp-page="/Vendas/Index">Voltar para vendas</a>
            <a class="btn btn-dark" asp-page="/Estoque/Index">Controle de Estoque</a>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.MensagemTela))
{
    <div class="alert alert-@Model.MensagemTelaTipo">@Model.MensagemTela</div>
}

@if (modoSomenteLeitura)
{
    <div class="venda-note venda-view-note mb-4">
        Esta venda já foi encerrada. Os dados abaixo estão disponíveis apenas para consulta.
    </div>
}

<div class="card venda-shell-card">
    <div class="card-header bg-white fw-semibold">@Model.TituloTela</div>
    <div class="card-body">
        <form method="post" asp-page-handler="Finalizar" id="vendaForm" class="row g-3">
            <input type="hidden" name="idVendaProduto" value="@Model.idVendaProduto" />
            <input type="hidden" id="payloadJson" name="payloadJson" />

            <div class="col-md-8">
                <label class="form-label">Cliente</label>
                <div class="cliente-search-wrap">
                    <input type="hidden" id="clienteSelect" value="@Model.VendaExistente?.IdPessoa" />
                    <input class="form-control" id="clienteBuscaInput" value="@Model.VendaExistente?.NomeCliente" placeholder="Digite nome, CPF/CNPJ, e-mail ou telefone" autocomplete="off" @(modoSomenteLeitura ? "disabled" : null) />
                    <div class="cliente-search-results" id="clienteBuscaResults"></div>
                </div>
                <div class="form-text">Deixe em branco para consumidor n&atilde;o identificado.</div>
            </div>

            <div class="col-md-4">
                <label class="form-label">Meio de pagamento</label>
                <select class="form-select" id="meioPagamentoSelect" @(modoSomenteLeitura ? "disabled" : null)>
                    <option value="">Livre</option>
                    @foreach (var meio in Model.Contexto.MeiosPagamento)
                    {
                        if (Model.VendaExistente?.IdMeioPagamento == meio.IdMeioPagamento)
                        {
                            <option value="@meio.IdMeioPagamento" data-nome="@meio.Nome" selected>@meio.Nome</option>
                        }
                        else
                        {
                            <option value="@meio.IdMeioPagamento" data-nome="@meio.Nome">@meio.Nome</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Recorr&ecirc;ncia</label>
                <select class="form-select" id="recorrenciaSelect" @(modoSomenteLeitura ? "disabled" : null)>
                    @if (Model.VendaExistente?.Recorrencia == RecorrenciaTipo.Mensal)
                    {
                        <option value="Nenhuma">Nenhuma</option>
                        <option value="Mensal" selected>Mensal</option>
                    }
                    else
                    {
                        <option value="Nenhuma" selected>Nenhuma</option>
                        <option value="Mensal">Mensal</option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Parcelas</label>
                <input type="number" class="form-control" id="numeroParcelasInput" value="1" min="1" max="60" step="1" @(modoSomenteLeitura ? "readonly" : null) />
            </div>

            <div class="col-md-4">
                <label class="form-label">Primeiro vencimento</label>
                <input type="date" class="form-control" id="primeiroVencimentoInput" value="@DateTime.Today.ToString("yyyy-MM-dd")" @(modoSomenteLeitura ? "readonly" : null) />
            </div>

            <div class="col-md-4">
                <label class="form-label">Conta caixa</label>
                <select class="form-select" id="contaCaixaSelect" @(modoSomenteLeitura ? "disabled" : null)>
                    <option value="">Selecione quando recebido na hora</option>
                    @foreach (var conta in Model.ContasCaixa)
                    {
                        <option value="@conta.IdConta">@conta.Nome</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label">Grupo do Plano de Contas</label>
                <select class="form-select" id="grupoPlanoContaSelect" data-smart-select data-smart-placeholder="Digite para pesquisar grupo..." @(modoSomenteLeitura ? "disabled" : null)>
                    <option value="">Selecione o grupo</option>
                    @foreach (var grupo in Model.GruposPlano)
                    {
                        <option value="@grupo.IdPlano" selected="@(Model.GrupoPlanoContaId == grupo.IdPlano)">@grupo.Codigo - @grupo.NomeExibicao</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label">Conta do Plano de Contas</label>
                <select class="form-select" id="planoContaSelect" data-selected="@Model.IdPlanoPadraoVenda" data-smart-select data-smart-placeholder="Digite para pesquisar conta..." @(modoSomenteLeitura ? "disabled" : null)>
                    <option value="">Selecione a conta</option>
                    @foreach (var plano in Model.ContasPlano)
                    {
                        <option value="@plano.IdPlano" selected="@(Model.IdPlanoPadraoVenda == plano.IdPlano)">@plano.Codigo - @plano.NomeExibicao</option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Tipo do item</label>
                <select class="form-select" id="tipoItemSelect" @(modoSomenteLeitura ? "disabled" : null)>
                    <option value="Produto">Produto</option>
                    <option value="Servico">Serviço</option>
                </select>
            </div>

            <div class="col-md-5">
                <label class="form-label">Item</label>
                <select class="form-select" id="catalogoSelect" data-smart-select data-smart-placeholder="Digite para pesquisar item..." @(modoSomenteLeitura ? "disabled" : null)></select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Quantidade</label>
                <input type="number" id="quantidadeInput" class="form-control" value="1" min="1" step="1" @(modoSomenteLeitura ? "disabled" : null) />
            </div>

            <div class="col-md-4">
                <label class="form-label">Valor unitário</label>
                <input type="number" id="valorUnitarioInput" class="form-control" value="0" min="0" step="0.01" @(modoSomenteLeitura ? "disabled" : null) />
            </div>

            <div class="col-md-8">
                <label class="form-label">Observação</label>
                <input type="text" id="observacoesInput" class="form-control" maxlength="500" placeholder="Anotações da venda" value="@Model.VendaExistente?.Observacoes" @(modoSomenteLeitura ? "readonly" : null) />
            </div>

            <div class="col-md-2">
                <label class="form-label">Desconto</label>
                <input type="number" id="descontoInput" class="form-control" value="@Model.VendaExistente?.Desconto.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" min="0" step="0.01" @(modoSomenteLeitura ? "readonly" : null) />
            </div>

            <div class="col-md-2">
                <label class="form-label">Acréscimo</label>
                <input type="number" id="acrescimoInput" class="form-control" value="@Model.VendaExistente?.Acrescimo.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" min="0" step="0.01" @(modoSomenteLeitura ? "readonly" : null) />
            </div>

            <div class="col-12 d-flex gap-3 flex-wrap">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="recebidoNaHoraCheck" checked="@(Model.VendaExistente is null ? "checked" : null)" @(Model.VendaExistente?.RecebidoNaHora == true ? "checked" : null) @(modoSomenteLeitura ? "disabled" : null) />
                    <label class="form-check-label" for="recebidoNaHoraCheck">Venda recebida na hora</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="emitirNotaServicoCheck" @(Model.VendaExistente?.SolicitarEmissaoFiscalServico == true ? "checked" : null) @(modoSomenteLeitura ? "disabled" : null) />
                    <label class="form-check-label" for="emitirNotaServicoCheck">Emitir nota fiscal de serviço ao concluir</label>
                </div>
            </div>

            <div class="col-12">
                <div class="venda-note">
                    Nesta rotina, a emissão fiscal deve ser usada apenas para serviços e somente em homologação. Vendas de produtos continuam sem emissão fiscal.
                </div>
            </div>

            @if (!modoSomenteLeitura)
            {
                <div class="col-12 d-flex justify-content-end">
                    <button type="button" class="btn btn-primary" id="addItemBtn">Adicionar item</button>
                </div>
            }

            <div class="col-12">
                <div class="table-responsive">
                    <table class="table table-sm align-middle" id="carrinhoTable">
                        <thead>
                            <tr>
                                <th>Tipo</th>
                                <th>Descrição</th>
                                <th class="text-end">Qtd.</th>
                                <th class="text-end">Unitário</th>
                                <th class="text-end">Total</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Nenhum item adicionado.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-12">
                <div class="venda-summary d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <small>Valor total da venda</small>
                        <div class="fs-4 fw-semibold" id="totalVendaLabel">R$ 0,00</div>
                    </div>
                    <div class="text-end">
                        <div id="resumoCarrinhoLabel">0 item(ns) no carrinho</div>
                        <div class="small text-white-50">Produtos reduzem estoque somente após a conclusão.</div>
                    </div>
                </div>
            </div>

            <div class="col-12 text-end">
                @if (modoSomenteLeitura)
                {
                    <a class="btn btn-primary" asp-page="/Vendas/Index">Voltar para vendas</a>
                }
                else
                {
                    <button type="submit" class="btn btn-primary" id="finalizarVendaBtn">@(Model.idVendaProduto.GetValueOrDefault() > 0 ? "Salvar alterações" : "Concluir venda")</button>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const produtos = @Html.Raw(Model.ProdutosJson);
        const servicos = @Html.Raw(Model.ServicosJson);
        const itensIniciais = @Html.Raw(Model.ItensJson);
        const modoSomenteLeitura = @(modoSomenteLeitura ? "true" : "false");
        const clientesBuscaUrl = '@Url.Page("/API/Clientes")';
        let carrinho = Array.isArray(itensIniciais) ? [...itensIniciais] : [];

        const tipoItemSelect = document.getElementById('tipoItemSelect');
        const catalogoSelect = document.getElementById('catalogoSelect');
        const quantidadeInput = document.getElementById('quantidadeInput');
        const valorUnitarioInput = document.getElementById('valorUnitarioInput');
        const addItemBtn = document.getElementById('addItemBtn');
        const payloadJsonInput = document.getElementById('payloadJson');
        const vendaForm = document.getElementById('vendaForm');
        const resumoCarrinhoLabel = document.getElementById('resumoCarrinhoLabel');
        const clienteHidden = document.getElementById('clienteSelect');
        const clienteBuscaInput = document.getElementById('clienteBuscaInput');
        const clienteBuscaResults = document.getElementById('clienteBuscaResults');
        const grupoPlanoContaSelect = document.getElementById('grupoPlanoContaSelect');
        const planoContaSelect = document.getElementById('planoContaSelect');
        const contaCaixaSelect = document.getElementById('contaCaixaSelect');
        const recebidoNaHoraCheck = document.getElementById('recebidoNaHoraCheck');
        let clienteBuscaTimer = null;

        function formatCurrency(value) {
            return Number(value || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
        }

        function esconderResultadoClientes() {
            clienteBuscaResults.style.display = 'none';
            clienteBuscaResults.innerHTML = '';
        }

        function selecionarCliente(cliente) {
            clienteHidden.value = cliente?.id || '';
            clienteBuscaInput.value = cliente?.nome || '';
            esconderResultadoClientes();
        }

        async function buscarClientes(termo) {
            const response = await fetch(`${clientesBuscaUrl}?q=${encodeURIComponent(termo || '')}&somenteClientes=true`, {
                headers: { 'Accept': 'application/json' }
            });

            if (!response.ok) {
                return [];
            }

            return await response.json();
        }

        function renderClientes(clientes) {
            if (!clientes.length) {
                clienteBuscaResults.innerHTML = '<div class="px-3 py-2 text-muted">Nenhum cliente encontrado.</div>';
                clienteBuscaResults.style.display = 'block';
                return;
            }

            clienteBuscaResults.innerHTML = clientes.map(cliente => `
                <button type="button" class="cliente-search-option" data-id="${cliente.id}" data-nome="${cliente.nome}">
                    <span class="fw-semibold">${cliente.nome}</span>
                    <span class="d-block small text-muted">${cliente.rotulo}</span>
                </button>
            `).join('');
            clienteBuscaResults.querySelectorAll('.cliente-search-option').forEach(botao => {
                botao.addEventListener('click', () => selecionarCliente({
                    id: botao.dataset.id,
                    nome: botao.dataset.nome
                }));
            });
            clienteBuscaResults.style.display = 'block';
        }

        if (clienteBuscaInput && !modoSomenteLeitura) {
            clienteBuscaInput.addEventListener('input', () => {
                clienteHidden.value = '';
                clearTimeout(clienteBuscaTimer);
                const termo = clienteBuscaInput.value.trim();
                clienteBuscaTimer = setTimeout(async () => renderClientes(await buscarClientes(termo)), 250);
            });
            clienteBuscaInput.addEventListener('focus', async () => {
                if (!clienteBuscaInput.value.trim()) {
                    renderClientes(await buscarClientes(''));
                }
            });
            document.addEventListener('click', event => {
                if (!event.target.closest('.cliente-search-wrap')) {
                    esconderResultadoClientes();
                }
            });
        }

        async function carregarContasPlano(idGrupo, selectedId) {
            planoContaSelect.innerHTML = '<option value="">Selecione a conta</option>';
            planoContaSelect.disabled = !idGrupo || modoSomenteLeitura;
            if (!idGrupo) {
                return;
            }

            const response = await fetch(`${window.location.pathname}?handler=ContasFilhas&idGrupo=${encodeURIComponent(idGrupo)}`, {
                headers: { 'Accept': 'application/json' }
            });

            if (!response.ok) {
                planoContaSelect.innerHTML = '<option value="">Nao foi possivel carregar as contas</option>';
                return;
            }

            const contas = await response.json();
            contas.forEach(conta => {
                const option = document.createElement('option');
                option.value = conta.id;
                option.textContent = conta.rotulo;
                if (selectedId && String(selectedId) === String(conta.id)) {
                    option.selected = true;
                }
                planoContaSelect.appendChild(option);
            });
        }

        function atualizarObrigatoriedadeContaCaixa() {
            contaCaixaSelect.required = recebidoNaHoraCheck.checked;
        }

        function formatQuantity(value) {
            return Math.trunc(Number(value || 0)).toLocaleString('pt-BR', { maximumFractionDigits: 0 });
        }

        function formatItemQuantity(item) {
            return item.tipoItem === 'Produto'
                ? formatQuantity(item.quantidade)
                : Number(item.quantidade || 0).toLocaleString('pt-BR', { maximumFractionDigits: 3 });
        }

        function configurarQuantidadeInput() {
            const isProduto = tipoItemSelect.value === 'Produto';
            quantidadeInput.min = isProduto ? '1' : '0.001';
            quantidadeInput.step = isProduto ? '1' : '0.001';

            if (isProduto) {
                const quantidade = Number(quantidadeInput.value || 1);
                quantidadeInput.value = String(Math.max(1, Math.trunc(quantidade)));
            }
        }

        function getCatalogoAtual() {
            return tipoItemSelect.value === 'Servico' ? servicos : produtos;
        }

        function preencherCatalogo() {
            const catalogo = getCatalogoAtual();
            catalogoSelect.innerHTML = '';

            if (!catalogo.length) {
                const option = document.createElement('option');
                option.value = '';
                option.textContent = 'Nenhum item disponivel';
                catalogoSelect.appendChild(option);
                valorUnitarioInput.value = '0';
                return;
            }

            for (const item of catalogo) {
                const option = document.createElement('option');
                option.value = item.id;
                const detalhe = item.tipo === 'Produto' && item.controlaEstoque
                    ? ` | estoque: ${formatQuantity(item.estoqueAtual)}`
                    : '';
                option.textContent = `${item.nome} | ${formatCurrency(item.valor)}${detalhe}`;
                option.dataset.valor = item.valor;
                option.dataset.nome = item.nome;
                option.dataset.tipo = item.tipo;
                catalogoSelect.appendChild(option);
            }

            valorUnitarioInput.value = Number(catalogo[0].valor || 0).toFixed(2);
            configurarQuantidadeInput();
        }

        function atualizarValorCatalogo() {
            const selected = catalogoSelect.options[catalogoSelect.selectedIndex];
            valorUnitarioInput.value = selected?.dataset?.valor ? Number(selected.dataset.valor).toFixed(2) : '0';
        }

        function renderCarrinho() {
            const tbody = document.querySelector('#carrinhoTable tbody');

            if (!carrinho.length) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">Nenhum item adicionado.</td></tr>';
                document.getElementById('totalVendaLabel').textContent = formatCurrency(0);
                resumoCarrinhoLabel.textContent = '0 item(ns) no carrinho';
                return;
            }

            let html = '';
            let total = 0;
            carrinho.forEach((item, index) => {
                const totalItem = Number(item.quantidade) * Number(item.valorUnitario);
                total += totalItem;
                const botaoAcao = modoSomenteLeitura
                    ? '<span class="text-muted small">Somente leitura</span>'
                    : `<button type="button" class="btn btn-sm btn-danger" onclick="removerItem(${index})">Remover</button>`;

                html += `
                    <tr>
                        <td><span class="badge ${item.tipoItem === 'Servico' ? 'bg-primary' : 'bg-success'}">${item.tipoItem}</span></td>
                        <td>${item.descricao}</td>
                        <td class="text-end">${formatItemQuantity(item)}</td>
                        <td class="text-end">${formatCurrency(item.valorUnitario)}</td>
                        <td class="text-end fw-semibold">${formatCurrency(totalItem)}</td>
                        <td class="text-end">${botaoAcao}</td>
                    </tr>
                `;
            });

            tbody.innerHTML = html;

            const desconto = Number(document.getElementById('descontoInput').value || 0);
            const acrescimo = Number(document.getElementById('acrescimoInput').value || 0);
            const totalFinal = total - desconto + acrescimo;
            document.getElementById('totalVendaLabel').textContent = formatCurrency(totalFinal);
            resumoCarrinhoLabel.textContent = `${carrinho.length} item(ns) no carrinho`;
        }

        window.removerItem = function(index) {
            if (modoSomenteLeitura) {
                return;
            }

            carrinho.splice(index, 1);
            renderCarrinho();
        };

        if (addItemBtn) {
            addItemBtn.addEventListener('click', () => {
                const catalogo = getCatalogoAtual();
                const idSelecionado = Number(catalogoSelect.value);
                const selecionado = catalogo.find(item => Number(item.id) === idSelecionado);
                const quantidade = Number(quantidadeInput.value || 0);
                const valorUnitario = Number(valorUnitarioInput.value || 0);

                if (!selecionado || quantidade <= 0 || valorUnitario < 0) {
                    alert('Selecione um item valido e informe quantidade maior que zero.');
                    return;
                }

                if (selecionado.tipo === 'Produto' && !Number.isInteger(quantidade)) {
                    alert('Informe uma quantidade inteira para produtos de estoque.');
                    return;
                }

                carrinho.push({
                    tipoItem: selecionado.tipo,
                    idProduto: selecionado.tipo === 'Produto' ? selecionado.id : null,
                    idServico: selecionado.tipo === 'Servico' ? selecionado.id : null,
                    descricao: selecionado.nome,
                    quantidade,
                    valorUnitario
                });

                quantidadeInput.value = '1';
                renderCarrinho();
            });
        }

        vendaForm.addEventListener('submit', (event) => {
            if (modoSomenteLeitura) {
                event.preventDefault();
                return;
            }

            if (!carrinho.length) {
                event.preventDefault();
                alert('Adicione ao menos um item para concluir a venda.');
                return;
            }

            const meioPagamentoSelect = document.getElementById('meioPagamentoSelect');
            const meioSelecionado = meioPagamentoSelect.options[meioPagamentoSelect.selectedIndex];
            const recebidoNaHora = recebidoNaHoraCheck.checked;
            const numeroParcelas = Math.max(1, Math.trunc(Number(document.getElementById('numeroParcelasInput').value || 1)));

            if (!planoContaSelect.value) {
                event.preventDefault();
                alert('Selecione uma conta analitica do plano de contas para a venda.');
                return;
            }

            if (recebidoNaHora && !contaCaixaSelect.value) {
                event.preventDefault();
                alert('Selecione a conta caixa que recebeu o valor da venda.');
                return;
            }

            const payload = {
                idPessoa: document.getElementById('clienteSelect').value ? Number(document.getElementById('clienteSelect').value) : null,
                idMeioPagamento: meioPagamentoSelect.value ? Number(meioPagamentoSelect.value) : null,
                idPlano: planoContaSelect.value ? Number(planoContaSelect.value) : null,
                idConta: contaCaixaSelect.value ? Number(contaCaixaSelect.value) : null,
                tipoPagamento: meioSelecionado?.dataset?.nome || null,
                recorrencia: document.getElementById('recorrenciaSelect').value || 'Nenhuma',
                recebidoNaHora,
                emitirNotaFiscalServico: document.getElementById('emitirNotaServicoCheck').checked,
                numeroParcelas,
                primeiroVencimento: document.getElementById('primeiroVencimentoInput').value || null,
                desconto: Number(document.getElementById('descontoInput').value || 0),
                acrescimo: Number(document.getElementById('acrescimoInput').value || 0),
                observacoes: document.getElementById('observacoesInput').value || null,
                itens: carrinho.map(item => ({
                    tipoItem: item.tipoItem,
                    idProduto: item.idProduto,
                    idServico: item.idServico,
                    quantidade: item.quantidade,
                    valorUnitario: item.valorUnitario
                }))
            };

            payloadJsonInput.value = JSON.stringify(payload);
        });

        tipoItemSelect.addEventListener('change', preencherCatalogo);
        catalogoSelect.addEventListener('change', atualizarValorCatalogo);
        grupoPlanoContaSelect.addEventListener('change', () => carregarContasPlano(grupoPlanoContaSelect.value, null));
        recebidoNaHoraCheck.addEventListener('change', atualizarObrigatoriedadeContaCaixa);
        document.getElementById('descontoInput').addEventListener('input', renderCarrinho);
        document.getElementById('acrescimoInput').addEventListener('input', renderCarrinho);

        preencherCatalogo();
        atualizarObrigatoriedadeContaCaixa();
        if (grupoPlanoContaSelect.value && planoContaSelect.dataset.selected) {
            carregarContasPlano(grupoPlanoContaSelect.value, planoContaSelect.dataset.selected);
        }
        renderCarrinho();
    </script>
}
