@page
@model CorteCor.Pages.Vendas.DetalhesModel
@using CorteCor.Models
@{
    ViewData["Title"] = "Pós-venda";
    var venda = Model.Contexto.Venda;
    var notaAtiva = Model.Contexto.Notas.Any(n => n.Status != "Cancelada" && n.Status != "Rejeitada");
}

@section Styles {
    <style>
        .pos-shell-card {
            border: 0;
            border-radius: 20px;
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
        }

        .pos-hero {
            background: linear-gradient(135deg, #fff7ed 0%, #ffffff 48%, #eff6ff 100%);
            border-radius: 24px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .pos-kpi {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 1rem 1.1rem;
            height: 100%;
        }

        .pos-kpi-label {
            font-size: 0.74rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #6b7280;
            margin-bottom: 0.35rem;
        }

        .pos-kpi-value {
            font-size: 1.45rem;
            font-weight: 700;
            color: #111827;
        }

        .pos-note {
            border-radius: 14px;
            padding: 0.9rem 1rem;
            background: #eff6ff;
            border: 1px solid #93c5fd;
            color: #1d4ed8;
            font-size: 0.95rem;
        }

        .pos-alert-warning {
            background: #fff7ed;
            border-color: #fdba74;
            color: #9a3412;
        }

        .pos-summary-box {
            background: #0f172a;
            color: #fff;
            border-radius: 18px;
            padding: 1rem 1.1rem;
        }

        .pos-summary-box small {
            color: rgba(255,255,255,0.7);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .pos-table td {
            vertical-align: top;
        }

        .pos-actions-wrap {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
    </style>
}

<div class="pos-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h2 class="mb-1">Pós-venda da venda #@venda?.IdVendaProduto</h2>
            <div class="text-muted">Controle trocas, devoluções e cancelamentos com reflexo em estoque, financeiro e CRM.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" asp-page="/Vendas/Index">Voltar para vendas</a>
            <a class="btn btn-dark" asp-page="/NotaFiscalLista" asp-route-idVendaProduto="@venda?.IdVendaProduto">Notas da venda</a>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-@(Model.FlashType ?? "info")">@Model.FlashMessage</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="pos-kpi">
            <div class="pos-kpi-label">Cliente</div>
            <div class="pos-kpi-value fs-5">@(string.IsNullOrWhiteSpace(venda?.NomeCliente) ? "Consumidor final" : venda?.NomeCliente)</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pos-kpi">
            <div class="pos-kpi-label">Status da venda</div>
            <div class="pos-kpi-value fs-5">@venda?.Status</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pos-kpi">
            <div class="pos-kpi-label">Total original</div>
            <div class="pos-kpi-value fs-5">R$ @venda?.ValorTotal.ToString("N2")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pos-kpi">
            <div class="pos-kpi-label">Status fiscal</div>
            <div class="pos-kpi-value fs-5">@(string.IsNullOrWhiteSpace(venda?.StatusFiscal) ? "Sem nota" : venda?.StatusFiscal)</div>
        </div>
    </div>
</div>

@if (notaAtiva)
{
    <div class="alert pos-alert-warning mb-4">
        Esta venda possui nota fiscal ativa. Itens de serviço não podem entrar em devolução, troca ou cancelamento enquanto a nota não for cancelada. O cancelamento total também fica bloqueado.
    </div>
}

<div class="row g-4">
    <div class="col-xl-7">
        <div class="card pos-shell-card mb-4">
            <div class="card-header bg-white fw-semibold">Processar pós-venda</div>
            <div class="card-body">
                <form method="post" asp-page-handler="Processar" id="posVendaForm" class="row g-3">
                    <input type="hidden" name="idVendaProduto" value="@venda?.IdVendaProduto" />
                    <input type="hidden" id="payloadJson" name="payloadJson" />

                    <div class="col-md-4">
                        <label class="form-label">Operação</label>
                        <select class="form-select" id="tipoOperacaoSelect">
                            <option value="@VendaPosVendaTipo.Devolucao">Devolução</option>
                            <option value="@VendaPosVendaTipo.CancelamentoParcial">Cancelamento parcial</option>
                            <option value="@VendaPosVendaTipo.Troca">Troca</option>
                        </select>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Observações</label>
                        <input class="form-control" id="observacoesInput" maxlength="500" placeholder="Explique o motivo da operação." />
                    </div>

                    <div class="col-12">
                        <div class="table-responsive">
                            <table class="table table-sm align-middle pos-table">
                                <thead>
                                    <tr>
                                        <th>Item</th>
                                        <th class="text-end">Vendido</th>
                                        <th class="text-end">Cancelado</th>
                                        <th class="text-end">Devolvido</th>
                                        <th class="text-end">Trocado</th>
                                        <th class="text-end">Disponível</th>
                                        <th class="text-end">Processar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Contexto.Itens)
                                    {
                                        var bloqueadoPorNota = notaAtiva && item.TipoItem == VendaProdutoTipoItem.Servico;
                                        var formatoQuantidade = item.TipoItem == VendaProdutoTipoItem.Produto ? "N0" : "N3";
                                        var stepQuantidade = item.TipoItem == VendaProdutoTipoItem.Produto ? "1" : "0.001";
                                        var maxQuantidade = item.TipoItem == VendaProdutoTipoItem.Produto
                                            ? decimal.Truncate(item.QuantidadeDisponivelPosVenda).ToString(System.Globalization.CultureInfo.InvariantCulture)
                                            : item.QuantidadeDisponivelPosVenda.ToString(System.Globalization.CultureInfo.InvariantCulture);
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@item.Descricao</div>
                                                <div class="small text-muted">@item.TipoItem • R$ @item.ValorUnitario.ToString("N2")</div>
                                            </td>
                                            <td class="text-end">@item.Quantidade.ToString(formatoQuantidade)</td>
                                            <td class="text-end">@item.QuantidadeCancelada.ToString(formatoQuantidade)</td>
                                            <td class="text-end">@item.QuantidadeDevolvida.ToString(formatoQuantidade)</td>
                                            <td class="text-end">@item.QuantidadeTrocada.ToString(formatoQuantidade)</td>
                                            <td class="text-end fw-semibold">@item.QuantidadeDisponivelPosVenda.ToString(formatoQuantidade)</td>
                                            <td class="text-end">
                                                <input type="number"
                                                       class="form-control text-end posvenda-qtd"
                                                       data-item-id="@item.IdItemVenda"
                                                       data-disponivel="@maxQuantidade"
                                                       value="0"
                                                       min="0"
                                                       step="@stepQuantidade"
                                                       max="@maxQuantidade"
                                                       @(bloqueadoPorNota ? "disabled" : null) />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="col-12" id="trocaBox" style="display:none;">
                        <div class="border rounded-4 p-3 bg-light">
                            <div class="fw-semibold mb-3">Itens de reposição da troca</div>
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label">Tipo</label>
                                    <select class="form-select" id="reposicaoTipoItemSelect">
                                        <option value="Produto">Produto</option>
                                        <option value="Servico">Serviço</option>
                                    </select>
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label">Item</label>
                                    <select class="form-select" id="reposicaoCatalogoSelect"></select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Qtd.</label>
                                    <input class="form-control" type="number" id="reposicaoQuantidadeInput" value="1" min="1" step="1" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Unitário</label>
                                    <input class="form-control" type="number" id="reposicaoValorUnitarioInput" value="0" min="0" step="0.01" />
                                </div>
                                <div class="col-12 text-end">
                                    <button type="button" class="btn btn-primary" id="addReposicaoBtn">Adicionar reposição</button>
                                </div>
                                <div class="col-12">
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0" id="reposicaoTable">
                                            <thead>
                                                <tr>
                                                    <th>Tipo</th>
                                                    <th>Descrição</th>
                                                    <th class="text-end">Qtd.</th>
                                                    <th class="text-end">Unitário</th>
                                                    <th class="text-end">Total</th>
                                                    <th class="text-end">Ações</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td colspan="6" class="text-center text-muted py-3">Nenhum item de reposição adicionado.</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="pos-summary-box d-flex justify-content-between align-items-center flex-wrap gap-3">
                            <div>
                                <small>Crédito</small>
                                <div class="fs-4 fw-semibold" id="creditoLabel">R$ 0,00</div>
                            </div>
                            <div>
                                <small>Reposição</small>
                                <div class="fs-4 fw-semibold" id="reposicaoLabel">R$ 0,00</div>
                            </div>
                            <div class="text-end">
                                <small>Diferença financeira</small>
                                <div class="fs-4 fw-semibold" id="diferencaLabel">R$ 0,00</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="pos-note">
                            Devolução e cancelamento parcial devolvem produtos ao estoque quando houver controle. Troca soma o retorno dos itens originais com a saída dos itens de reposição e ajusta o financeiro automaticamente.
                        </div>
                    </div>

                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-primary">Processar pós-venda</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card pos-shell-card">
            <div class="card-header bg-white fw-semibold">Estorno total da venda</div>
            <div class="card-body">
                <form method="post" asp-page-handler="CancelarTotal" onsubmit="return confirm('Confirma o estorno total desta venda?');" class="row g-3">
                    <input type="hidden" name="idVendaProduto" value="@venda?.IdVendaProduto" />
                    <div class="col-12">
                        <div class="pos-note pos-alert-warning mb-3">
                            O estoque sera devolvido, os titulos financeiros vinculados serao ajustados e lancamentos futuros desta venda serao cancelados.
                        </div>
                        <label class="form-label">Justificativa do estorno total</label>
                        <textarea class="form-control" name="observacoes" rows="3" minlength="5" maxlength="500" required placeholder="Motivo do estorno total"></textarea>
                    </div>
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-danger" @(notaAtiva ? "disabled" : null)>Estornar venda</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-5">
        <div class="card pos-shell-card mb-4">
            <div class="card-header bg-white fw-semibold">Financeiro da venda</div>
            <div class="card-body">
                @if (Model.Contexto.Titulos.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle pos-table mb-0">
                            <thead>
                                <tr>
                                    <th>Descrição</th>
                                    <th>Status</th>
                                    <th class="text-end">Valor</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var titulo in Model.Contexto.Titulos)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@titulo.Descricao</div>
                                            <div class="small text-muted">@titulo.Tipo • @titulo.Origem</div>
                                        </td>
                                        <td><span class="badge bg-secondary">@titulo.Status</span></td>
                                        <td class="text-end">R$ @titulo.ValorOriginal.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Nenhum título financeiro vinculado a esta venda.</div>
                }
            </div>
        </div>

        <div class="card pos-shell-card mb-4">
            <div class="card-header bg-white fw-semibold">Notas fiscais</div>
            <div class="card-body">
                @if (Model.Contexto.Notas.Any())
                {
                    <div class="d-grid gap-2">
                        @foreach (var nota in Model.Contexto.Notas)
                        {
                            <a class="btn btn-dark text-start" asp-page="/NotaFiscalLista" asp-route-idNotaFiscal="@nota.IdNotaFiscal">
                                NFS-e @nota.Numero/@nota.Serie • @nota.Status
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="text-muted">Nenhuma nota fiscal vinculada a esta venda.</div>
                }
            </div>
        </div>

        <div class="card pos-shell-card">
            <div class="card-header bg-white fw-semibold">Histórico de pós-venda</div>
            <div class="card-body">
                @if (Model.Contexto.HistoricoPosVenda.Any())
                {
                    <div class="d-grid gap-3">
                        @foreach (var historico in Model.Contexto.HistoricoPosVenda)
                        {
                            <div class="border rounded-4 p-3">
                                <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                    <div>
                                        <div class="fw-semibold">@historico.TipoOperacao</div>
                                        <div class="small text-muted">@historico.DataOperacao.ToString("dd/MM/yyyy HH:mm") • @historico.UsuarioOperador</div>
                                    </div>
                                    <span class="badge bg-secondary">@historico.Status</span>
                                </div>
                                <div class="small mt-2">Crédito: R$ @historico.ValorCredito.ToString("N2") • Reposição: R$ @historico.ValorReposicao.ToString("N2") • Diferença: R$ @historico.DiferencaFinanceira.ToString("N2")</div>
                                @if (!string.IsNullOrWhiteSpace(historico.Observacoes))
                                {
                                    <div class="mt-2 text-muted">@historico.Observacoes</div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-muted">Nenhuma operação de pós-venda registrada para esta venda.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const produtos = @Html.Raw(Model.ProdutosJson);
        const servicos = @Html.Raw(Model.ServicosJson);
        const posVendaForm = document.getElementById('posVendaForm');
        const payloadJsonInput = document.getElementById('payloadJson');
        const tipoOperacaoSelect = document.getElementById('tipoOperacaoSelect');
        const trocaBox = document.getElementById('trocaBox');
        const observacoesInput = document.getElementById('observacoesInput');
        const reposicaoTipoItemSelect = document.getElementById('reposicaoTipoItemSelect');
        const reposicaoCatalogoSelect = document.getElementById('reposicaoCatalogoSelect');
        const reposicaoQuantidadeInput = document.getElementById('reposicaoQuantidadeInput');
        const reposicaoValorUnitarioInput = document.getElementById('reposicaoValorUnitarioInput');
        const addReposicaoBtn = document.getElementById('addReposicaoBtn');
        let reposicoes = [];

        function formatCurrency(value) {
            return Number(value || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
        }

        function formatQuantity(value) {
            return Math.trunc(Number(value || 0)).toLocaleString('pt-BR', { maximumFractionDigits: 0 });
        }

        function formatItemQuantity(item) {
            return item.tipoItem === 'Produto'
                ? formatQuantity(item.quantidade)
                : Number(item.quantidade || 0).toLocaleString('pt-BR', { maximumFractionDigits: 3 });
        }

        function configurarQuantidadeReposicao() {
            const catalogo = getCatalogoReposicaoAtual();
            const selecionado = catalogo.find(item => String(item.id) === String(reposicaoCatalogoSelect.value)) || catalogo[0];
            const isProduto = selecionado?.tipo === 'Produto';

            reposicaoQuantidadeInput.min = isProduto ? '1' : '0.001';
            reposicaoQuantidadeInput.step = isProduto ? '1' : '0.001';

            if (isProduto) {
                const quantidade = Number(reposicaoQuantidadeInput.value || 1);
                reposicaoQuantidadeInput.value = String(Math.max(1, Math.trunc(quantidade)));
            }
        }

        function atualizarTrocaUi() {
            const isTroca = tipoOperacaoSelect.value === '@VendaPosVendaTipo.Troca';
            trocaBox.style.display = isTroca ? '' : 'none';
            if (!isTroca) {
                reposicoes = [];
                renderReposicoes();
            }
            atualizarResumo();
        }

        function getCatalogoReposicaoAtual() {
            return reposicaoTipoItemSelect.value === 'Servico' ? servicos : produtos;
        }

        function preencherCatalogoReposicao() {
            const catalogo = getCatalogoReposicaoAtual();
            reposicaoCatalogoSelect.innerHTML = '';
            if (!catalogo.length) {
                const option = document.createElement('option');
                option.value = '';
                option.textContent = 'Nenhum item disponível';
                reposicaoCatalogoSelect.appendChild(option);
                reposicaoValorUnitarioInput.value = '0';
                return;
            }

            for (const item of catalogo) {
                const option = document.createElement('option');
                option.value = item.id;
                const detalhe = item.tipo === 'Produto' && item.controlaEstoque
                    ? ` | estoque: ${formatQuantity(item.estoqueAtual)}`
                    : '';
                option.textContent = `${item.nome} | ${formatCurrency(item.valor)}${detalhe}`;
                option.dataset.valor = item.valor;
                option.dataset.nome = item.nome;
                option.dataset.tipo = item.tipo;
                reposicaoCatalogoSelect.appendChild(option);
            }

            reposicaoValorUnitarioInput.value = Number(catalogo[0].valor || 0).toFixed(2);
            configurarQuantidadeReposicao();
        }

        function atualizarValorReposicao() {
            const selected = reposicaoCatalogoSelect.options[reposicaoCatalogoSelect.selectedIndex];
            reposicaoValorUnitarioInput.value = selected?.dataset?.valor ? Number(selected.dataset.valor).toFixed(2) : '0';
            configurarQuantidadeReposicao();
        }

        function obterItensOriginaisSelecionados() {
            const inputs = Array.from(document.querySelectorAll('.posvenda-qtd'));
            return inputs
                .filter(input => !input.disabled)
                .map(input => ({
                    idItemVenda: Number(input.dataset.itemId),
                    quantidade: Number(input.value || 0)
                }))
                .filter(item => item.quantidade > 0);
        }

        function atualizarResumo() {
            const inputs = Array.from(document.querySelectorAll('.posvenda-qtd'));
            let credito = 0;
            for (const input of inputs) {
                const row = input.closest('tr');
                const valorUnitarioTexto = row.querySelector('.small.text-muted')?.textContent || '';
                const match = valorUnitarioTexto.match(/R\$ ([0-9\.,]+)/);
                const valorUnitario = match ? Number(match[1].replace(/\./g, '').replace(',', '.')) : 0;
                credito += Number(input.value || 0) * valorUnitario;
            }

            let reposicao = 0;
            for (const item of reposicoes) {
                reposicao += Number(item.quantidade) * Number(item.valorUnitario);
            }

            const diferenca = reposicao - credito;
            document.getElementById('creditoLabel').textContent = formatCurrency(credito);
            document.getElementById('reposicaoLabel').textContent = formatCurrency(reposicao);
            document.getElementById('diferencaLabel').textContent = formatCurrency(diferenca);
        }

        function renderReposicoes() {
            const tbody = document.querySelector('#reposicaoTable tbody');
            if (!reposicoes.length) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">Nenhum item de reposição adicionado.</td></tr>';
                atualizarResumo();
                return;
            }

            let html = '';
            reposicoes.forEach((item, index) => {
                const total = Number(item.quantidade) * Number(item.valorUnitario);
                html += `
                    <tr>
                        <td><span class="badge ${item.tipoItem === 'Servico' ? 'bg-primary' : 'bg-success'}">${item.tipoItem}</span></td>
                        <td>${item.descricao}</td>
                        <td class="text-end">${formatItemQuantity(item)}</td>
                        <td class="text-end">${formatCurrency(item.valorUnitario)}</td>
                        <td class="text-end fw-semibold">${formatCurrency(total)}</td>
                        <td class="text-end"><button type="button" class="btn btn-sm btn-danger" onclick="removerReposicao(${index})">Remover</button></td>
                    </tr>
                `;
            });

            tbody.innerHTML = html;
            atualizarResumo();
        }

        window.removerReposicao = function(index) {
            reposicoes.splice(index, 1);
            renderReposicoes();
        };

        addReposicaoBtn.addEventListener('click', () => {
            const catalogo = getCatalogoReposicaoAtual();
            const idSelecionado = Number(reposicaoCatalogoSelect.value);
            const selecionado = catalogo.find(item => Number(item.id) === idSelecionado);
            const quantidade = Number(reposicaoQuantidadeInput.value || 0);
            const valorUnitario = Number(reposicaoValorUnitarioInput.value || 0);

            if (!selecionado || quantidade <= 0 || valorUnitario < 0) {
                alert('Selecione um item válido e informe quantidade maior que zero.');
                return;
            }

            if (selecionado.tipo === 'Produto' && !Number.isInteger(quantidade)) {
                alert('Informe uma quantidade inteira para produtos de estoque.');
                return;
            }

            reposicoes.push({
                tipoItem: selecionado.tipo,
                idProduto: selecionado.tipo === 'Produto' ? selecionado.id : null,
                idServico: selecionado.tipo === 'Servico' ? selecionado.id : null,
                descricao: selecionado.nome,
                quantidade,
                valorUnitario
            });

            reposicaoQuantidadeInput.value = '1';
            renderReposicoes();
        });

        posVendaForm.addEventListener('submit', (event) => {
            const itensOriginais = obterItensOriginaisSelecionados();
            if (!itensOriginais.length) {
                event.preventDefault();
                alert('Selecione ao menos um item e quantidade para processar o pós-venda.');
                return;
            }

            if (tipoOperacaoSelect.value === '@VendaPosVendaTipo.Troca' && !reposicoes.length) {
                event.preventDefault();
                alert('Adicione ao menos um item de reposição para concluir a troca.');
                return;
            }

            const payload = {
                tipoOperacao: tipoOperacaoSelect.value,
                observacoes: observacoesInput.value || null,
                itensOriginais,
                itensReposicao: reposicoes.map(item => ({
                    tipoItem: item.tipoItem,
                    idProduto: item.idProduto,
                    idServico: item.idServico,
                    quantidade: item.quantidade,
                    valorUnitario: item.valorUnitario
                }))
            };

            payloadJsonInput.value = JSON.stringify(payload);
        });

        document.querySelectorAll('.posvenda-qtd').forEach(input => input.addEventListener('input', atualizarResumo));
        tipoOperacaoSelect.addEventListener('change', atualizarTrocaUi);
        reposicaoTipoItemSelect.addEventListener('change', preencherCatalogoReposicao);
        reposicaoCatalogoSelect.addEventListener('change', atualizarValorReposicao);

        preencherCatalogoReposicao();
        atualizarTrocaUi();
        renderReposicoes();
    </script>
}
