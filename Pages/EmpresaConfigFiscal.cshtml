@page
@model CorteCor.Pages.SalaoConfigFiscalModel
@{
    ViewData["Title"] = "Configuração Fiscal";
}

<div class="container mt-4">
    <h2>Configuração Fiscal (NFC-e / NFS-e)</h2>
    <hr />

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert alert-success">@Model.Mensagem</div>
    }
    @if (!string.IsNullOrEmpty(Model.Erro))
    {
        <div class="alert alert-danger">@Model.Erro</div>
    }

    <form method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Configuracao.IdConfigFiscal" />
        <input type="hidden" asp-for="Configuracao.IdSalao" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Razão Social</label>
                <input type="text" asp-for="Configuracao.RazaoSocial" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">CNPJ</label>
                <input type="text" asp-for="Configuracao.Cnpj" class="form-control cnpj" required />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Inscrição Estadual</label>
                <input type="text" asp-for="Configuracao.InscricaoEstadual" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Inscrição Municipal</label>
                <input type="text" asp-for="Configuracao.InscricaoMunicipal" class="form-control" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Ambiente Sefaz/Prefeitura</label>
                <select asp-for="Configuracao.Ambiente" class="form-control">
                    <option value="2">Homologação (Testes)</option>
                    <option value="1">Produção (Oficial)</option>
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Regime Tributário</label>
                <select asp-for="Configuracao.RegimeTributario" class="form-control">
                    <option value="1">Simples Nacional</option>
                    <option value="2">Simples Nacional - Excesso Receita Bruta</option>
                    <option value="3">Regime Normal (Lucro Presumido/Real)</option>
                </select>
            </div>
            <div class="col-md-2 mb-3">
                <label class="form-label">Cód. UF (IBGE)</label>
                <select asp-for="Configuracao.CodigoUFIBGE" class="form-select" id="uf-select" required>
                    <option value="">Selecione...</option>
                </select>
            </div>
            <div class="col-md-2 mb-3">
                <label class="form-label">Cód. Município (IBGE)</label>
                <select asp-for="Configuracao.CodigoMunicipioIBGE" class="form-select" id="municipio-select" required>
                    <option value="">Selecione...</option>
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Regime Especial de Tributação</label>
                <select asp-for="Configuracao.RegimeEspecialTributacao" class="form-control">
                    <option value="0">Nenhum</option>
                    <option value="1">Microempresa Municipal</option>
                    <option value="2">Estimativa</option>
                    <option value="3">Sociedade de Profissionais</option>
                    <option value="4">Cooperativa</option>
                    <option value="5">Microempreendedor Individual (MEI)</option>
                    <option value="6">Microempresa ou Empresa de Pequeno Porte (ME/EPP)</option>
                </select>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">Exigibilidade do ISS</label>
                <select asp-for="Configuracao.IssExigibilidade" class="form-control">
                    <option value="1">Exigível</option>
                    <option value="2">Não incidência</option>
                    <option value="3">Isenção</option>
                    <option value="4">Exportação</option>
                    <option value="5">Imunidade</option>
                    <option value="6">Exigibilidade Suspensa por Decisão Judicial</option>
                    <option value="7">Exigibilidade Suspensa por Processo Administrativo</option>
                </select>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">ISS Retido</label>
                <select asp-for="Configuracao.IssRetido" class="form-control">
                    <option value="1">Sim</option>
                    <option value="2">Não</option>
                </select>
            </div>
        </div>

        <h4 class="mt-4">Configuração NFC-e</h4>
        <div class="card p-3 bg-light mb-4">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">CSC (Token)</label>
                    <input type="text" asp-for="Configuracao.CSC" class="form-control" placeholder="Ex: 0123456789ABCDEF..." />
                </div>
                <div class="col-md-2 mb-3">
                    <label class="form-label">ID CSC</label>
                    <input type="text" asp-for="Configuracao.IdCSC" class="form-control" placeholder="000001" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Série NFC-e</label>
                    <input type="number" asp-for="Configuracao.SerieNFCe" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Próximo Número NFC-e</label>
                    <input type="number" asp-for="Configuracao.NumeroNFCe" class="form-control" />
                </div>
            </div>
        </div>

        <h4 class="mt-4">Configuração NFS-e Nacional</h4>
        <div class="card p-3 bg-light mb-4">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Token NFS-e Nacional</label>
                    <input type="text" asp-for="Configuracao.TokenNfse" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Série NFS-e</label>
                    <input type="number" asp-for="Configuracao.SerieNFSe" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Próximo Número NFS-e</label>
                    <input type="number" asp-for="Configuracao.NumeroNFSe" class="form-control" />
                </div>
            </div>
        </div>

        <h4 class="mt-4">Endereço e Contato do Prestador (Para NFS-e)</h4>
        <div class="card p-3 bg-light mb-4">
            <div class="row">
                <div class="col-md-2 mb-3">
                    <label class="form-label">CEP</label>
                    <input type="text" asp-for="Configuracao.EnderecoCep" class="form-control cep" />
                </div>
                <div class="col-md-7 mb-3">
                    <label class="form-label">Logradouro</label>
                    <input type="text" asp-for="Configuracao.EnderecoLogradouro" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Número</label>
                    <input type="text" asp-for="Configuracao.EnderecoNumero" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Bairro</label>
                    <input type="text" asp-for="Configuracao.EnderecoBairro" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Telefone</label>
                    <input type="text" asp-for="Configuracao.Telefone" class="form-control telefone" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" asp-for="Configuracao.Email" class="form-control" />
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12 mb-3">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="emissaoAuto"
                        asp-for="Configuracao.EmissaoAutomatica">
                    <label class="form-check-label" for="emissaoAuto">
                        <strong>Emissão Automática ao Pagar</strong> <br>
                        <small class="text-muted">Gera e envia a nota fiscal automaticamente para a Sefaz/Prefeitura
                            assim que o agendamento for registrado como "Pago".</small>
                    </label>
                </div>
            </div>
        </div>

        <h4 class="mt-4">Certificado Digital (A1)</h4>
        <div class="card p-3 bg-light mb-4">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Upload do arquivo (.pfx)</label>
                    <input type="file" name="certificadoFile" class="form-control" accept=".pfx" />
                    @if (Model.PossuiCertificadoSalvo)
                    {
                        <small class="text-success fw-bold d-block mt-1">O Empresa já possui um certificado salvo. Envie outro
                            apenas para substituí-lo.</small>
                    }
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Senha do Certificado</label>
                    <input type="password" name="senhaCertificado" class="form-control" />
                </div>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary px-4">Salvar Configurações</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.cnpj').inputmask('99.999.999/9999-99');
            $('.cep').inputmask('99999-999');
            $('.telefone').inputmask('(99) 99999-9999');

            var initialUfId = '@(Model.Configuracao.CodigoUFIBGE)';
            var initialMunicipioId = '@(Model.Configuracao.CodigoMunicipioIBGE)';

            // Load States
            $.getJSON('https://servicodados.ibge.gov.br/api/v1/localidades/estados?orderBy=nome', function (data) {
                var $ufSelect = $('#uf-select');
                $.each(data, function (key, val) {
                    $ufSelect.append($('<option></option>').val(val.id).html(val.sigla));
                });
                
                if (initialUfId && initialUfId !== '0') {
                    $ufSelect.val(initialUfId);
                    carregarMunicipios(initialUfId, initialMunicipioId);
                }
            });

            // UF change event
            $('#uf-select').change(function () {
                var ufId = $(this).val();
                carregarMunicipios(ufId, null);
            });

            function carregarMunicipios(ufId, selectedMunicipioId) {
                var $municipioSelect = $('#municipio-select');
                $municipioSelect.empty().append('<option value="">Carregando...</option>');
                
                if (ufId) {
                    $.getJSON('https://servicodados.ibge.gov.br/api/v1/localidades/estados/' + ufId + '/municipios?orderBy=nome', function (data) {
                        $municipioSelect.empty().append('<option value="">Selecione...</option>');
                        $.each(data, function (key, val) {
                            $municipioSelect.append($('<option></option>').val(val.id).html(val.nome));
                        });
                        if (selectedMunicipioId && selectedMunicipioId !== '0') {
                            $municipioSelect.val(selectedMunicipioId);
                        }
                    });
                } else {
                    $municipioSelect.empty().append('<option value="">Selecione...</option>');
                }
            }
        });
    </script>
}

