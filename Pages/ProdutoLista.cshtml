@page
@model CorteCor.Pages.ProdutoListaModel

<div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h4>Lista de Produtos</h4>
        <a asp-page="/ProdutoCadastro" class="btn btn-primary">Cadastrar Novo</a>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="q" class="form-label">Buscar por nome, codigo ou tags</label>
                    <input type="text" id="q" name="q" value="@Model.q" class="form-control" placeholder="Digite sua busca">
                </div>
                <div class="col-md-3">
                    <label for="idCategoria" class="form-label">Filtrar por categoria</label>
                    <select name="idCategoria" id="idCategoria" class="form-select">
                        <option value="">-- Todas --</option>
                        @foreach (var cat in Model.Categorias)
                        {
                            var isSelected = Model.IdCategoria == cat.IdCategoria ? "selected" : "";
                            @Html.Raw($"<option value='{cat.IdCategoria}' {isSelected}>{cat.Nome}</option>")
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" id="incluirArquivados" name="incluirArquivados" value="true" @(Model.incluirArquivados ? "checked" : "")>
                        <label class="form-check-label" for="incluirArquivados">Mostrar arquivados</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert alert-@Model.MensagemTipo mt-2">
            @Model.Mensagem
        </div>
    }

    <div class="table-responsive mt-3">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Nome / Código</th>
                    <th>Categoria</th>
                    <th>Estoque</th>
                    <th>Preço de Venda</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Produtos.Items != null && Model.Produtos.Items.Any())
                {
                    foreach (var produto in Model.Produtos.Items)
                    {
                        <tr>
                            <td>
                                <strong>@produto.Nome</strong><br />
                                <small class="text-muted">Cod: @(string.IsNullOrWhiteSpace(produto.CodigoProprio) ? "-" : produto.CodigoProprio)</small>
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(produto.CategoriaNome) ? "-" : produto.CategoriaNome)</td>
                            <td>
                                @if (produto.ControlarEstoque)
                                {
                                    @produto.EstoqueAtual
                                    @if (produto.EstoqueAtual <= produto.EstoqueMinimo)
                                    {
                                        <span class="badge bg-warning text-dark" title="Estoque abaixo do minimo">Baixo</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Não controla</span>
                                }
                            </td>
                            <td>R$ @produto.PrecoVenda.ToString("0.00")</td>
                            <td>
                                @if (produto.Arquivado)
                                {
                                    <span class="badge bg-secondary">Arquivado</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                            </td>
                            <td class="actions">
                                <form method="post" style="display: inline;">
                                    <input type="hidden" name="id" value="@produto.IdProduto">
                                    <input type="hidden" name="action" value="alterar">
                                    <input type="hidden" name="idCategoria" value="@Model.IdCategoria">
                                    <input type="hidden" name="q" value="@Model.q">
                                    <input type="hidden" name="incluirArquivados" value="@Model.incluirArquivados">
                                    <input type="hidden" name="p" value="@Model.Produtos.PageIndex">
                                    <button type="submit" class="btn btn-info btn-sm">Alterar</button>
                                </form>

                                <form method="post" style="display: inline;" onsubmit="return confirm('Tem certeza que deseja inativar este produto?');">
                                    <input type="hidden" name="id" value="@produto.IdProduto">
                                    <input type="hidden" name="action" value="excluir">
                                    <input type="hidden" name="idCategoria" value="@Model.IdCategoria">
                                    <input type="hidden" name="q" value="@Model.q">
                                    <input type="hidden" name="incluirArquivados" value="@Model.incluirArquivados">
                                    <input type="hidden" name="p" value="@Model.Produtos.PageIndex">
                                    <button type="submit" class="btn btn-danger btn-sm">Inativar</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">Nenhum produto encontrado.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Produtos.TotalPages > 1)
    {
        <nav aria-label="Paginação de produtos">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Produtos.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="?p=@(Model.Produtos.PageIndex - 1)&q=@Model.q&idCategoria=@Model.IdCategoria&incluirArquivados=@Model.incluirArquivados">Anterior</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Página @Model.Produtos.PageIndex de @Model.Produtos.TotalPages</span>
                </li>
                <li class="page-item @(Model.Produtos.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="?p=@(Model.Produtos.PageIndex + 1)&q=@Model.q&idCategoria=@Model.IdCategoria&incluirArquivados=@Model.incluirArquivados">Próxima</a>
                </li>
            </ul>
        </nav>
    }
</div>
