@page 
@model LoginModel
@{
    ViewData["Title"] = @Model.NomeSalao;
}

    
    <style>
        body {
            display: block;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            font-family: Arial, sans-serif;
            padding: 30px;
        }

        .login-container {
            background: #fff;
            padding: 2rem;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
            width: 100%;
            max-width: 400px;
            margin: auto;
        }

        .login-container h3 {
            text-align: center;
            margin-bottom: 1rem;
            color: #333;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-group label {
            display: block;
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
            color: #666;
        }

        .form-group input {
            width: 100%;
            padding: 0.8rem;
            font-size: 1rem;
            border: 1px solid #ccc;
            border-radius: 6px;
        }

        .form-group input:focus {
            outline: none;
            border-color: #4e54c8;
            box-shadow: 0 0 5px rgba(78, 84, 200, 0.5);
        }

        .btn {
            display: block;
            width: 100%;
            padding: 0.8rem;
            font-size: 1rem;
            color: #fff;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.3s;
        }

        .btn:hover {
            background: #3e44b0;
        }

        .footer {
            margin-top: 1rem;
            text-align: center;
            font-size: 0.8rem;
            color: #666;
        }

        .footer a {
            color: #4e54c8;
            text-decoration: none;
        }

        .footer a:hover {
            text-decoration: underline;
        }

        .login-loading-panel {
            display: none;
            align-items: center;
            gap: .75rem;
            margin-top: 1rem;
            padding: .85rem 1rem;
            border-radius: 8px;
            background: #eef6ff;
            border: 1px solid #bfdbfe;
            color: #1e3a8a;
            font-size: .92rem;
            line-height: 1.35;
        }

        .login-loading-panel.show {
            display: flex;
        }

        .login-loading-gif {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: 4px solid #bfdbfe;
            border-top-color: #2563eb;
            animation: login-spin .8s linear infinite;
            flex: 0 0 auto;
        }

        .login-loading-panel strong {
            display: block;
            color: #172554;
            margin-bottom: .1rem;
        }

        .login-field-locked {
            background: #f1f5f9 !important;
            cursor: wait;
        }

        @@keyframes login-spin {
            to { transform: rotate(360deg); }
        }
    </style>

<div class="login-container">
    <div style="text-align: center;">
        <img src="~/img/cortecor.png" style="width:90%;margin-bottom: 20px">
    </div>
    
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Erro de Login',
                    text: '@Html.Raw(Model.ErrorMessage)',
                    confirmButtonColor: '#4e54c8'
                });
            });
        </script>
    }
    <form method="post" id="loginForm">
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" value="@Model.Email" autocomplete="username" required>
        </div>
        <div class="form-group">
            <label for="password">Senha</label>
            <input type="password" id="password" name="password" value="@(Model.PreservePassword ? Model.PasswordValue : string.Empty)" autocomplete="current-password" required>
        </div>
        <button type="submit" id="loginButton" class="btn btn-success">Entrar</button>
        <div id="loginLoadingPanel" class="login-loading-panel" role="status" aria-live="polite">
            <span class="login-loading-gif" aria-hidden="true"></span>
            <span>
                <strong>Entrando no sistema</strong>
                Estamos preparando tudo para voc&ecirc; acessar o sistema.
            </span>
        </div>
    </form>
    <div class="footer">
        <p>Esqueceu a senha? <a href="~/EsqueciSenha?t=2">Clique aqui</a></p>
    </div>
    <footer class="border-top  text-muted mt-5">
        <div style="margin: auto;width: fit-content;">
            <div class="mb-2" style="margin: auto;width: fit-content;">&copy; 2025 - Tonni Corte & Cor </div>
            <div class="mb-2" style="margin: auto;width: fit-content;">Desenvolvido por <a href="https://tonni.com.br">TONNI Tecnologia</a></div>
            <div style="margin: auto;width: fit-content;"><a href="Privacidade">Políticas de Privacidade</a></div>
            <div style="margin: auto;width: fit-content;"><a href="TermosUso">Termos de Uso</a></div><br />
            <div style="margin: auto;width: fit-content;">
                <a href="~/adm"
                   style="color: red !important;">Área do Salão de Beleza</a>
            </div>
        </div>
    </footer>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('loginForm');
        const email = document.getElementById('email');
        const password = document.getElementById('password');
        const button = document.getElementById('loginButton');
        const loadingPanel = document.getElementById('loginLoadingPanel');

        if (!form || !email || !password || !button || !loadingPanel) {
            return;
        }

        form.addEventListener('submit', function () {
            button.disabled = true;
            button.textContent = 'Entrando...';
            email.readOnly = true;
            password.readOnly = true;
            email.setAttribute('aria-disabled', 'true');
            password.setAttribute('aria-disabled', 'true');
            email.classList.add('login-field-locked');
            password.classList.add('login-field-locked');
            loadingPanel.classList.add('show');
        });
    });
</script>
