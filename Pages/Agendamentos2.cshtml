@page
@model CorteCor.Pages.Agendamentos2Model
@{
    ViewData["Title"] = "Agendamentos";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" />
    <style>
        /* ====== Corte&Cor - FullCalendar (LIGHT / legível) ====== */

        :root {
            --cc-bg: #f5f7fb;
            --cc-card: #ffffff;
            --cc-border: #e6eaf2;
            --cc-text: #111827;
            --cc-muted: #475569;
            --cc-accent: #2563eb; /* azul */
            --cc-accent-soft: rgba(37,99,235,.10);
            --cc-green: #16a34a;
            --cc-shadow: 0 10px 30px rgba(17,24,39,.08);
        }

        body {
            background: var(--cc-bg);
        }

        /* card do calendário */
        #calendar {
            max-width: 1220px;
            margin: 18px auto;
            padding: 14px;
            border-radius: 18px;
            background: var(--cc-card);
            border: 1px solid var(--cc-border);
            box-shadow: var(--cc-shadow);
        }

        .cc-modal-row {
            display: grid;
            grid-template-columns: 120px 1fr;
            gap: 10px;
            align-items: center;
            margin-bottom: 10px;
        }

        .fc {
            color: var(--cc-text) !important;
        }

            /* toolbar */
            .fc .fc-toolbar {
                gap: 10px;
                padding: 8px 8px 16px;
            }

            .fc .fc-toolbar-title {
                font-size: 1.15rem;
                font-weight: 700;
                color: var(--cc-text) !important;
            }

            /* botões */
            .fc .fc-button {
                border: 1px solid var(--cc-border) !important;
                background: #fff !important;
                color: var(--cc-text) !important;
                border-radius: 12px !important;
                padding: 8px 12px !important;
                box-shadow: none !important;
            }

                .fc .fc-button:hover {
                    background: #f8fafc !important;
                    border-color: #d8deea !important;
                }

            /* botão ativo */
            .fc .fc-button-primary:not(:disabled).fc-button-active,
            .fc .fc-button-primary:not(:disabled):active {
                background: var(--cc-accent) !important;
                border-color: var(--cc-accent) !important;
                color: #fff !important;
            }

            /* today */
            .fc .fc-today-button {
                border-color: rgba(22,163,74,.25) !important;
                background: rgba(22,163,74,.08) !important;
                color: #0f172a !important;
            }

            /* grid */
            .fc .fc-scrollgrid,
            .fc-theme-standard td,
            .fc-theme-standard th {
                border-color: var(--cc-border) !important;
            }

            /* cabeçalho dos dias */
            .fc .fc-col-header {
                background: #f1f5ff;
            }

            .fc .fc-col-header-cell-cushion {
                padding: 10px 8px !important;
                font-weight: 700;
                color: #1e3a8a !important;
                text-transform: uppercase;
                letter-spacing: .4px;
                font-size: .78rem;
            }

            /* horas */
            .fc .fc-timegrid-axis-cushion,
            .fc .fc-timegrid-slot-label-cushion {
                color: var(--cc-muted) !important;
                font-weight: 700;
                font-variant-numeric: tabular-nums;
            }

            /* linhas */
            .fc .fc-timegrid-slot-lane {
                border-bottom: 1px solid #eef2f7 !important;
            }

            .fc .fc-timegrid-slot {
                height: 1.75em;
            }

            /* hoje */
            .fc .fc-day-today {
                background: var(--cc-accent-soft) !important;
            }

            /* seleção */
            .fc .fc-highlight {
                background: rgba(37,99,235,.18) !important;
            }

            /* eventos */
            .fc .fc-event {
                border-radius: 12px !important;
                border: 1px solid rgba(37,99,235,.25) !important;
                color: var(--cc-text) !important;
            }

                .fc .fc-event .fc-event-main {
                    padding: 6px 8px !important;
                }

            .fc .fc-event-title {
                font-weight: 700;
            }

            .fc .fc-event-time {
                font-weight: 700;
                opacity: .85;
            }

            /* indicador de agora */
            .fc .fc-now-indicator-line {
                border-color: rgba(22,163,74,.9) !important;
                border-width: 2px !important;
            }

            .fc .fc-now-indicator-arrow {
                border-color: rgba(22,163,74,.9) !important;
            }

            /* seu cabeçalho roxo (mantive, mas se quiser eu harmonizo com o tema) */
            .fc th {
                background: #767dff !important;
            }

            /* botão "Semanas" como texto (não clicável) */
            .fc .fc-ccSemanas-button {
                background: transparent !important;
                border: 0 !important;
                box-shadow: none !important;
                cursor: default !important;
                padding: 0 10px !important;
                color: var(--cc-muted) !important;
                font-weight: 700 !important;
            }

            .fc .fc-ccSemanas-button:hover {
                background: transparent !important;
            }

            /* botão "Novo Agendamento" em destaque */
            .fc .fc-novoAgendamento-button {
                background: var(--cc-accent) !important;
                border-color: var(--cc-accent) !important;
                color: #fff !important;
            }

            .fc .fc-novoAgendamento-button:hover {
                background: #1d4ed8 !important;
                border-color: #1d4ed8 !important;
            }

        /* ====== Responsividade Móvel ====== */
        @@media (max-width: 768px) {
            .fc .fc-toolbar {
                flex-direction: column !important;
                gap: 15px !important;
                align-items: center !important;
            }

            .fc .fc-toolbar-chunk {
                display: flex;
                justify-content: center;
                width: 100%;
            }

            .fc .fc-toolbar-title {
                text-align: center;
                font-size: 1.1rem;
            }

            /* Garante que o grupo "Semanas" e botões nav fiquem bem no meio */
            .fc .fc-button-group {
                justify-content: center;
            }
        }

    </style>
}

<div class="container-fluid">
    <div class="d-flex align-items-center justify-content-between mt-3">
        <h3 class="mb-0">Agendamentos</h3>
    </div>

    @if (TempData["AvisoLimite"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show mt-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["AvisoLimite"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div id="calendar"></div>
</div>

<!-- Anti-forgery (necessário para POST via fetch) -->
<form method="post" id="antiForgeryForm" class="d-none">
    @Html.AntiForgeryToken()
</form>

<!-- Modal (Bootstrap 5) acionado ao clicar no calendário -->
<div class="modal fade" id="agendamentoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Novo agendamento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <div class="modal-body">
                <div class="cc-modal-row">
                    <label class="form-label mb-0">Início</label>
                    <input id="inicio" class="form-control" type="datetime-local" />
                </div>

                <div class="cc-modal-row">
                    <label class="form-label mb-0">Fim</label>
                    <input id="fim" class="form-control" type="text" readonly />
                </div>

                <div class="cc-modal-row">
                    <label class="form-label mb-0">Cliente</label>
                    <select id="idPessoa" class="form-select">
                        <option value="">Selecione...</option>
                        @foreach (var p in Model.Clientes)
                        {
                            <option value="@p.IdPessoa">@p.Nome</option>
                        }
                    </select>
                </div>


                <div class="cc-modal-row">
                    <label class="form-label mb-0">Serviço</label>
                    <select id="idServico" class="form-select">
                        <option value="">Selecione...</option>
                        @foreach (var s in Model.Servicos)
                        {
                            <option value="@s.IdServico" data-duracao-min="@((int)s.Duracao.TotalMinutes)">
                                @s.Nome
                            </option>
                        }

                    </select>
                </div>

                <div id="rowStatus" class="cc-modal-row d-none">
                    <label class="form-label mb-0">Status</label>
                    <select id="idStatus" class="form-select">
                        <option value="Agendado">Agendado</option>
                        <option value="Pago">Pago</option>
                        <option value="Pendente">Pendente</option>
                        <option value="Cancelado">Cancelado</option>
                    </select>
                </div>

                <div class="text-muted small">

                </div>
            </div>

            <div class="modal-footer">
                <input type="hidden" id="idAgendamento" value="" />
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnSalvar" class="btn btn-primary">Salvar</button>
                <button type="button" id="btnAlterar" class="btn btn-success d-none">Alterar</button>
                <button type="button" id="btnExcluir" class="btn btn-danger d-none">Excluir</button>
                <button type="button" id="btnPagar" class="btn btn-primary d-none">Pagar Agora</button>
            </div>
        </div>
    </div>
</div>



<!-- NOVO Modal (Bootstrap 5) - Novo Agendamento manual pelo botão -->
<div class="modal fade" id="agendamentoNovoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Novo agendamento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <div class="modal-body">
                <div class="cc-modal-row">
                    <label class="form-label mb-0">Início</label>
                    <!-- habilitado com calendário (date/time picker do navegador) -->
                    <input id="inicioNovo" class="form-control" type="datetime-local" />
                </div>

                <div class="cc-modal-row">
                    <label class="form-label mb-0">Fim</label>
                    <!-- habilitado com calendário (date/time picker do navegador) -->
                    <input id="fimNovo" class="form-control" type="datetime-local" readonly/>
                </div>

                <div class="cc-modal-row">
                    <label class="form-label mb-0">Cliente</label>
                    <select id="idPessoaNovo" class="form-select">
                        <option value="">Selecione...</option>
                        @foreach (var p in Model.Clientes)
                        {
                            <option value="@p.IdPessoa">@p.Nome</option>
                        }
                    </select>
                </div>

                <div class="cc-modal-row">
                    <label class="form-label mb-0">Serviço</label>
                    <select id="idServicoNovo" class="form-select">
                        <option value="">Selecione...</option>
                        @foreach (var s in Model.Servicos)
                        {
                            <option value="@s.IdServico" data-duracao-min="@((int)s.Duracao.TotalMinutes)">
                                @s.Nome
                            </option>
                        }
                    </select>
                </div>

                <div class="text-muted small">
                    Obs: escolha Início pelo calendário. Ao trocar o serviço, o sistema inclui o fim pela duração do serviço.
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnSalvarNovo" class="btn btn-primary">Salvar</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <!-- FullCalendar (global bundle) -->
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/locales-all.global.min.js"></script>

    <script>
        let calendar;
        let modal;
        let modalNovo;
        let selectionStart = null;
        let selectionEnd = null;

        function getAntiForgeryToken() {
            const input = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
            return input ? input.value : '';
        }

        function formatLocal(dt) {
            return new Intl.DateTimeFormat('pt-BR', {
                dateStyle: 'short',
                timeStyle: 'short'
            }).format(dt);
        }


        async function carregarEventos(fetchInfo, successCallback, failureCallback) {
            try {
                const url = `?handler=Events&start=${encodeURIComponent(fetchInfo.startStr)}&end=${encodeURIComponent(fetchInfo.endStr)}`;
                const resp = await fetch(url, { method: 'GET' });
                if (!resp.ok) throw new Error('Falha ao carregar eventos');
                const data = await resp.json();
                successCallback(data);
            } catch (e) {
                console.error(e);
                failureCallback(e);
            }
        }
        async function atualizarServicosDisponiveis(start, selectId, currentValue) {
            const resp = await fetch(`?handler=AvailableServices&start=${encodeURIComponent(start.toISOString())}`);
            if (!resp.ok) return;

            const services = await resp.json();
            const select = document.getElementById(selectId);
            
            // Se o serviço atual não estiver no retorno (por indisponibilidade), 
            // no modo de edição é bom manter a opção dele se quisermos apenas visualizá-lo.
            // Mas o requisito pede para "somente mostrar os disponíveis".
            
            select.innerHTML = '<option value="">Selecione...</option>';
            services.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s.id;
                opt.textContent = s.nome;
                opt.dataset.duracaoMin = s.duracaoMin;
                if (currentValue && parseInt(currentValue) === s.id) opt.selected = true;
                select.appendChild(opt);
            });
        }

        async function abrirModal(start, end) {
            selectionStart = start;
            selectionEnd = end;

            // Título dinâmico
            document.querySelector('#agendamentoModal .modal-title').textContent = 'Novo agendamento';

            document.getElementById('idAgendamento').value = '';
            document.getElementById('inicio').value = toDateTimeLocalValue(start);

            // Fetch serviços disponíveis
            await atualizarServicosDisponiveis(start, 'idServico');

            // limpa campos
            document.getElementById('idPessoa').value = '';
            document.getElementById('idServico').value = '';

            // Toggle botões
            document.getElementById('btnSalvar').classList.remove('d-none');
            document.getElementById('btnAlterar').classList.add('d-none');
            document.getElementById('btnExcluir').classList.add('d-none');

            // Status no novo agendamento
            document.getElementById('rowStatus').classList.add('d-none');
            document.getElementById('idStatus').value = 'Agendado';

            // fim passa a ser calculado pelo serviço (fallback 30min)
            recalcularFimPeloServico();

            modal.show();
        }


        function getDuracaoServicoMinutos() {
            const opt = document.querySelector('#idServico option:checked');
            const min = parseInt(opt?.dataset?.duracaoMin || '0', 10);
            // fallback: 30 min se não tiver duração válida
            return (!min || isNaN(min) || min <= 0) ? 30 : min;
        }

        function recalcularFimPeloServico() {
            if (!selectionStart) return;

            const min = getDuracaoServicoMinutos();
            selectionEnd = new Date(selectionStart.getTime() + min * 60 * 1000);
            
            // Se for datetime-local
            // document.getElementById('fim').value = toDateTimeLocalValue(selectionEnd); 
            // Mas o fim é texto readonly na modal principal? Não, é "text" readonly. 
            // Vamos manter padrao de exibicao texto para Fim, ou mudar para datetime-local readonly.
            // O original era: input type="text" readonly. formatLocal(end).
            document.getElementById('fim').value = formatLocal(selectionEnd);
        }


        async function salvarAgendamento() {
            const idPessoaStr = document.getElementById('idPessoa').value;
            const clienteTexto = document.querySelector('#idPessoa option:checked')?.textContent?.trim() || '';

            const idServicoStr = document.getElementById('idServico').value;
            const servicoTexto = document.querySelector('#idServico option:checked')?.textContent?.trim() || '';

            if (!selectionStart) return;

            // garante que o fim esteja calculado
            recalcularFimPeloServico();

            if (!idPessoaStr || !idServicoStr) {
                Swal.fire('Atenção', 'Informe Cliente e Serviço.', 'warning');
                return;
            }

            const payload = {
                start: selectionStart.toISOString(),
                idPessoa: parseInt(idPessoaStr, 10),
                idServico: parseInt(idServicoStr, 10)
            };

            const resp = await fetch('?handler=Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getAntiForgeryToken()
                },
                body: JSON.stringify(payload)
            });

            if (!resp.ok) {
                const txt = await resp.text();
                console.error(txt);
                await showError(resp, 'Erro ao salvar agendamento.');
                return;
            }

            const result = await resp.json();

            const primeiroNome = clienteTexto.split(' ')[0];
            calendar.addEvent({
                id: result.id,
                title: `${primeiroNome} - ${servicoTexto}`,
                start: selectionStart,
                end: selectionEnd,
                color: result.servicoCor
            });


            modal.hide();
        }

        async function alterarAgendamento() {
            const id = document.getElementById('idAgendamento').value;
            const idPessoaStr = document.getElementById('idPessoa').value;
            const idServicoStr = document.getElementById('idServico').value;

            if (!id || !idPessoaStr || !idServicoStr) {
                Swal.fire('Atenção', 'Dados incompletos.', 'warning');
                return;
            }

            const payload = {
                id: parseInt(id),
                idPessoa: parseInt(idPessoaStr),
                idServico: parseInt(idServicoStr),
                status: document.getElementById('idStatus').value,
                start: selectionStart.toISOString() 
            };

            const resp = await fetch('?handler=Update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getAntiForgeryToken()
                },
                body: JSON.stringify(payload)
            });

            if (resp.ok) {
                const result = await resp.json();
                const evt = calendar.getEventById(id);
                if (evt) {
                   evt.setProp('title', result.title);
                   evt.setProp('backgroundColor', result.color);
                   if (result.start) evt.setStart(result.start);
                   if (result.end) evt.setEnd(result.end);
                }
                modal.hide();
                Swal.fire('Sucesso', 'Agendamento atualizado.', 'success');
            } else {
                await showError(resp, 'Erro ao alterar agendamento.');
            }
        }

        async function excluirAgendamento() {
            const id = document.getElementById('idAgendamento').value;
            if (!id) return;

            const result = await Swal.fire({
                title: 'Excluir?',
                text: "Deseja realmente excluir este agendamento?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e53e3e',
                cancelButtonColor: '#ccc',
                confirmButtonText: 'Sim, excluir!',
                cancelButtonText: 'Cancelar'
            });

            if (!result.isConfirmed) return;

            const resp = await fetch(`?handler=Delete&id=${id}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': getAntiForgeryToken() }
            });

            if (resp.ok) {
                calendar.getEventById(id)?.remove();
                modal.hide();
                Swal.fire('Excluído', 'Agendamento removido.', 'success');
            } else {
                await showError(resp, 'Erro ao excluir.');
            }
        }

        async function iniciarPagamento() {
            const id = document.getElementById('idAgendamento').value;
            if (!id) return;

            const resp = await fetch('?handler=Pagar', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getAntiForgeryToken()
                },
                body: JSON.stringify({ idAgendamento: parseInt(id) })
            });

            if (resp.ok) {
                const data = await resp.json();
                if (data.checkoutUrl) {
                    window.open(data.checkoutUrl, '_blank');
                    modal.hide();
                    calendar.refetchEvents();
                    Swal.fire('Pagamento Iniciado', 'Aguardando confirmação do Mercado Pago.', 'info');
                }
            } else {
                await showError(resp, 'Erro ao iniciar pagamento.');
            }
        }

        /* funções do modal novo - acionado pelo botão*/
        function toDateTimeLocalValue(dt) {
            const pad = n => String(n).padStart(2, '0');
            return `${dt.getFullYear()}-${pad(dt.getMonth() + 1)}-${pad(dt.getDate())}T${pad(dt.getHours())}:${pad(dt.getMinutes())}`;
        }

        function fromDateTimeLocalValue(val) {
            // "YYYY-MM-DDTHH:mm" -> Date (local)
            return val ? new Date(val) : null;
        }

        function roundToNext30Min(dt) {
            const ms = 30 * 60 * 1000;
            return new Date(Math.ceil(dt.getTime() / ms) * ms);
        }

        function getDuracaoServicoMinutosFrom(selectId) {
            const opt = document.querySelector(`#${selectId} option:checked`);
            const min = parseInt(opt?.dataset?.duracaoMin || '0', 10);
            return (!min || isNaN(min) || min <= 0) ? 30 : min;
        }

        function sugerirFimNovoPeloServico() {
            const start = fromDateTimeLocalValue(document.getElementById('inicioNovo').value);
            if (!start) return;

            const min = getDuracaoServicoMinutosFrom('idServicoNovo');
            const end = new Date(start.getTime() + min * 60 * 1000);

            document.getElementById('fimNovo').value = toDateTimeLocalValue(end);
        }

        async function abrirModalNovoAgendamento() {
            // default: próximo bloco de 30 min
            const start = roundToNext30Min(new Date());
            document.getElementById('inicioNovo').value = toDateTimeLocalValue(start);

            // Fetch serviços disponíveis
            await atualizarServicosDisponiveis(start, 'idServicoNovo');

            // limpa selects
            document.getElementById('idPessoaNovo').value = '';
            document.getElementById('idServicoNovo').value = '';

            // sugere fim (30min fallback)
            sugerirFimNovoPeloServico();

            modalNovo.show();
        }

        async function salvarAgendamentoNovo() {
            const idPessoaStr = document.getElementById('idPessoaNovo').value;
            const clienteTexto = document.querySelector('#idPessoaNovo option:checked')?.textContent?.trim() || '';

            const idServicoStr = document.getElementById('idServicoNovo').value;
            const servicoTexto = document.querySelector('#idServicoNovo option:checked')?.textContent?.trim() || '';

            const start = fromDateTimeLocalValue(document.getElementById('inicioNovo').value);
            const end = fromDateTimeLocalValue(document.getElementById('fimNovo').value);

            if (!start || !end) {
                Swal.fire('Atenção', 'Informe Início e Fim.', 'warning');
                return;
            }

            if (end <= start) {
                Swal.fire('Atenção', 'O Fim deve ser maior que o Início.', 'warning');
                return;
            }

            if (!idPessoaStr || !idServicoStr) {
                Swal.fire('Atenção', 'Informe Cliente e Serviço.', 'warning');
                return;
            }

            const payload = {
                start: start.toISOString(),
                end: end.toISOString(),               // <-- novo (back-end aceitará)
                idPessoa: parseInt(idPessoaStr, 10),
                idServico: parseInt(idServicoStr, 10)
            };

            const resp = await fetch('?handler=Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getAntiForgeryToken()
                },
                body: JSON.stringify(payload)
            });

            if (!resp.ok) {
                const txt = await resp.text();
                console.error(txt);
                await showError(resp, 'Erro ao salvar agendamento.');
                return;
            }

            const result = await resp.json();

            const primeiroNome = clienteTexto.split(' ')[0];
            calendar.addEvent({
                id: result.id,
                title: `${primeiroNome} - ${servicoTexto}`,
                start: start,
                end: end,
                color: result.servicoCor
            });

            modalNovo.hide();
        }



        document.addEventListener('DOMContentLoaded', function () {
            modal = new bootstrap.Modal(document.getElementById('agendamentoModal'));

            const calendarEl = document.getElementById('calendar');

            calendar = new FullCalendar.Calendar(calendarEl, {
                locale: 'pt-br',
                timeZone: 'local',

                initialView: 'timeGridDay',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'timeGridWeek,timeGridDay novoAgendamento'
                },
                buttonText: {
                    today: 'Hoje',
                    week: 'Semana',
                    day: 'Dia'
                },
                customButtons: {
                    novoAgendamento: {     
                        text: 'Novo Agendamento',
                        click: abrirModalNovoAgendamento
                    }
                },

                allDaySlot: false,
                nowIndicator: true,
                slotMinTime: '07:00:00',
                slotMaxTime: '21:00:00',
                slotDuration: '00:30:00',

                slotLabelFormat: {
                    hour: '2-digit',
                    minute: '2-digit',
                    hour12: false
                },

                selectable: true,
                selectMirror: true,

                select: function (info) {
                    abrirModal(info.start, info.end);
                    calendar.unselect();
                },

                dateClick: function (info) {
                    const start = info.date;
                    const end = new Date(start.getTime() + 30 * 60 * 1000);
                    abrirModal(start, end);
                },

                events: carregarEventos,

                eventClick: async function (info) {
                    const id = info.event.id;
                    const resp = await fetch(`?handler=Details&id=${id}`);
                    if (!resp.ok) return;

                    const data = await resp.json();
                    
                    selectionStart = new Date(data.start);

                    // Título dinâmico
                    document.querySelector('#agendamentoModal .modal-title').textContent = 'Alterar Agendamento';

                    document.getElementById('idAgendamento').value = data.id;
                    document.getElementById('inicio').value = toDateTimeLocalValue(selectionStart);
                    document.getElementById('idPessoa').value = data.idPessoa;
                    
                    // Fetch serviços disponíveis para este horário antes de setar o valor
                    await atualizarServicosDisponiveis(selectionStart, 'idServico', data.idServico);
                    
                    document.getElementById('idServico').value = data.idServico;
                    
                    // Status
                    document.getElementById('rowStatus').classList.remove('d-none');
                    document.getElementById('idStatus').value = data.status;

                    recalcularFimPeloServico();

                    // Bloqueio se Pago
                    const isPago = data.status === 'Pago';
                    document.getElementById('idPessoa').disabled = isPago;
                    document.getElementById('idServico').disabled = isPago;
                    document.getElementById('idStatus').disabled = isPago;

                    // Toggle botões
                    document.getElementById('btnSalvar').classList.add('d-none');
                    
                    if (isPago) {
                        document.getElementById('btnAlterar').classList.add('d-none');
                        document.getElementById('btnExcluir').classList.add('d-none');
                        document.getElementById('btnPagar').classList.add('d-none');
                    } else {
                        document.getElementById('btnAlterar').classList.remove('d-none');
                        document.getElementById('btnExcluir').classList.remove('d-none');
                        document.getElementById('btnPagar').classList.remove('d-none');
                    }

                    modal.show();
                }
            });

            /* listeners do modal novo */
            modalNovo = new bootstrap.Modal(document.getElementById('agendamentoNovoModal'));

            document.getElementById('btnSalvarNovo').addEventListener('click', salvarAgendamentoNovo);
            document.getElementById('inicioNovo').addEventListener('change', async function() {
                const start = fromDateTimeLocalValue(this.value);
                if (start) {
                    await atualizarServicosDisponiveis(start, 'idServicoNovo');
                }
                sugerirFimNovoPeloServico();
            });
            document.getElementById('idServicoNovo').addEventListener('change', sugerirFimNovoPeloServico);

            document.getElementById('btnAlterar').addEventListener('click', alterarAgendamento);
            document.getElementById('btnExcluir').addEventListener('click', excluirAgendamento);
            document.getElementById('btnPagar').addEventListener('click', iniciarPagamento);




            calendar.render();
            document.getElementById('btnSalvar').addEventListener('click', salvarAgendamento);
            document.getElementById('idServico').addEventListener('change', recalcularFimPeloServico);

            document.getElementById('btnSalvar').addEventListener('click', salvarAgendamento);
            document.getElementById('idServico').addEventListener('change', recalcularFimPeloServico);

            // Listener para mudança de horário na edição
            document.getElementById('inicio').addEventListener('change', function() {
                const val = this.value;
                if(val) {
                    selectionStart = fromDateTimeLocalValue(val);
                    recalcularFimPeloServico();
                }
            });

        });
    </script>
}
