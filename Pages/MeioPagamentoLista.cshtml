@page
@model CorteCor.Pages.MeioPagamentoListaModel

<style>
    @@media (max-width: 768px) {
        table th:nth-child(2),
        table td:nth-child(2),
        table th:nth-child(3),
        table td:nth-child(3),
        table th:nth-child(4),
        table td:nth-child(4),
        table th:nth-child(5),
        table td:nth-child(5) {
            display: none;
        }
    }
</style>

<div class="container">
    <h4>Lista de Meios de Pagamento</h4>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert">
            @Model.Mensagem
        </div>
    }

    <table>
        <thead>
            <tr>
                <th>Nome</th>
                <th>Tipo</th>
                <th>Gateway</th>
                <th>Taxa %</th>
                <th>Taxa Fixa</th>
                <th>Parcelamento</th>
                <th>Prazo (dias)</th>
                <th>Ativo</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var Meio in Model.MeiosPagamento)
            {
                <tr>
                    <td>@Meio.Nome</td>
                    <td>@Meio.Tipo</td>
                    <td>@Meio.Gateway</td>
                    <td>@Meio.TaxaPercentual.ToString("0.###")</td>
                    <td>R$ @Meio.TaxaFixa.ToString("0.00")</td>
                    <td>
                        @(Meio.PermiteParcelamento
                            ? $"Sim ({(Meio.ParcelasMax.HasValue ? Meio.ParcelasMax.Value.ToString() : "-")}x)"
                            : "Não")
                    </td>
                    <td>@Meio.PrazoRecebimentoDias</td>
                    <td>@(Meio.Ativo ? "Sim" : "Não")</td>
                    <td class="actions">
                        <form method="post" style="display: inline;">
                            <input type="hidden" name="id" value="@Meio.IdMeioPagamento">
                            <input type="hidden" name="action" value="alterar">
                            <button class="btn btn-info">Alterar</button>
                        </form>

                        <form method="post" style="display: inline;">
                            <input type="hidden" name="id" value="@Meio.IdMeioPagamento">
                            <input type="hidden" name="action" value="ativar">
                            <button class="btn btn-success">Ativar</button>
                        </form>

                        <form method="post" style="display: inline;">
                            <input type="hidden" name="id" value="@Meio.IdMeioPagamento">
                            <input type="hidden" name="action" value="desativar">
                            <button class="btn btn-warning">Desativar</button>
                        </form>

                        <form method="post" style="display: inline;" onsubmit="return confirm('Tem certeza que deseja excluir este Meio de Pagamento?');">
                            <input type="hidden" name="id" value="@Meio.IdMeioPagamento">
                            <input type="hidden" name="action" value="excluir">
                            <button class="btn btn-danger">Excluir</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
