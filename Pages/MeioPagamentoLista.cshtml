@page
@model CorteCor.Pages.MeioPagamentoListaModel



<div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h4>Lista de Meios de Pagamento</h4>
        <a asp-page="/MeioPagamentoCadastro" class="btn btn-primary">Cadastrar Novo</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert">
            @Model.Mensagem
        </div>
    }

    <table>
        <thead>
            <tr>
                <th>Nome</th>
                <th>Tipo</th>
                <th>Gateway</th>
                <th>Taxa %</th>
                <th>Taxa Fixa</th>
                <th class="d-none d-md-table-cell">Parcelamento</th>
                <th>Prazo (dias)</th>
                <th>Ativo</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var Meio in Model.MeiosPagamento)
            {
                <tr>
                    <td>@Meio.Nome</td>
                    <td>@Meio.Tipo</td>
                    <td>@Meio.Gateway</td>
                    <td>@Meio.TaxaPercentual.ToString("0.###")</td>
                    <td>R$ @Meio.TaxaFixa.ToString("0.00")</td>
                    <td class="d-none d-md-table-cell">
                        @(Meio.PermiteParcelamento
                            ? $"Sim ({(Meio.ParcelasMax.HasValue ? Meio.ParcelasMax.Value.ToString() : "-")}x)"
                            : "Não")
                    </td>
                    <td>@Meio.PrazoRecebimentoDias</td>
                    <td>@(Meio.Ativo ? "Sim" : "Não")</td>
                    <td class="actions">
                        <a asp-page="/MeioPagamentoCadastro" asp-route-id="@Meio.IdMeioPagamento" class="btn btn-info">Alterar</a>

                        <form method="post" style="display: inline;">
                            <input type="hidden" name="id" value="@Meio.IdMeioPagamento">
                            <input type="hidden" name="action" value="ativar">
                            <button class="btn btn-success">Ativar</button>
                        </form>

                        <form method="post" style="display: inline;">
                            <input type="hidden" name="id" value="@Meio.IdMeioPagamento">
                            <input type="hidden" name="action" value="desativar">
                            <button class="btn btn-warning">Desativar</button>
                        </form>

                        <form method="post" style="display: inline;"
                            onsubmit="return confirm('Tem certeza que deseja excluir este Meio de Pagamento?');">
                            <input type="hidden" name="id" value="@Meio.IdMeioPagamento">
                            <input type="hidden" name="action" value="excluir">
                            <button class="btn btn-danger">Excluir</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
