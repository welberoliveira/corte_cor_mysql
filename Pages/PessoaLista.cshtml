@page
@model CorteCor.Pages.PessoaListaModel
@{
    ViewData["Title"] = "Pessoas";
}

<div class="row">
    <div class="col-md-10">
        <h2>@ViewData["Title"]</h2>
    </div>
    <div class="col-md-2">
        <a class="btn btn-primary pull-right" asp-page="/PessoaCadastro">Nova Pessoa</a>
    </div>
</div>
<br />

@if (!string.IsNullOrEmpty(Model.Mensagem))
{
    <div class="alert alert-info">@Model.Mensagem</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Telefone</th>
                <th>Email</th>
                <th>Data Nascimento</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var Pessoa in Model.Pessoas.Items)
            {
                <tr>
                    <td>@Pessoa.Nome</td>
                    <td>@Pessoa.Telefone</td>
                    <td>@Pessoa.Email</td>
                    <td>@(Pessoa.DataNascimento.HasValue ? Pessoa.DataNascimento.Value.ToShortDateString() : "")</td>
                    <td class="actions">
                        <form method="post" style="display: inline;">
                            <button name="id" value="@Pessoa.IdPessoa" class="btn btn-info" type="submit"
                                formaction="?handler=Alterar">Alterar</button>
                            <input type="hidden" name="action" value="alterar">
                        </form>

                        <form method="post" style="display: inline;"
                            onsubmit="return confirm('Tem certeza que deseja excluir esta Pessoa?');">
                            <input type="hidden" name="id" value="@Pessoa.IdPessoa">
                            <input type="hidden" name="action" value="excluir">
                            <button class="btn btn-danger">Excluir</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination Controls -->
@if (Model.Pessoas.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Pessoas.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="?p=@(Model.Pessoas.PageIndex - 1)" tabindex="-1">Anterior</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">Página @Model.Pessoas.PageIndex de @Model.Pessoas.TotalPages</span>
            </li>
            <li class="page-item @(Model.Pessoas.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="?p=@(Model.Pessoas.PageIndex + 1)">Próxima</a>
            </li>
        </ul>
    </nav>
}

<style>
    .actions form {
        display: inline-block;
        margin-right: 5px;
    }
</style>
