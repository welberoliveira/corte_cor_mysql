                                    <li><hr class="dropdown-divider"></li>

                                    <li><a class="dropdown-item" asp-area="" asp-page="/ModeloEmailLista">Modelo de e-mail</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-page="/ModeloSMSLista">Modelo de SMS</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-page="/LembreteConfigLista">Regras de Lembretes</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-page="/Relatorios/LogEmail">Log de Envios e-mails/SMS/Whatsapp</a></li>
