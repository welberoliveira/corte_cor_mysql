<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CorteCor.styles.css" asp-append-version="true" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <link href="~/css/site2.css" rel="stylesheet" />
    <!-- Adicionando jQuery (se ainda não estiver incluído) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

    <!-- Adicionando jQuery InputMask -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.inputmask/5.0.8/jquery.inputmask.min.js"></script>

    <!--Scripts para DayPilot: https://www.daypilot.org/-->
    <script src="~/js/daypilot/daypilot-all.min.js"></script>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @RenderSection("Styles", required: false)

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background: #f3f4f6;
        }

        .container {
            max-width: 1200px;
            margin: 0.3rem auto;
            padding: 0.3rem;
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }

        h1, h2, h3, h4, h5, h6 {
            text-align: center;
            color: #333;
            margin-bottom: 1.5rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-group label {
            display: block;
            font-size: 0.9rem;
            margin-bottom: 0.0rem;
        }

        .form-group input {
            width: 100%;
            padding: 0.8rem;
            font-size: 1rem;
            border: 1px solid #ccc;
            border-radius: 6px;
        }

        .form-check-input {
            max-width: 40px;
        }

        .alert {
            padding: 1rem;
            margin-bottom: 1.5rem;
            border-radius: 8px;
            background-color: #e7f9ed;
            color: #276749;
            border: 1px solid #c6f6d5;
            text-align: center;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
            font-size: 0.9rem;
            background: white;
            border-radius: 12px;
            overflow: hidden;
        }

            .table thead th, table th {
                background-color: #0d6efd !important;
                color: #ffffff !important;
                text-transform: uppercase;
                font-weight: bold;
                padding: 0.75rem 1rem;
                text-align: left;
                border: none;
            }

            table td {
                padding: 0.4rem;
                border-bottom: 1px solid #ddd;
                color: #555;
            }

            /* Badge Pills Global Styles */
            .badge-pill {
                padding: 0.4em 0.8em;
                font-weight: 500;
                border-radius: 9999px;
                color: #fff !important;
                display: inline-block;
            }
            .badge-success { background-color: #10b981 !important; }
            .badge-danger { background-color: #ef4444 !important; }
            .badge-warning { background-color: #f59e0b !important; }
            .badge-secondary { background-color: #6b7280 !important; }
            .badge-info { background-color: #3b82f6 !important; }

            table tr:nth-child(even) {
                background: #f9f9f9;
            }

            table tr:hover {
                background: #f1f5ff;
            }

        .actions {
            display: flex;
            gap: 0.5rem;
        }

        .btn {
            padding: 0.5rem 1rem;
            font-size: 0.8rem;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.3s;
            min-width: 78px;
        }

        .btn-info {
            background: #2d89ef;
        }

            .btn-info:hover {
                background: #1a6ede;
            }

        .btn-success {
            background: #38a169;
        }

            .btn-success:hover {
                background: #2f855a;
            }

        .btn-warning {
            background: #dd6b20;
        }

            .btn-warning:hover {
                background: #c05621;
            }

        .btn-danger {
            background: #e53e3e;
        }

        .btn-danger:hover {
            background: #c53030;
        }

        form.mb-3 {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
        }

            form.mb-3 label {
                font-size: 1rem;
                font-weight: bold;
                color: #333;
            }

            form.mb-3 select {
                padding: 0.5rem 1rem;
                font-size: 1rem;
                border: 1px solid #ccc;
                border-radius: 8px;
                outline: none;
                transition: border-color 0.3s, box-shadow 0.3s;
                background-color: #fff;
                color: #333;
                cursor: pointer;
            }

                form.mb-3 select:focus {
                    border-color: #4e54c8;
                    box-shadow: 0 0 8px rgba(78, 84, 200, 0.5);
                }

            .actions {
                display: flex;
                flex-wrap: wrap; /* Permite que os botões quebrem para a próxima linha */
                gap: 0.5rem; /* Espaço entre os botões */
            }

                .actions button {
                    flex: 1 1 calc(50% - 0.5rem); /* Botões ocupam 50% da largura menos o espaço entre eles */
                    margin-bottom: 0.5rem; /* Espaço inferior para organizar a disposição */
                }
        }

    }
    </style>

</head>
<body>
