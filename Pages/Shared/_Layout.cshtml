                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        }
    </header>
    <div class="container">
        <main role="main" class="pb-3 pt-3">
            @RenderBody()
        </main>
    </div>
    @if (!(ViewData["HideMenu"]?.ToString() == "true"))
    {
        <footer class="border-top  text-muted mt-5">
            <div style="margin: auto;width: fit-content;">
                <div class="mb-2" style="margin: auto;width: fit-content;">&copy; 2025 - Tonni Corte & Cor </div>
                <div class="mb-2" style="margin: auto;width: fit-content;">Desenvolvido por <a href="https://tonni.com.br">TONNI Tecnologia</a></div>
            </div>
        </footer>
    }

    <script>
        // ---- Global Error Handling Helper
        // ---- Global Error Handling Helper
        async function showError(resp, defaultMsg) {
            let msg = defaultMsg;
            let detail = '';

            try {
                // Clone the response so we can read it twice if needed (json then text)
                const clone = resp.clone();
                
                try {
                    const errorData = await clone.json();
                    // Handle both camelCase and PascalCase
                    msg = errorData.message || errorData.Message || defaultMsg;
                    detail = errorData.detail || errorData.Detail || '';
                } catch (eJson) {
                    // Not JSON, try text
                    msg = await resp.text() || defaultMsg;
                }
            } catch (e) {
                console.error("Erro ao processar resposta de erro:", e);
            }

            await Swal.fire({
                icon: 'error',
                title: 'Oops...',
                text: msg,
                footer: detail ? `<div style="color: #721c24; background-color: #f8d7da; border-color: #f5c6cb; padding: .75rem 1.25rem; border: 1px solid transparent; border-radius: .25rem; font-size: 0.8em; text-align: left; max-height: 200px; overflow: auto;"><b>Detalhe Técnico:</b> ${detail}</div>` : null,
                confirmButtonColor: '#3085d6'
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)


</body>
</html>

