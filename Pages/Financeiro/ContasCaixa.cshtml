@page
@model CorteCor.Pages.Financeiro.ContasCaixaModel
@{
    ViewData["Title"] = "Contas Caixa";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <h2 class="mb-1">Contas Caixa e Bancos</h2>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-page="/Financeiro/ContaCaixaCadastro">Nova Conta</a>
        <a class="btn btn-secondary" asp-page="/Financeiro/Index">Voltar ao financeiro</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-@(Model.FlashType ?? "info")">@Model.FlashMessage</div>
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white fw-semibold">Contas cadastradas</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Tipo</th>
                        <th>Banco</th>
                        <th class="text-end">Saldo inicial</th>
                        <th>Status</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var conta in Model.Contas)
                    {
                        <tr>
                            <td>@conta.Nome</td>
                            <td>@conta.Tipo</td>
                            <td>@(string.IsNullOrWhiteSpace(conta.Banco) ? "-" : conta.Banco)</td>
                            <td class="text-end">R$ @conta.SaldoInicial.ToString("N2")</td>
                            <td><span class="badge @(conta.Ativo ? "bg-success" : "bg-secondary")">@(conta.Ativo ? "Ativa" : "Inativa")</span></td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-primary" asp-page="/Financeiro/ContaCaixaCadastro" asp-route-id="@conta.IdConta">Editar</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Contas.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Nenhuma conta cadastrada.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
