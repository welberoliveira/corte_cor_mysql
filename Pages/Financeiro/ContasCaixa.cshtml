@page
@model CorteCor.Pages.Financeiro.ContasCaixaModel
@{
    ViewData["Title"] = "Contas Caixa";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <h2 class="mb-1">Contas Caixa e Bancos</h2>
        <div class="text-muted">Base para saldo inicial, conciliação e visão projetada de caixa.</div>
    </div>
    <a class="btn btn-outline-primary" asp-page="/Financeiro/Index">Voltar ao financeiro</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-@(Model.FlashType ?? "info")">@Model.FlashMessage</div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-semibold">@(Model.ContaInput.IdConta > 0 ? "Editar conta" : "Nova conta")</div>
            <div class="card-body">
                <form method="post" asp-page-handler="Salvar" class="row g-3">
                    <input type="hidden" asp-for="ContaInput.IdConta" />
                    <div class="col-12">
                        <label class="form-label">Nome</label>
                        <input class="form-control" asp-for="ContaInput.Nome" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Tipo</label>
                        <select class="form-select" asp-for="ContaInput.Tipo">
                            <option value="Caixa">Caixa</option>
                            <option value="Banco">Banco</option>
                            <option value="Carteira">Carteira</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Saldo inicial</label>
                        <input type="number" class="form-control" asp-for="ContaInput.SaldoInicial" step="0.01" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Banco</label>
                        <input class="form-control" asp-for="ContaInput.Banco" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Agência</label>
                        <input class="form-control" asp-for="ContaInput.Agencia" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Conta</label>
                        <input class="form-control" asp-for="ContaInput.Conta" />
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="ContaInput.Ativo" />
                            <label class="form-check-label" asp-for="ContaInput.Ativo">Ativa</label>
                        </div>
                    </div>
                    <div class="col-12 text-end">
                        <button class="btn btn-primary" type="submit">Salvar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-semibold">Contas cadastradas</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Tipo</th>
                                <th>Banco</th>
                                <th class="text-end">Saldo inicial</th>
                                <th>Status</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var conta in Model.Contas)
                            {
                                <tr>
                                    <td>@conta.Nome</td>
                                    <td>@conta.Tipo</td>
                                    <td>@(string.IsNullOrWhiteSpace(conta.Banco) ? "-" : conta.Banco)</td>
                                    <td class="text-end">R$ @conta.SaldoInicial.ToString("N2")</td>
                                    <td><span class="badge @(conta.Ativo ? "bg-success" : "bg-secondary")">@(conta.Ativo ? "Ativa" : "Inativa")</span></td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary" asp-page="/Financeiro/ContasCaixa" asp-route-id="@conta.IdConta">Editar</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

