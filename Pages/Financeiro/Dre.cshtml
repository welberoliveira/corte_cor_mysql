@page
@model CorteCor.Pages.Financeiro.DreModel
@{
    ViewData["Title"] = "DRE";
    var receitaBase = Model.Dre.ReceitaLiquida == 0 ? Model.Dre.LucroBruto : Model.Dre.ReceitaLiquida;
}

<style>
    .dre-table th,
    .dre-table td {
        white-space: nowrap;
    }

    .dre-table td:first-child,
    .dre-table th:first-child {
        white-space: normal;
        min-width: 320px;
    }

    .dre-grupo td {
        background: #f8fafc;
        font-weight: 700;
    }

    .dre-subtotal td {
        border-top: 2px solid #cbd5e1;
        background: #eef2ff;
        font-weight: 700;
    }

    .dre-final td {
        border-top: 2px solid #1d4ed8;
        background: #dbeafe;
        color: #0f172a;
        font-weight: 800;
    }

    .dre-indent-1 {
        display: inline-block;
        padding-left: 1.5rem;
        color: #475569;
    }
</style>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <h2 class="mb-1">DRE</h2>
        <div class="text-muted">Demonstração do Resultado do Exercício por competência contábil.</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-secondary" asp-page="/Financeiro/Relatorios">Relatórios</a>
        <a class="btn btn-secondary" asp-page="/Financeiro/Index">Dashboard</a>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white fw-semibold">Filtro</div>
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label" for="TipoPeriodo">Tipo de DRE</label>
                <select class="form-select" id="TipoPeriodo" name="TipoPeriodo">
                    <option value="Mensal" selected="@(Model.TipoPeriodo == "Mensal")">Mensal</option>
                    <option value="Anual" selected="@(Model.TipoPeriodo == "Anual")">Anual</option>
                </select>
            </div>
            <div class="col-md-3" id="FiltroMes">
                <label class="form-label" for="Mes">Mês</label>
                <select class="form-select" id="Mes" name="Mes">
                    @for (var mes = 1; mes <= 12; mes++)
                    {
                        <option value="@mes" selected="@(Model.Mes == mes)">@Model.NomeMesCompleto(mes)</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" for="Ano">Ano</label>
                <select class="form-select" id="Ano" name="Ano">
                    @foreach (var ano in Model.AnosDisponiveis)
                    {
                        <option value="@ano" selected="@(Model.Ano == ano)">@ano</option>
                    }
                </select>
            </div>
            <div class="col-md-3 text-md-end">
                <button class="btn btn-primary" type="submit">Gerar DRE</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="small text-muted">Receita líquida</div>
                <div class="fs-4 fw-bold @(Model.Dre.ReceitaLiquida >= 0 ? "text-success" : "text-danger")">@Model.FormatarMoeda(Model.Dre.ReceitaLiquida)</div>
                <div class="small text-muted">@Model.PeriodoSelecionado()</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="small text-muted">Lucro bruto</div>
                <div class="fs-4 fw-bold @(Model.Dre.LucroBruto >= 0 ? "text-primary" : "text-danger")">@Model.FormatarMoeda(Model.Dre.LucroBruto)</div>
                <div class="small text-muted">Margem: @Model.FormatarPercentual(Model.Dre.LucroBruto, receitaBase)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="small text-muted">Resultado operacional</div>
                <div class="fs-4 fw-bold @(Model.Dre.ResultadoOperacional >= 0 ? "text-primary" : "text-danger")">@Model.FormatarMoeda(Model.Dre.ResultadoOperacional)</div>
                <div class="small text-muted">Antes do resultado financeiro</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="small text-muted">Resultado líquido</div>
                <div class="fs-4 fw-bold @(Model.Dre.ResultadoLiquido >= 0 ? "text-success" : "text-danger")">@Model.FormatarMoeda(Model.Dre.ResultadoLiquido)</div>
                <div class="small text-muted">Margem: @Model.FormatarPercentual(Model.Dre.ResultadoLiquido, receitaBase)</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <span class="fw-semibold">DRE @Model.TipoPeriodo - @Model.PeriodoSelecionado()</span>
            <span class="text-muted small d-block">Base: lançamentos por competência, exceto cancelados</span>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-sm btn-success"
               asp-page-handler="ExportExcel"
               asp-route-TipoPeriodo="@Model.TipoPeriodo"
               asp-route-Mes="@Model.Mes"
               asp-route-Ano="@Model.Ano">Exportar Excel</a>
            <a class="btn btn-sm btn-danger"
               asp-page-handler="ExportPdf"
               asp-route-TipoPeriodo="@Model.TipoPeriodo"
               asp-route-Mes="@Model.Mes"
               asp-route-Ano="@Model.Ano"
               target="_blank">Exportar PDF</a>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle dre-table">
                <thead>
                    <tr>
                        <th>Conta contábil / linha do DRE</th>
                        @if (Model.TipoPeriodo == "Anual")
                        {
                            @foreach (var mes in Model.Dre.Meses)
                            {
                                <th class="text-end">@Model.NomeMes(mes)</th>
                            }
                        }
                        else
                        {
                            <th class="text-end">@Model.NomeMes(Model.Mes)</th>
                        }
                        @if (Model.TipoPeriodo == "Anual")
                        {
                            <th class="text-end">Total</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var linha in Model.Dre.Linhas)
                    {
                        <tr class="@Model.ClasseLinha(linha)">
                            <td><span class="dre-indent-@linha.Nivel">@linha.Descricao</span></td>
                            @if (Model.TipoPeriodo == "Anual")
                            {
                                @foreach (var mes in Model.Dre.Meses)
                                {
                                    var valorMes = linha.ObterValor(mes);
                                    <td class="text-end @Model.ClasseValor(valorMes)">@Model.FormatarMoeda(valorMes)</td>
                                }
                            }
                            else
                            {
                                var valorMes = linha.ObterValor(Model.Mes);
                                <td class="text-end @Model.ClasseValor(valorMes)">@Model.FormatarMoeda(valorMes)</td>
                            }
                            @if (Model.TipoPeriodo == "Anual")
                            {
                                <td class="text-end @Model.ClasseValor(linha.Total)">@Model.FormatarMoeda(linha.Total)</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const tipoPeriodo = document.getElementById('TipoPeriodo');
        const filtroMes = document.getElementById('FiltroMes');

        function atualizarFiltroMes() {
            filtroMes.classList.toggle('d-none', tipoPeriodo.value === 'Anual');
        }

        tipoPeriodo.addEventListener('change', atualizarFiltroMes);
        atualizarFiltroMes();
    </script>
}
