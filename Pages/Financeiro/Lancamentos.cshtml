@page
@using CorteCor.Models
@model CorteCor.Pages.Financeiro.LancamentosModel
@{
    ViewData["Title"] = "Lançamentos Financeiros";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <h2 class="mb-1">Contas a pagar e a receber</h2>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-page="/Financeiro/LancamentoCadastro">Novo Lançamento</a>
        <a class="btn btn-secondary" asp-page="/Financeiro/Index">Dashboard</a>
        <a class="btn btn-dark" asp-page="/Financeiro/Relatorios">Relatórios</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-@(Model.FlashType ?? "info")">@Model.FlashMessage</div>
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white fw-semibold">Filtros</div>
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Tipo</label>
                <select class="form-select" name="Tipo" id="FiltroTipoTitulo">
                    <option value="">Todos</option>
                    <option value="Receber" selected="@(Model.Tipo == "Receber")">Receber</option>
                    <option value="Pagar" selected="@(Model.Tipo == "Pagar")">Pagar</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select class="form-select" name="Status">
                    <option value="">Todos</option>
                    <option value="Aberto" selected="@(Model.Status == "Aberto")">Aberto</option>
                    <option value="Vencido" selected="@(Model.Status == "Vencido")">Vencido</option>
                    <option value="Liquidado" selected="@(Model.Status == "Liquidado")">Liquidado</option>
                    <option value="Cancelado" selected="@(Model.Status == "Cancelado")">Cancelado</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Recorr&ecirc;ncia</label>
                <select class="form-select" name="Recorrencia">
                    <option value="">Todas</option>
                    <option value="@RecorrenciaTipo.Nenhuma" selected="@(Model.Recorrencia == RecorrenciaTipo.Nenhuma)">Nenhuma</option>
                    <option value="@RecorrenciaTipo.Mensal" selected="@(Model.Recorrencia == RecorrenciaTipo.Mensal)">Mensal</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Data início</label>
                <input type="date" class="form-control" name="DataInicio" value="@Model.DataInicio?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Data fim</label>
                <input type="date" class="form-control" name="DataFim" value="@Model.DataFim?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Grupo do Plano de Contas</label>
                <select class="form-select" name="IdGrupoPlano" id="FiltroGrupoPlanoContaId" data-smart-select data-smart-placeholder="Digite para pesquisar grupo...">
                    <option value="">Todos</option>
                    @foreach (var grupo in Model.GruposPlano)
                    {
                        <option value="@grupo.IdPlano" selected="@(Model.IdGrupoPlano == grupo.IdPlano)">@grupo.Codigo - @grupo.NomeExibicao</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Conta</label>
                <select class="form-select" name="IdPlano" id="FiltroPlanoContaId" data-smart-select data-smart-placeholder="Digite para pesquisar conta...">
                    <option value="">Todas</option>
                    @foreach (var plano in Model.ContasPlano)
                    {
                        <option value="@plano.IdPlano" selected="@(Model.IdPlano == plano.IdPlano)">@plano.Codigo - @plano.NomeExibicao</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Conta caixa</label>
                <select class="form-select" name="IdConta">
                    <option value="">Todas</option>
                    @foreach (var conta in Model.Contas)
                    {
                        <option value="@conta.IdConta" selected="@(Model.IdConta == conta.IdConta)">@conta.Nome</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Pesquisa</label>
                <input class="form-control" name="Pesquisa" value="@Model.Pesquisa" placeholder="Descrição, pessoa ou documento" />
            </div>
            <div class="col-md-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="SomenteVencidos" name="SomenteVencidos" value="true" checked="@Model.SomenteVencidos" />
                    <label class="form-check-label" for="SomenteVencidos">Somente vencidos</label>
                </div>
            </div>
            <div class="col-md-8 text-md-end">
                <button class="btn btn-primary" type="submit">Filtrar</button>
                <a class="btn btn-secondary" asp-page="/Financeiro/Lancamentos">Limpar</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const grupoSelect = document.getElementById('FiltroGrupoPlanoContaId');
        const contaSelect = document.getElementById('FiltroPlanoContaId');
        const tipoSelect = document.getElementById('FiltroTipoTitulo');

        if (!grupoSelect || !contaSelect || !tipoSelect) {
            return;
        }

        function tipoAtual() {
            return tipoSelect.value || '';
        }

        function limparContas() {
            contaSelect.innerHTML = '<option value="">Todas</option>';
            contaSelect.disabled = true;
        }

        async function carregarGrupos(tipo) {
            grupoSelect.innerHTML = '<option value="">Todos</option>';
            grupoSelect.disabled = true;
            limparContas();

            const response = await fetch(`${window.location.pathname}?handler=GruposPlano&tipo=${encodeURIComponent(tipo || '')}`, {
                headers: { 'Accept': 'application/json' }
            });

            if (!response.ok) {
                grupoSelect.innerHTML = '<option value="">Nao foi possivel carregar os grupos</option>';
                return;
            }

            const grupos = await response.json();
            grupos.forEach(function (grupo) {
                const option = document.createElement('option');
                option.value = grupo.id;
                option.textContent = grupo.rotulo;
                grupoSelect.appendChild(option);
            });

            grupoSelect.disabled = false;
        }

        async function carregarContas(idGrupo) {
            contaSelect.innerHTML = '<option value="">Todas</option>';
            contaSelect.disabled = !idGrupo;

            if (!idGrupo) {
                return;
            }

            const response = await fetch(`${window.location.pathname}?handler=ContasFilhas&idGrupo=${encodeURIComponent(idGrupo)}&tipo=${encodeURIComponent(tipoAtual())}`, {
                headers: { 'Accept': 'application/json' }
            });

            if (!response.ok) {
                contaSelect.innerHTML = '<option value="">Nao foi possivel carregar as contas</option>';
                return;
            }

            const contas = await response.json();
            contas.forEach(function (conta) {
                const option = document.createElement('option');
                option.value = conta.id;
                option.textContent = conta.rotulo;
                contaSelect.appendChild(option);
            });
        }

        grupoSelect.addEventListener('change', function () {
            carregarContas(grupoSelect.value);
        });

        tipoSelect.addEventListener('change', function () {
            carregarGrupos(tipoAtual());
        });

        contaSelect.disabled = !grupoSelect.value;
    });
</script>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white fw-semibold">Lançamentos</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Descrição</th>
                        <th>Pessoa</th>
                        <th>Vencimento</th>
                        <th>Status</th>
                        <th class="text-end">Valor</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Titulos.Items)
                    {
                        <tr>
                            <td><span class="badge @(item.Tipo == "Receber" ? "bg-success" : "bg-danger")">@item.Tipo</span></td>
                            <td>
                                <div class="fw-semibold">@item.Descricao</div>
                                <div class="small text-muted">@item.NomePlano</div>
                                @if (item.Recorrencia == RecorrenciaTipo.Mensal)
                                {
                                    <span class="badge bg-info text-dark">Mensal</span>
                                }
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(item.NomePessoa) ? "-" : item.NomePessoa)</td>
                            <td>@item.DataVencimento.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge @(item.Status == "Liquidado" ? "bg-primary" : item.Status == "Cancelado" ? "bg-secondary" : item.Status == "Vencido" ? "bg-danger" : "bg-warning text-dark")">@item.Status</span>
                                @if (item.Conciliado)
                                {
                                    <span class="badge bg-dark">Conciliado</span>
                                }
                            </td>
                            <td class="text-end fw-semibold">R$ @(item.Status == "Liquidado" ? item.ValorLiquidado.ToString("N2") : item.ValorAberto.ToString("N2"))</td>
                            <td class="text-end">
                                <div class="d-flex flex-wrap justify-content-end gap-1">
                                    <a class="btn btn-sm btn-primary" asp-page="/Financeiro/LancamentoCadastro" asp-route-idTitulo="@item.IdTitulo">Editar</a>
                                    @if (item.Status != "Liquidado" && item.Status != "Cancelado")
                                    {
                                        <form method="post" asp-page-handler="Liquidar" class="d-inline">
                                            <input type="hidden" name="id" value="@item.IdTitulo" />
                                            <input type="hidden" name="valorLiquidado" value="@item.ValorOriginal" />
                                            <input type="hidden" name="dataLiquidacao" value="@DateTime.Now.ToString("s")" />
                                            <input type="hidden" name="conciliado" value="true" />
                                            <button class="btn btn-sm btn-success" type="submit">Liquidar</button>
                                        </form>
                                    }
                                    @if (item.Status == "Liquidado")
                                    {
                                        <form method="post" asp-page-handler="Reabrir" class="d-inline">
                                            <input type="hidden" name="id" value="@item.IdTitulo" />
                                            <button class="btn btn-sm btn-warning" type="submit">Reabrir</button>
                                        </form>
                                    }
                                    @if (item.Status != "Cancelado")
                                    {
                                        <form method="post" asp-page-handler="Cancelar" class="d-inline">
                                            <input type="hidden" name="id" value="@item.IdTitulo" />
                                            <button class="btn btn-sm btn-danger" type="submit">Cancelar</button>
                                        </form>
                                    }
                                    <form method="post" asp-page-handler="Conciliar" class="d-inline">
                                        <input type="hidden" name="id" value="@item.IdTitulo" />
                                        <input type="hidden" name="conciliado" value="@(!item.Conciliado)" />
                                        <button class="btn btn-sm btn-dark" type="submit">@(item.Conciliado ? "Desconciliar" : "Conciliar")</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Titulos.Items.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">Nenhum lançamento encontrado.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Titulos.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.Titulos.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Titulos.PageIndex ? "active" : "")">
                            <a class="page-link" asp-page="/Financeiro/Lancamentos" asp-route-p="@i" asp-route-Tipo="@Model.Tipo" asp-route-Status="@Model.Status" asp-route-Recorrencia="@Model.Recorrencia" asp-route-Pesquisa="@Model.Pesquisa" asp-route-IdGrupoPlano="@Model.IdGrupoPlano" asp-route-IdPlano="@Model.IdPlano" asp-route-IdConta="@Model.IdConta" asp-route-DataInicio="@Model.DataInicio?.ToString("yyyy-MM-dd")" asp-route-DataFim="@Model.DataFim?.ToString("yyyy-MM-dd")" asp-route-SomenteVencidos="@Model.SomenteVencidos">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>
