@page
@model CorteCor.Pages.Financeiro.RelatoriosModel
@using System.Text.Json
@{
    ViewData["Title"] = "Relatórios Financeiros";
    var inadimplenciaLabels = Model.Relatorio.InadimplenciaPorFaixa.Select(i => i.Nome).ToList();
    var inadimplenciaValores = Model.Relatorio.InadimplenciaPorFaixa.Select(i => i.Valor).ToList();
    var fluxoLabels = Model.Relatorio.FluxoProjetado.Select(f => f.Data.ToString("dd/MM")).ToList();
    var fluxoEntradas = Model.Relatorio.FluxoProjetado.Select(f => f.Entradas).ToList();
    var fluxoSaidas = Model.Relatorio.FluxoProjetado.Select(f => f.Saidas).ToList();
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <h2 class="mb-1">Relatórios Financeiros</h2>
        <div class="text-muted">DRE, inadimplência, concentração de receitas e fluxo projetado.</div>
    </div>
    <a class="btn btn-primary" asp-page="/Financeiro/Index">Voltar ao dashboard</a>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Data início</label>
                <input type="date" class="form-control" name="dataInicio" value="@Model.DataInicio.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Data fim</label>
                <input type="date" class="form-control" name="dataFim" value="@Model.DataFim.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-6 text-md-end">
                <button class="btn btn-primary" type="submit">Atualizar relatórios</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-semibold">Fluxo projetado</div>
            <div class="card-body">
                <canvas id="fluxoProjetadoChart" height="140"></canvas>
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-semibold">Inadimplência por faixa</div>
            <div class="card-body">
                <canvas id="inadimplenciaChart" height="140"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-6">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white fw-semibold">Receitas por plano</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Plano</th>
                                <th>Quantidade</th>
                                <th class="text-end">Valor</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Relatorio.ReceitasPorPlano)
                            {
                                <tr>
                                    <td>@item.Nome</td>
                                    <td>@item.Quantidade</td>
                                    <td class="text-end">R$ @item.Valor.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-semibold">Receitas por forma</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Forma</th>
                                <th>Quantidade</th>
                                <th class="text-end">Valor</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Relatorio.ReceitasPorForma)
                            {
                                <tr>
                                    <td>@item.Nome</td>
                                    <td>@item.Quantidade</td>
                                    <td class="text-end">R$ @item.Valor.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-6">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white fw-semibold">Despesas por plano</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Plano</th>
                                <th>Quantidade</th>
                                <th class="text-end">Valor</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Relatorio.DespesasPorPlano)
                            {
                                <tr>
                                    <td>@item.Nome</td>
                                    <td>@item.Quantidade</td>
                                    <td class="text-end">R$ @item.Valor.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-semibold">Títulos do período</div>
            <div class="card-body">
                <div class="table-responsive" style="max-height: 420px;">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Tipo</th>
                                <th>Descrição</th>
                                <th>Venc.</th>
                                <th>Status</th>
                                <th class="text-end">Valor</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var titulo in Model.Relatorio.Titulos.Take(20))
                            {
                                <tr>
                                    <td>@titulo.Tipo</td>
                                    <td>@titulo.Descricao</td>
                                    <td>@titulo.DataVencimento.ToString("dd/MM/yyyy")</td>
                                    <td>@titulo.Status</td>
                                    <td class="text-end">R$ @titulo.ValorOriginal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        new Chart(document.getElementById('fluxoProjetadoChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(JsonSerializer.Serialize(fluxoLabels)),
                datasets: [
                    { label: 'Entradas', data: @Html.Raw(JsonSerializer.Serialize(fluxoEntradas)), backgroundColor: '#16a34a' },
                    { label: 'Saídas', data: @Html.Raw(JsonSerializer.Serialize(fluxoSaidas)), backgroundColor: '#dc2626' }
                ]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });

        new Chart(document.getElementById('inadimplenciaChart'), {
            type: 'pie',
            data: {
                labels: @Html.Raw(JsonSerializer.Serialize(inadimplenciaLabels)),
                datasets: [{ data: @Html.Raw(JsonSerializer.Serialize(inadimplenciaValores)), backgroundColor: ['#f59e0b','#f97316','#ef4444','#991b1b'] }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });
    </script>
}

