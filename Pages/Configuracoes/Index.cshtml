@section Scripts {
    <script>
        $(document).ready(function() {
            // Manter aba ativa após refresh
            var activeTab = localStorage.getItem('activeTab');
            if (activeTab) {
                var triggerEl = document.querySelector('#configTabs button[data-bs-target="' + activeTab + '"]');
                if (triggerEl) bootstrap.Tab.getOrCreateInstance(triggerEl).show();
            }

            var tabEl = document.querySelectorAll('button[data-bs-toggle="tab"]');
            tabEl.forEach(function(el) {
                el.addEventListener('shown.bs.tab', function (event) {
                    localStorage.setItem('activeTab', event.target.getAttribute('data-bs-target'));
                });
            });

            // Máscaras
            if ($.fn.inputmask) {
                $(".phone").inputmask("(99) 99999-9999");
                $(".cep").inputmask("99999-999");
                $(".cnpj").inputmask("99.999.999/9999-99");
            } else {
                // Fallback simples se inputmask não estiver carregado (embora deva estar via layout)
                $(".phone").attr("placeholder", "(99) 99999-9999");
                $(".cep").attr("placeholder", "99999-999");
                $(".cnpj").attr("placeholder", "99.999.999/9999-99");
            }
        });

        function abrirModalPlano() {
            $('#plano_id').val(0);
            $('#plano_codigo').val('');
            $('#plano_descricao').val('');
            $('#plano_tipo').val('R');
            new bootstrap.Modal(document.getElementById('modalPlano')).show();
        }

        function editarPlano(p) {
            $('#plano_id').val(p.idPlano);
            $('#plano_codigo').val(p.codigo);
            $('#plano_descricao').val(p.descricao);
            $('#plano_tipo').val(p.tipo);
            new bootstrap.Modal(document.getElementById('modalPlano')).show();
        }

        function abrirModalConta() {
            $('#conta_id').val(0);
            $('#conta_nome').val('');
            $('#conta_tipo').val('Banco');
            $('#conta_banco').val('');
            $('#conta_agencia').val('');
            $('#conta_conta').val('');
            $('#conta_saldo').val('0.00');
            new bootstrap.Modal(document.getElementById('modalConta')).show();
        }

        function editarConta(c) {
            $('#conta_id').val(c.idConta);
            $('#conta_nome').val(c.nome);
            $('#conta_tipo').val(c.tipo);
            $('#conta_banco').val(c.banco);
            $('#conta_agencia').val(c.agencia);
            $('#conta_conta').val(c.conta);
            $('#conta_saldo').val(c.saldoInicial);
            new bootstrap.Modal(document.getElementById('modalConta')).show();
        }

        function abrirModalMeio() {
            $('#meio_id').val(0);
            $('#meio_nome').val('');
            $('#meio_tipo').val('Cartão de Crédito');
            $('#meio_gateway').val('');
            $('#meio_taxa').val('0');
            $('#meio_prazo').val('0');
            $('#meio_ativo').prop('checked', true);
            $('#sectionMP').hide();
            new bootstrap.Modal(document.getElementById('modalMeio')).show();
        }

        function editarMeio(m) {
            $('#meio_id').val(m.idMeioPagamento);
            $('#meio_nome').val(m.nome);
            $('#meio_tipo').val(m.tipo);
            $('#meio_gateway').val(m.gateway);
            $('#meio_taxa').val(m.taxaPercentual);
            $('#meio_prazo').val(m.prazoRecebimentoDias);
            $('#meio_ativo').prop('checked', m.ativo);
            
            if (m.gateway === 'MercadoPago') {
                $('#sectionMP').show();
                $('#meio_mp_token').val(m.mpAccessTokenProd);
                $('#meio_mp_prod').prop('checked', m.mpProduction);
            } else {
                $('#sectionMP').hide();
            }
            
            new bootstrap.Modal(document.getElementById('modalMeio')).show();
        }

        $('#meio_gateway').on('change', function() {
            if ($(this).val() === 'MercadoPago') $('#sectionMP').show();
            else $('#sectionMP').hide();
        });

        function abrirModalApi() {
            new bootstrap.Modal(document.getElementById('modalApi')).show();
        }
    </script>
}
