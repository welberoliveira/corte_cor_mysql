@page
@model ErrorModel
@{
    ViewData["Title"] = "Erro";
}

<h1 class="text-danger">Erro.</h1>
<h2 class="text-danger">Um erro ocorreu durante o processamento do seu pedido.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<p>
    <strong>Detalhes do erro:</strong> @Model.ErrorMessage
</p>
<p>
    <strong>Stack Trace:</strong> <pre>@Model.StackTrace</pre>
</p>
