@page
@model CorteCor.Pages.PessoaCadastroModel
@{
    ViewData["Title"] = "Cadastrar Cliente / Fornecedor / Lead";
    var ufs = new[] { "AC", "AL", "AP", "AM", "BA", "CE", "DF", "ES", "GO", "MA", "MT", "MS", "MG", "PA", "PB", "PR", "PE", "PI", "RJ", "RN", "RS", "RO", "RR", "SC", "SP", "SE", "TO" };
}

<div class="container pessoa-cadastro-page">
    <h4>Cadastrar Cliente / Fornecedor / Lead</h4>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert alert-@Model.MensagemTipo">
            @Model.Mensagem
        </div>
    }

    <form method="post" id="pessoaCadastroForm">
        <input type="hidden" name="id" value="@Model.Pessoa?.IdPessoa">
        <input type="hidden" id="telefone" name="telefone" value="@Model.Pessoa?.Telefone">
        <input type="hidden" id="email" name="email" value="@Model.Pessoa?.Email">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="row mb-3">
            <div class="col-md-12">
                <label class="font-weight-bold d-block">Tipo de contato</label>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" id="isCliente" name="isCliente" @(Model.Pessoa?.IsCliente == true || Model.Pessoa?.IdPessoa == 0 ? "checked" : "")>
                    <label class="form-check-label" for="isCliente">Cliente</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" id="isFornecedor" name="isFornecedor" @(Model.Pessoa?.IsFornecedor == true ? "checked" : "")>
                    <label class="form-check-label" for="isFornecedor">Fornecedor</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" id="isLead" name="isLead" @(Model.Pessoa?.IsLead == true ? "checked" : "")>
                    <label class="form-check-label" for="isLead">Lead</label>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 form-group">
                <label for="cpfCnpj">CPF/CNPJ</label>
                <div class="input-group">
                    <input type="text" id="cpfCnpj" name="cpfCnpj" class="form-control" value="@Model.Pessoa?.CpfCnpj">
                    <span class="input-group-text" id="cpfCnpjSpinner" style="display:none;">
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                    </span>
                </div>
            </div>
            <div class="col-md-6 form-group">
                <label for="nome">Nome</label>
                <input type="text" id="nome" name="nome" class="form-control" required value="@Model.Pessoa?.Nome">
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 form-group">
                <label>Telefone</label>
                <div id="telefonesContainer" class="contact-list"></div>
                <button type="button" class="btn btn-outline-primary btn-sm mt-2" id="adicionarTelefone">Adicionar telefone</button>
            </div>
            <div class="col-md-6 form-group">
                <label>E-mail</label>
                <div id="emailsContainer" class="contact-list"></div>
                <button type="button" class="btn btn-outline-primary btn-sm mt-2" id="adicionarEmail">Adicionar e-mail</button>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 form-group">
                <label for="nomeContato">Nome contato</label>
                <input type="text" id="nomeContato" name="nomeContato" class="form-control" value="@Model.Pessoa?.NomeContato">
            </div>
        </div>

        <div class="cadastro-section mt-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0">Endere&ccedil;o</h5>
                <button type="button" class="btn btn-outline-primary btn-sm" data-toggle-section data-bs-toggle="collapse" data-bs-target="#enderecoCampos" aria-expanded="false" aria-controls="enderecoCampos">
                    Mostrar
                </button>
            </div>
            <hr />
            <div id="enderecoCampos" class="collapse">
                <div class="row">
                    <div class="col-md-3 form-group">
                        <label for="cep">CEP</label>
                        <div class="input-group">
                            <input type="text" id="cep" name="cep" class="form-control" value="@Model.Pessoa?.Cep">
                            <span class="input-group-text" id="cepSpinner" style="display:none;">
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                            </span>
                        </div>
                    </div>
                    <div class="col-md-7 form-group">
                        <label for="logradouro">Logradouro</label>
                        <input type="text" id="logradouro" name="logradouro" class="form-control" value="@Model.Pessoa?.Logradouro">
                    </div>
                    <div class="col-md-2 form-group">
                        <label for="numero">N&uacute;mero</label>
                        <input type="text" id="numero" name="numero" class="form-control" value="@Model.Pessoa?.Numero">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label for="complemento">Complemento</label>
                        <input type="text" id="complemento" name="complemento" class="form-control" value="@Model.Pessoa?.Complemento">
                    </div>
                    <div class="col-md-3 form-group">
                        <label for="bairro">Bairro</label>
                        <input type="text" id="bairro" name="bairro" class="form-control" value="@Model.Pessoa?.Bairro">
                    </div>
                    <div class="col-md-3 form-group">
                        <label for="cidade">Cidade</label>
                        <input type="text" id="cidade" name="cidade" class="form-control" value="@Model.Pessoa?.Cidade">
                    </div>
                    <div class="col-md-2 form-group">
                        <label for="uf">UF</label>
                        <select id="uf" name="uf" class="form-control">
                            <option value="">--</option>
                            @foreach (var sigla in ufs)
                            {
                                var isSelected = Model.Pessoa?.UF == sigla ? "selected" : "";
                                @Html.Raw($"<option value='{sigla}' {isSelected}>{sigla}</option>")
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="cadastro-section mt-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0">Endere&ccedil;o de entrega</h5>
                <div class="d-flex gap-2 flex-wrap">
                    <button type="button" class="btn btn-outline-primary btn-sm" data-toggle-section data-bs-toggle="collapse" data-bs-target="#enderecoEntregaCampos" aria-expanded="false" aria-controls="enderecoEntregaCampos">
                        Mostrar
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" id="copiarEnderecoEntrega">
                        Copiar endere&ccedil;o principal
                    </button>
                </div>
            </div>
            <hr />
            <div id="enderecoEntregaCampos" class="collapse">
                <div class="row">
                    <div class="col-md-3 form-group">
                        <label for="entCep">CEP</label>
                        <input type="text" id="entCep" name="entCep" class="form-control" value="@Model.Pessoa?.EntCep">
                    </div>
                    <div class="col-md-7 form-group">
                        <label for="entLogradouro">Logradouro</label>
                        <input type="text" id="entLogradouro" name="entLogradouro" class="form-control" value="@Model.Pessoa?.EntLogradouro">
                    </div>
                    <div class="col-md-2 form-group">
                        <label for="entNumero">N&uacute;mero</label>
                        <input type="text" id="entNumero" name="entNumero" class="form-control" value="@Model.Pessoa?.EntNumero">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label for="entComplemento">Complemento</label>
                        <input type="text" id="entComplemento" name="entComplemento" class="form-control" value="@Model.Pessoa?.EntComplemento">
                    </div>
                    <div class="col-md-3 form-group">
                        <label for="entBairro">Bairro</label>
                        <input type="text" id="entBairro" name="entBairro" class="form-control" value="@Model.Pessoa?.EntBairro">
                    </div>
                    <div class="col-md-3 form-group">
                        <label for="entCidade">Cidade</label>
                        <input type="text" id="entCidade" name="entCidade" class="form-control" value="@Model.Pessoa?.EntCidade">
                    </div>
                    <div class="col-md-2 form-group">
                        <label for="entUf">UF</label>
                        <select id="entUf" name="entUf" class="form-control">
                            <option value="">--</option>
                            @foreach (var sigla in ufs)
                            {
                                var isSelected = Model.Pessoa?.EntUf == sigla ? "selected" : "";
                                @Html.Raw($"<option value='{sigla}' {isSelected}>{sigla}</option>")
                            }
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label for="entNome">Nome/Raz&atilde;o Social (entrega)</label>
                        <input type="text" id="entNome" name="entNome" class="form-control" value="@Model.Pessoa?.EntNome">
                    </div>
                    <div class="col-md-4 form-group">
                        <label for="entCpfCnpj">CPF/CNPJ (entrega)</label>
                        <input type="text" id="entCpfCnpj" name="entCpfCnpj" class="form-control" value="@Model.Pessoa?.EntCpfCnpj">
                    </div>
                    <div class="col-md-4 form-group">
                        <label for="entInscricaoEstadual">Inscri&ccedil;&atilde;o Estadual (entrega)</label>
                        <input type="text" id="entInscricaoEstadual" name="entInscricaoEstadual" class="form-control" value="@Model.Pessoa?.EntInscricaoEstadual">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="entEmail">E-mail (entrega)</label>
                        <input type="email" id="entEmail" name="entEmail" class="form-control" value="@Model.Pessoa?.EntEmail">
                    </div>
                    <div class="col-md-6 form-group">
                        <label for="entTelefone">Telefone (entrega)</label>
                        <input type="text" id="entTelefone" name="entTelefone" class="form-control" value="@Model.Pessoa?.EntTelefone">
                    </div>
                </div>
            </div>
        </div>

        <div class="cadastro-section mt-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0">Informa&ccedil;&otilde;es da empresa</h5>
                <button type="button" class="btn btn-outline-primary btn-sm" data-toggle-section data-bs-toggle="collapse" data-bs-target="#informacoesEmpresaCampos" aria-expanded="false" aria-controls="informacoesEmpresaCampos">
                    Mostrar
                </button>
            </div>
            <hr />
            <div id="informacoesEmpresaCampos" class="collapse">
                <div class="row">
                    <div class="col-md-4 form-group">
                        <label for="razaoSocial">Raz&atilde;o Social</label>
                        <input type="text" id="razaoSocial" name="razaoSocial" class="form-control" value="@Model.Pessoa?.RazaoSocial">
                    </div>
                    <div class="col-md-4 form-group">
                        <label for="nomeFantasia">Nome Fantasia</label>
                        <input type="text" id="nomeFantasia" name="nomeFantasia" class="form-control" value="@Model.Pessoa?.NomeFantasia">
                    </div>
                    <div class="col-md-4 form-group">
                        <label for="cnae">CNAE</label>
                        <input type="text" id="cnae" name="cnae" class="form-control" value="@Model.Pessoa?.Cnae">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label for="dataNascimento">Data nasc./funda&ccedil;&atilde;o</label>
                        <input type="date" id="dataNascimento" name="dataNascimento" class="form-control" value="@(Model.Pessoa?.DataNascimento?.ToString("yyyy-MM-dd") ?? "")">
                    </div>
                    <div class="col-md-4 form-group">
                        <label for="pais">Pa&iacute;s</label>
                        <input type="text" id="pais" name="pais" class="form-control" value="@Model.Pessoa?.Pais">
                    </div>
                    <div class="col-md-4 form-group">
                        <label for="idEstrangeiro">ID Estrangeiro</label>
                        <input type="text" id="idEstrangeiro" name="idEstrangeiro" class="form-control" value="@Model.Pessoa?.IdEstrangeiro">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label for="inscricaoEstadual">Inscri&ccedil;&atilde;o Estadual</label>
                        <input type="text" id="inscricaoEstadual" name="inscricaoEstadual" class="form-control" value="@Model.Pessoa?.InscricaoEstadual">
                    </div>
                    <div class="col-md-4 form-group">
                        <label for="inscricaoMunicipal">Inscri&ccedil;&atilde;o Municipal</label>
                        <input type="text" id="inscricaoMunicipal" name="inscricaoMunicipal" class="form-control" value="@Model.Pessoa?.InscricaoMunicipal">
                    </div>
                    <div class="col-md-4 form-group">
                        <label for="ieSubstTrib">IE Subst. Trib.</label>
                        <input type="text" id="ieSubstTrib" name="ieSubstTrib" class="form-control" value="@Model.Pessoa?.IESubstTrib">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3 form-group align-self-end">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="consumidorFinal" name="consumidorFinal" @(Model.Pessoa?.ConsumidorFinal == true ? "checked" : "")>
                            <label class="form-check-label" for="consumidorFinal">Consumidor final?</label>
                        </div>
                    </div>
                    <div class="col-md-3 form-group">
                        <label for="indicadorIE">Indicador IE</label>
                        <select id="indicadorIE" name="indicadorIE" class="form-control">
                            <option value="">Selecione...</option>
                            @if (Model.Pessoa?.IndicadorIE == 1) { <option value="1" selected>1 - Contribuinte ICMS</option> } else { <option value="1">1 - Contribuinte ICMS</option> }
                            @if (Model.Pessoa?.IndicadorIE == 2) { <option value="2" selected>2 - Contribuinte Isento</option> } else { <option value="2">2 - Contribuinte Isento</option> }
                            @if (Model.Pessoa?.IndicadorIE == 9) { <option value="9" selected>9 - N&atilde;o Contribuinte</option> } else { <option value="9">9 - N&atilde;o Contribuinte</option> }
                        </select>
                    </div>
                    <div class="col-md-3 form-group">
                        <label for="suframa">Suframa</label>
                        <input type="text" id="suframa" name="suframa" class="form-control" value="@Model.Pessoa?.Suframa">
                    </div>
                    <div class="col-md-3 form-group">
                        <label for="dataComemorativa">Data comemorativa</label>
                        <input type="date" id="dataComemorativa" name="dataComemorativa" class="form-control" value="@(Model.Pessoa?.DataComemorativa?.ToString("yyyy-MM-dd") ?? "")">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-8 form-group">
                        <label for="descricaoComemoracao">Descri&ccedil;&atilde;o da comemora&ccedil;&atilde;o</label>
                        <input type="text" id="descricaoComemoracao" name="descricaoComemoracao" class="form-control" value="@Model.Pessoa?.DescricaoComemoracao">
                    </div>
                    <div class="col-md-4 form-group">
                        <label for="tags">Palavras-chave (tags)</label>
                        <input type="text" id="tags" name="tags" class="form-control" value="@Model.Pessoa?.Tags" placeholder="Ex.: Revenda, VIP, Especial">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="basesLegais">Bases legais (LGPD)</label>
                        <textarea id="basesLegais" name="basesLegais" class="form-control" rows="3">@Model.Pessoa?.BasesLegais</textarea>
                    </div>
                    <div class="col-md-6 form-group">
                        <label for="observacoes">Observa&ccedil;&otilde;es</label>
                        <textarea id="observacoes" name="observacoes" class="form-control" rows="3">@Model.Pessoa?.Observacoes</textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-6">
                <button type="submit" class="btn btn-primary">@Model.ButtonText</button>
                <a class="btn btn-secondary" asp-page="/PessoaLista">Cancelar</a>
            </div>
            <div class="col-md-6 text-end">
                @{
                    bool cadastroSalvo = (Model.Pessoa?.IdPessoa ?? 0) > 0;
                }
                @if (cadastroSalvo)
                {
                    <button type="submit" asp-page-handler="EnviarCredenciais" class="btn btn-secondary" id="btnEnviarCredenciais">
                        <i class="bi bi-envelope"></i> Enviar credenciais
                    </button>
                }
                else
                {
                    <button type="submit" asp-page-handler="EnviarCredenciais" class="btn btn-secondary" id="btnEnviarCredenciais" disabled>
                        <i class="bi bi-envelope"></i> Enviar credenciais
                    </button>
                    <div class="alert alert-warning mt-2 small" id="alertaCredenciais">
                        <i class="bi bi-info-circle"></i>
                        Conclua e salve o cadastro antes de gerar os dados de acesso.
                    </div>
                }
            </div>
        </div>
    </form>
</div>

<style>
    .pessoa-cadastro-page .form-group {
        margin-bottom: 1rem;
    }

    .contact-row {
        display: flex;
        gap: .5rem;
        margin-bottom: .5rem;
    }

    .contact-row .form-control {
        min-width: 0;
    }

    .contact-row .btn {
        white-space: nowrap;
    }

    .contact-remove-btn {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
        color: #fff !important;
        opacity: 1 !important;
        visibility: visible !important;
    }

    .contact-remove-btn:hover,
    .contact-remove-btn:focus {
        background-color: #bb2d3b !important;
        border-color: #b02a37 !important;
        color: #fff !important;
    }
</style>

<script>
    $(document).ready(function () {
        const telefonesIniciais = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TelefonesCadastro));
        const emailsIniciais = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.EmailsCadastro));

        function normalizarLista(valores) {
            const itens = Array.isArray(valores) ? valores : [valores];
            return [...new Set(itens.map(function (valor) {
                return (valor || "").trim();
            }).filter(Boolean))];
        }

        function criarGerenciadorContatos(config) {
            let itens = normalizarLista(config.valoresIniciais);
            if (itens.length === 0) {
                itens = [""];
            }

            const container = $(config.container);
            const hidden = $(config.hidden);

            function sincronizar() {
                hidden.val(itens.map(function (valor) {
                    return (valor || "").trim();
                }).filter(Boolean).join("; "));
            }

            function renderizar() {
                container.empty();

                itens.forEach(function (valor, index) {
                    const row = $('<div class="contact-row"></div>');
                    const input = $('<input class="form-control">')
                        .attr("type", config.tipo || "text")
                        .attr("placeholder", config.placeholder)
                        .val(valor);

                    if (config.mascaraTelefone) {
                        input.inputmask("(99) 99999-9999");
                    }

                    input.on("input", function () {
                        itens[index] = $(this).val();
                        sincronizar();
                    });

                    const remover = $('<button type="button" class="btn btn-danger btn-sm contact-remove-btn">Excluir</button>');
                    remover.on("click", function () {
                        itens.splice(index, 1);
                        if (itens.length === 0) {
                            itens = [""];
                        }
                        renderizar();
                    });

                    row.append(input, remover);
                    container.append(row);
                });

                sincronizar();
            }

            $(config.botaoAdicionar).on("click", function () {
                itens.push("");
                renderizar();
                container.find("input").last().focus();
            });

            renderizar();

            return {
                setValues: function (valores) {
                    itens = normalizarLista(valores);
                    if (itens.length === 0) {
                        itens = [""];
                    }
                    renderizar();
                },
                getFirst: function () {
                    return normalizarLista(itens)[0] || "";
                },
                sync: sincronizar
            };
        }

        const telefoneManager = criarGerenciadorContatos({
            container: "#telefonesContainer",
            hidden: "#telefone",
            botaoAdicionar: "#adicionarTelefone",
            placeholder: "(00) 00000-0000",
            valoresIniciais: telefonesIniciais,
            mascaraTelefone: true
        });

        const emailManager = criarGerenciadorContatos({
            container: "#emailsContainer",
            hidden: "#email",
            botaoAdicionar: "#adicionarEmail",
            placeholder: "email@exemplo.com",
            tipo: "email",
            valoresIniciais: emailsIniciais
        });

        $("#cep").inputmask("99999-999");
        $("#entCep").inputmask("99999-999");
        $("#entTelefone").inputmask("(99) 99999-9999");

        var cpfCnpjField = $("#cpfCnpj");
        cpfCnpjField.attr("maxlength", "18");

        cpfCnpjField.on("input", function () {
            var val = $(this).val().replace(/\D/g, "");
            if (val.length > 14) val = val.substring(0, 14);

            if (val.length <= 11) {
                val = val.replace(/(\d{3})(\d)/, "$1.$2");
                val = val.replace(/(\d{3})(\d)/, "$1.$2");
                val = val.replace(/(\d{3})(\d{1,2})$/, "$1-$2");
            } else {
                val = val.replace(/^(\d{2})(\d)/, "$1.$2");
                val = val.replace(/^(\d{2})\.(\d{3})(\d)/, "$1.$2.$3");
                val = val.replace(/\.(\d{3})(\d)/, ".$1/$2");
                val = val.replace(/(\d{4})(\d{1,2})$/, "$1-$2");
            }

            $(this).val(val);
        });

        cpfCnpjField.on("blur", function () {
            var val = $(this).val().replace(/\D/g, "");
            if (val.length !== 14) return;

            $("#cpfCnpjSpinner").show();

            fetch("?handler=ConsultaCnpj&cnpj=" + val)
                .then(function (response) { return response.json(); })
                .then(function (data) {
                    $("#cpfCnpjSpinner").hide();
                    if (data.sucesso) {
                        $("#nome").val("");
                        $("#razaoSocial").val("");
                        $("#nomeFantasia").val("");
                        $("#cnae").val("");
                        telefoneManager.setValues([]);
                        emailManager.setValues([]);
                        $("#dataNascimento").val("");
                        $("#inscricaoEstadual").val("");
                        $("#inscricaoMunicipal").val("");
                        $("#cep").val("");
                        $("#logradouro").val("");
                        $("#numero").val("");
                        $("#complemento").val("");
                        $("#bairro").val("");
                        $("#cidade").val("");
                        $("#uf").val("");

                        $("#razaoSocial").val(data.razaoSocial);
                        $("#nomeFantasia").val(data.nomeFantasia);
                        $("#cnae").val(data.cnae);

                        if (data.telefone) telefoneManager.setValues([data.telefone]);
                        if (data.email) emailManager.setValues([data.email]);
                        if (data.dataFundacao) {
                            var partes = data.dataFundacao.split("/");
                            if (partes.length === 3) {
                                $("#dataNascimento").val(partes[2] + "-" + partes[1] + "-" + partes[0]);
                            }
                        }

                        if (data.cep) {
                            $("#cep").val(data.cep.replace(/\D/g, "").replace(/(\d{5})(\d{3})/, "$1-$2"));
                        }
                        if (data.logradouro) $("#logradouro").val(data.logradouro);
                        if (data.numero) $("#numero").val(data.numero);
                        if (data.complemento) $("#complemento").val(data.complemento);
                        if (data.bairro) $("#bairro").val(data.bairro);
                        if (data.cidade) $("#cidade").val(data.cidade);
                        if (data.uf) $("#uf").val(data.uf);

                        if (!$("#nome").val()) {
                            $("#nome").val(data.nomeFantasia || data.razaoSocial);
                        }
                    } else {
                        alert("CNPJ: " + (data.mensagem || "Nao encontrado."));
                    }
                })
                .catch(function (err) {
                    $("#cpfCnpjSpinner").hide();
                    console.error("Erro ao consultar CNPJ:", err);
                });
        });

        $("#cep").on("blur", function () {
            var val = $(this).val().replace(/\D/g, "");
            if (val.length !== 8) return;

            $("#cepSpinner").show();

            fetch("?handler=ConsultaCep&cep=" + val)
                .then(function (response) { return response.json(); })
                .then(function (data) {
                    $("#cepSpinner").hide();
                    if (data.sucesso) {
                        $("#logradouro").val(data.logradouro);
                        $("#bairro").val(data.bairro);
                        $("#cidade").val(data.cidade);
                        $("#uf").val(data.uf);
                        $("#numero").focus();
                    } else {
                        alert("CEP: " + (data.mensagem || "Nao encontrado."));
                    }
                })
                .catch(function (err) {
                    $("#cepSpinner").hide();
                    console.error("Erro ao consultar CEP:", err);
                });
        });

        $("#copiarEnderecoEntrega").on("click", function () {
            $("#entCep").val($("#cep").val());
            $("#entLogradouro").val($("#logradouro").val());
            $("#entNumero").val($("#numero").val());
            $("#entComplemento").val($("#complemento").val());
            $("#entBairro").val($("#bairro").val());
            $("#entCidade").val($("#cidade").val());
            $("#entUf").val($("#uf").val());

            if (!$("#entNome").val()) {
                $("#entNome").val($("#razaoSocial").val() || $("#nome").val());
            }

            if (!$("#entCpfCnpj").val()) {
                $("#entCpfCnpj").val($("#cpfCnpj").val());
            }

            if (!$("#entEmail").val()) {
                $("#entEmail").val(emailManager.getFirst());
            }

            if (!$("#entTelefone").val()) {
                $("#entTelefone").val(telefoneManager.getFirst());
            }
        });

        document.querySelectorAll("[data-toggle-section]").forEach(function (button) {
            var targetSelector = button.getAttribute("data-bs-target");
            var target = document.querySelector(targetSelector);
            if (!target) return;

            function atualizarTexto() {
                button.textContent = target.classList.contains("show") ? "Ocultar" : "Mostrar";
                button.setAttribute("aria-expanded", target.classList.contains("show") ? "true" : "false");
            }

            target.addEventListener("shown.bs.collapse", atualizarTexto);
            target.addEventListener("hidden.bs.collapse", atualizarTexto);
            atualizarTexto();
        });

        $("#pessoaCadastroForm").on("submit", function () {
            telefoneManager.sync();
            emailManager.sync();
        });
    });
</script>
